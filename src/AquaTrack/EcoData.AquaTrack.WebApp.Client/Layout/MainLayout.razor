@inherits LayoutComponentBase
@using BlazingSingularity
@using BlazingSingularity.Commands
@using EcoData.AquaTrack.WebApp.Client.Pages
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Themes
@inject AuthStateService AuthState
@inject ClientAuthStateProvider AuthStateProvider
@inject INavigationService Navigation
@implements IDisposable

<MudThemeProvider Theme="AppThemes.Azure" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0"
               Style="background-color: var(--mud-palette-drawer-background); color: var(--mud-palette-text-primary);" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Edge="Edge.Start" Size="Size.Small"
                       Disabled="@(!Navigation.CanGoBack)" OnClick="NavigateBack" />
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">AquaTrack</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="ToggleTheme" />
        </MudHidden>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Docked" Variant="DrawerVariant.Responsive"
               Elevation="1">
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
            <MudToolBar Dense="true">
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" OnClick="ToggleDrawer"
                               Edge="Edge.Start" />
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Outlined.Notifications" Color="Color.Inherit" />
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit" OnClick="ToggleTheme" Edge="Edge.End" />
            </MudToolBar>
        </MudHidden>

        <MudNavMenu Class="pt-4">
            <MudNavLink Href="@HomePage.Path" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Home">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="@SensorsPage.Path" Icon="@Icons.Material.Outlined.Sensors">Sensors</MudNavLink>
            <MudNavGroup Title="Organizations" Icon="@Icons.Material.Outlined.Business" Expanded="true">
                <MudNavLink Href="/organizations/discover" Icon="@Icons.Material.Outlined.Explore">Discover</MudNavLink>
                <MudNavLink Href="/organizations/my" Icon="@Icons.Material.Outlined.FolderShared">My Orgs</MudNavLink>
                <MudNavLink Href="/organizations/requests" Icon="@Icons.Material.Outlined.Mail">Requests</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="@SensorMapPage.Path" Icon="@Icons.Material.Outlined.Map">Map</MudNavLink>
        </MudNavMenu>

        <MudSpacer />

        <MudDivider />
        <MudList T="string" Dense="true">
            @if (AuthState.IsAuthenticated)
            {
                <MudListItem>
                    <ChildContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Small">
                                @GetUserInitial()
                            </MudAvatar>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@AuthState.CurrentUser?.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@AuthState.CurrentUser?.Email</MudText>
                            </MudStack>
                        </MudStack>
                    </ChildContent>
                </MudListItem>
                <MudListItem OnClick="LogoutAsync" Icon="@Icons.Material.Outlined.Logout">
                    <ChildContent>
                        <MudText Typo="Typo.body2">Sign Out</MudText>
                    </ChildContent>
                </MudListItem>
            }
            else
            {
                <MudListItem Href="@LoginPage.Path" Icon="@Icons.Material.Outlined.Login">
                    <ChildContent>
                        <MudText Typo="Typo.body2">Sign In</MudText>
                    </ChildContent>
                </MudListItem>
            }
        </MudList>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-4 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private void NavigateBack()
    {
        Navigation.GoBack();
    }

    protected override async Task OnInitializedAsync()
    {
        AuthState.SetAuthStateProvider(AuthStateProvider);
        AuthState.OnAuthStateChanged += HandleAuthStateChanged;
        Navigation.OnStateChanged += HandleNavigationStateChanged;
        await AuthState.InitializeAsync();
    }

    private void HandleAuthStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleNavigationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetUserInitial()
    {
        var name = AuthState.CurrentUser?.DisplayName;
        return string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();
    }

    [RelayCommand]
    private async Task Logout()
    {
        await AuthState.LogoutAsync();
    }

    private async Task LogoutAsync()
    {
        await LogoutCommand.ExecuteAsync();
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= HandleAuthStateChanged;
        Navigation.OnStateChanged -= HandleNavigationStateChanged;
    }
}
