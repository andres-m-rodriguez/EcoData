@page "/organizations/requests"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Parameters
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Features.OrganizationAccessRequests.Dialogs
@using EcoData.Common.Pagination.Blazor
@inject IOrganizationAccessRequestHttpClient AccessRequestClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject INavigationService Navigation
@inject AuthStateService AuthState

<PageTitle>Access Requests - AquaTrack</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Access Requests</MudText>

@if (!AuthState.IsAuthenticated)
{
    <MudPaper Elevation="1" Class="pa-8 rounded-lg">
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Size="Size.Large" Color="Color.Info" Variant="Variant.Outlined">
                <MudIcon Icon="@Icons.Material.Outlined.Login" />
            </MudAvatar>
            <MudText Typo="Typo.h6" Align="Align.Center">Sign in to view requests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                Log in to manage your organization access requests.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login" Class="mt-2">
                Sign In
            </MudButton>
        </MudStack>
    </MudPaper>
}
else
{
    @* Search and Filters *@
    <MudPaper Elevation="1" Class="pa-4 rounded-lg mb-4">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudTextField @bind-Value="_searchText"
                              Placeholder="Search by organization name..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="300"
                              OnDebounceIntervalElapsed="OnSearchChanged"
                              Clearable="true"
                              OnClearButtonClick="ClearSearch"
                              Class="flex-grow-1" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenRequestDialog">
                    New Request
                </MudButton>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mr-2">Status:</MudText>
                <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="_statusFilter" SelectedValueChanged="OnStatusFilterChanged">
                    <MudChip Text="All" Value="@((string?)null)" Default="true"
                             Variant="@(_statusFilter is null ? Variant.Filled : Variant.Outlined)"
                             Color="Color.Default" />
                    <MudChip Text="Pending" Value="@("Pending")"
                             Variant="@(_statusFilter == "Pending" ? Variant.Filled : Variant.Outlined)"
                             Color="Color.Warning" />
                    <MudChip Text="Approved" Value="@("Approved")"
                             Variant="@(_statusFilter == "Approved" ? Variant.Filled : Variant.Outlined)"
                             Color="Color.Success" />
                    <MudChip Text="Rejected" Value="@("Rejected")"
                             Variant="@(_statusFilter == "Rejected" ? Variant.Filled : Variant.Outlined)"
                             Color="Color.Error" />
                </MudChipSet>
                @if (HasActiveFilters)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearAllFilters">
                        Clear Filters
                    </MudButton>
                }
            </MudStack>
        </MudStack>
    </MudPaper>

    @* Requests List *@
    <MudPaper Elevation="1" Class="rounded-lg">
        <EcoDataVirtualizedList @ref="_listRef"
                                TItem="OrganizationAccessRequestDto"
                                TParams="OrganizationAccessRequestParameters"
                                ItemsProvider="(p, ct) => AccessRequestClient.GetMyRequestsAsync(p)"
                                ParametersBuilder="CreateParameters"
                                CursorSelector="r => r.Id"
                                ItemSize="100"
                                OverscanCount="3">
            <LoadingTemplate>
                @for (var i = 0; i < 3; i++)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                        <MudStack Spacing="1" Class="flex-grow-1">
                            <MudSkeleton Width="50%" Height="20px" />
                            <MudSkeleton Width="30%" Height="14px" />
                        </MudStack>
                        <MudSkeleton Width="80px" Height="24px" />
                    </MudStack>
                }
            </LoadingTemplate>
            <EmptyTemplate>
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">
                        @if (HasActiveFilters)
                        {
                            <text>No matching requests</text>
                        }
                        else
                        {
                            <text>No access requests</text>
                        }
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @if (HasActiveFilters)
                        {
                            <text>Try adjusting your search or filters.</text>
                        }
                        else
                        {
                            <text>You haven't requested access to any organizations yet.</text>
                        }
                    </MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   OnClick="ClearAllFilters" Class="mt-3">
                            Clear Filters
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Explore"
                                   Href="/organizations/discover" Class="mt-3">
                            Discover Organizations
                        </MudButton>
                    }
                </MudStack>
            </EmptyTemplate>
            <PlaceholderTemplate>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                    <MudStack Spacing="1" Class="flex-grow-1">
                        <MudSkeleton Width="50%" Height="20px" />
                        <MudSkeleton Width="30%" Height="14px" />
                    </MudStack>
                </MudStack>
            </PlaceholderTemplate>
            <ItemTemplate Context="request">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                          Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">
                            <MudIcon Icon="@Icons.Material.Filled.Business" />
                        </MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle1">@request.OrganizationName</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Requested @FormatDate(request.CreatedAt)
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(request.RequestMessage))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                    "@request.RequestMessage"
                                </MudText>
                            }
                            @if (request.Status == "Rejected" && !string.IsNullOrWhiteSpace(request.ReviewNotes))
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                    <MudText Typo="Typo.caption">
                                        <strong>Reviewer notes:</strong> @request.ReviewNotes
                                    </MudText>
                                </MudAlert>
                            }
                            @if (request.Status != "Pending" && request.ReviewedAt.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                    @(request.Status == "Approved" ? "Approved" : "Rejected") on @FormatDate(request.ReviewedAt.Value)
                                </MudText>
                            }
                        </MudStack>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @switch (request.Status)
                        {
                            case "Pending":
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">
                                    Pending
                                </MudChip>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => CancelRequest(request)">
                                    Cancel
                                </MudButton>
                                break;
                            case "Approved":
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">
                                    Approved
                                </MudChip>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                           Href="@($"/organizations/{request.OrganizationId}")">
                                    View
                                </MudButton>
                                break;
                            case "Rejected":
                                <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small">
                                    Rejected
                                </MudChip>
                                break;
                        }
                    </MudStack>
                </MudStack>
            </ItemTemplate>
        </EcoDataVirtualizedList>
    </MudPaper>
}

@code {
    private EcoDataVirtualizedList<OrganizationAccessRequestDto, OrganizationAccessRequestParameters>? _listRef;
    private string? _searchText;
    private string? _statusFilter;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || _statusFilter is not null;

    protected override void OnInitialized()
    {
        Navigation.SetFallback("/organizations/my");
    }

    private OrganizationAccessRequestParameters CreateParameters(Guid? cursor) => new(
        PageSize: 20,
        Cursor: cursor,
        Status: _statusFilter,
        Search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText
    );

    private void OnSearchChanged(string _)
    {
        _listRef?.Refresh();
    }

    private void ClearSearch()
    {
        _searchText = null;
        _listRef?.Refresh();
    }

    private void OnStatusFilterChanged(string? status)
    {
        if (_statusFilter == status) return;
        _statusFilter = status;
        _listRef?.Refresh();
    }

    private void ClearAllFilters()
    {
        _searchText = null;
        _statusFilter = null;
        _listRef?.Refresh();
    }

    private async Task OpenRequestDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RequestAccessDialog>("Request Access", options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            _listRef?.Refresh();
        }
    }

    private async Task CancelRequest(OrganizationAccessRequestDto request)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to cancel your access request to \"{request.OrganizationName}\"?" },
            { x => x.ButtonText, "Cancel Request" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Cancel Request", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var cancelResult = await AccessRequestClient.CancelMyRequestAsync(request.Id);
            cancelResult.Switch(
                _ =>
                {
                    Snackbar.Add("Request cancelled successfully", Severity.Success);
                    _listRef?.Refresh();
                },
                _ => Snackbar.Add("Request not found", Severity.Error),
                validation => Snackbar.Add(validation.Errors.FirstOrDefault()?.ErrorMessage ?? "Cannot cancel request", Severity.Error),
                error => Snackbar.Add($"Failed to cancel: {error.Message}", Severity.Error)
            );
        }
    }

    private static string FormatDate(DateTimeOffset date) => date.LocalDateTime.ToString("MMM d, yyyy");
}
