@using BlazingSingularity.Signals

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Reject Request</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4">
            Are you sure you want to reject the access request from <strong>@RequesterName</strong>?
        </MudText>
        <MudTextField @bind-Value="ReviewNotes"
                      Label="Review Notes (Optional)"
                      Placeholder="Add a reason for rejection..."
                      Variant="Variant.Outlined"
                      Lines="3"
                      HelperText="This will be visible to administrators"
                      Class="mb-4" />
        <MudCheckBox @bind-Value="BlockUser" Color="Color.Error" Dense="true">
            <MudText Typo="Typo.body2">
                Also block this user from future requests
            </MudText>
        </MudCheckBox>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Submit">
            @(BlockUser ? "Reject & Block" : "Reject")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string RequesterName { get; set; } = string.Empty;

    [Signal]
    private string? _reviewNotes;

    [Signal]
    private bool _blockUser;

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(new RejectRequestResult(ReviewNotes, BlockUser)));

    public sealed record RejectRequestResult(string? ReviewNotes, bool BlockUser);
}
