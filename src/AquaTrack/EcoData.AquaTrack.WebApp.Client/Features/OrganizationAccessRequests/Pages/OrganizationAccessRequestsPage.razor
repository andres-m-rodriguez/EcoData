@page "/organizations/{OrganizationId:guid}/access-requests"
@using EcoData.AquaTrack.Contracts
@using EcoData.AquaTrack.WebApp.Client.Authorization
@attribute [OrganizationPermission(Permissions.Organization.ManageMembers)]
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Components
@using EcoData.AquaTrack.WebApp.Client.Features.OrganizationAccessRequests.Dialogs
@using EcoData.Common.Pagination.Blazor
@using EcoData.Identity.Contracts.Parameters
@using EcoData.Identity.Contracts.Responses
@using BlazingSingularity.Signals
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject IAccessRequestHttpClient AccessRequestClient
@inject INavigationService Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Access Requests - @(_organization?.Name ?? "Organization") - AquaTrack</PageTitle>

<SearchHeader SearchSignal="SearchTextSignal" Placeholder="Search requests..." EnableSticky="true">
    <Actions>
        <MudSelect T="string" @bind-Value="StatusFilter" Label="Status" Variant="Variant.Outlined"
                   Dense="true" Style="min-width: 150px;">
            <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
            <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
            <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
            <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
        </MudSelect>
    </Actions>
</SearchHeader>

@if (LoadOrganizationCommand.IsLoading)
{
    <MudPaper Elevation="1" Class="rounded-lg">
        @for (var i = 0; i < 5; i++)
        {
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                      Class="pa-3 border-b">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                    <MudStack Spacing="1">
                        <MudSkeleton Width="150px" Height="14px" />
                        <MudSkeleton Width="200px" Height="12px" />
                    </MudStack>
                </MudStack>
                <MudSkeleton Width="70px" Height="24px" Class="rounded-pill" />
            </MudStack>
        }
    </MudPaper>
}
else if (_organization is null)
{
    <MudPaper Elevation="1" Class="pa-8 rounded-lg">
        <MudStack AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
        </MudStack>
    </MudPaper>
}
else
{
    <MudPaper Elevation="1" Class="rounded-lg">
        <EcoDataVirtualizedList @ref="_virtualizedList" TItem="AccessRequestResponse" TParams="AccessRequestParameters"
                                ItemsProvider="GetItemsAsync" ParametersBuilder="BuildParameters" CursorSelector="r => r.Id"
                                ItemSize="65" OverscanCount="3">
            <LoadingTemplate>
                @for (var i = 0; i < 5; i++)
                {
                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                              Class="pa-3 border-b">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                            <MudStack Spacing="1">
                                <MudSkeleton Width="150px" Height="14px" />
                                <MudSkeleton Width="200px" Height="12px" />
                            </MudStack>
                        </MudStack>
                        <MudSkeleton Width="70px" Height="24px" Class="rounded-pill" />
                    </MudStack>
                }
            </LoadingTemplate>
            <EmptyTemplate>
                @if (HasActiveFilters)
                {
                    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No requests found</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            No access requests match your search criteria.
                        </MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAltOff"
                                   OnClick="ClearFilters" Class="mt-3">
                            Clear Filters
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.HowToReg" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No pending requests</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            There are no access requests waiting for review.
                        </MudText>
                    </MudStack>
                }
            </EmptyTemplate>
            <ItemTemplate Context="request">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                          Class="pa-3 border-b">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="3" Class="flex-grow-1 overflow-hidden">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">
                            @request.DisplayName.FirstOrDefault()
                        </MudAvatar>
                        <MudStack Spacing="0" Class="overflow-hidden">
                            <MudText Typo="Typo.body2" Class="mud-text-truncate">@request.DisplayName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mud-text-truncate">@request.Email</MudText>
                            <MudHidden Breakpoint="Breakpoint.SmAndUp" Invert>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @request.CreatedAt.LocalDateTime.ToString("MMM dd, yyyy")
                                </MudText>
                            </MudHidden>
                        </MudStack>
                    </MudStack>

                    <MudChip T="string"
                             Color="@GetStatusColor(request.Status)"
                             Size="Size.Small"
                             Variant="Variant.Filled">
                        @request.Status
                    </MudChip>

                    @if (request.Status == "Pending")
                    {
                        <MudHidden Breakpoint="Breakpoint.SmAndUp" Invert>
                            <MudButtonGroup Size="Size.Small" OverrideStyles="false">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Check"
                                           OnClick="@(() => ApproveRequest(request))">
                                    Approve
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Close"
                                           OnClick="@(() => RejectRequest(request))">
                                    Reject
                                </MudButton>
                            </MudButtonGroup>
                        </MudHidden>
                        <MudHidden Breakpoint="Breakpoint.Xs" Invert>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success"
                                             OnClick="@(() => ApproveRequest(request))">
                                    Approve
                                </MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Close" IconColor="Color.Error"
                                             OnClick="@(() => RejectRequest(request))">
                                    Reject
                                </MudMenuItem>
                            </MudMenu>
                        </MudHidden>
                    }
                    else if (!string.IsNullOrEmpty(request.ReviewNotes))
                    {
                        <MudTooltip Text="@request.ReviewNotes">
                            <MudIconButton Icon="@Icons.Material.Filled.Notes" Size="Size.Small" />
                        </MudTooltip>
                    }
                </MudStack>
            </ItemTemplate>
            <PlaceholderTemplate>
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                          Class="pa-3 border-b">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                        <MudStack Spacing="1">
                            <MudSkeleton Width="150px" Height="14px" />
                            <MudSkeleton Width="200px" Height="12px" />
                        </MudStack>
                    </MudStack>
                    <MudSkeleton Width="70px" Height="24px" Class="rounded-pill" />
                </MudStack>
            </PlaceholderTemplate>
        </EcoDataVirtualizedList>
    </MudPaper>
}

@code {
    private EcoDataVirtualizedList<AccessRequestResponse, AccessRequestParameters>? _virtualizedList;

    [Parameter]
    public Guid OrganizationId { get; set; }

    private OrganizationDtoForDetail? _organization;

    [Signal]
    private string? _searchText;

    [Signal]
    private string? _statusFilter;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText) || !string.IsNullOrWhiteSpace(StatusFilter);

    protected override async Task OnInitializedAsync()
    {
        Navigation.SetFallback($"/organizations/{OrganizationId}/team");
        SearchTextSignal.OnChange(_ => _virtualizedList?.Refresh());
        StatusFilterSignal.OnChange(_ => _virtualizedList?.Refresh());
        await LoadOrganizationCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task LoadOrganization()
    {
        var result = await OrganizationClient.GetByIdAsync(OrganizationId);
        result.Switch(
            organization => _organization = organization,
            _ => _organization = null,
            _ => _organization = null
        );
    }

    private AccessRequestParameters BuildParameters(Guid? cursor) => new(
        PageSize: 20,
        Cursor: cursor,
        Search: string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
        Status: StatusFilter
    );

    private IAsyncEnumerable<AccessRequestResponse> GetItemsAsync(AccessRequestParameters parameters, CancellationToken cancellationToken)
    {
        return AccessRequestClient.GetAllAsync(OrganizationId, parameters, cancellationToken);
    }

    private void ClearFilters()
    {
        SearchText = null;
        StatusFilter = null;
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private async Task ApproveRequest(AccessRequestResponse request)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to approve the access request from {request.DisplayName}? They will be added as a Viewer." },
            { x => x.ButtonText, "Approve" },
            { x => x.Color, Color.Success }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Approve Request", parameters, options);
        var dialogResult = await dialog.Result;

        if (dialogResult is { Canceled: false })
        {
            var result = await AccessRequestClient.UpdateStatusAsync(OrganizationId, request.Id, true);
            result.Switch(
                _ =>
                {
                    Snackbar.Add($"{request.DisplayName} has been approved and added as a Viewer", Severity.Success);
                    _virtualizedList?.Refresh();
                },
                _ => Snackbar.Add("Access request not found", Severity.Error),
                conflict => Snackbar.Add(conflict.Message, Severity.Warning),
                error => Snackbar.Add($"Failed to approve request: {error.Message}", Severity.Error)
            );
        }
    }

    private async Task RejectRequest(AccessRequestResponse request)
    {
        var parameters = new DialogParameters<RejectRequestDialog>
        {
            { x => x.RequesterName, request.DisplayName }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RejectRequestDialog>("Reject Request", parameters, options);
        var dialogResult = await dialog.Result;

        if (dialogResult is { Canceled: false, Data: string reviewNotes })
        {
            var result = await AccessRequestClient.UpdateStatusAsync(OrganizationId, request.Id, false, reviewNotes);
            result.Switch(
                _ =>
                {
                    Snackbar.Add($"Request from {request.DisplayName} has been rejected", Severity.Info);
                    _virtualizedList?.Refresh();
                },
                _ => Snackbar.Add("Access request not found", Severity.Error),
                conflict => Snackbar.Add(conflict.Message, Severity.Warning),
                error => Snackbar.Add($"Failed to reject request: {error.Message}", Severity.Error)
            );
        }
    }
}
