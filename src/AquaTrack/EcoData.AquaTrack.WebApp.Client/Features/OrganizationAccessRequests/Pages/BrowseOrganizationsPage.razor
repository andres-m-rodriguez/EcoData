@page "/browse"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Parameters
@using EcoData.AquaTrack.Contracts.Requests
@using EcoData.AquaTrack.Application.Client
@using BlazingSingularity.Signals
@using BlazingSingularity.Commands
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Features.OrganizationAccessRequests.Dialogs
@inject IOrganizationHttpClient OrganizationClient
@inject IOrganizationAccessRequestHttpClient AccessRequestClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Browse Organizations - AquaTrack</PageTitle>

<SearchHeader SearchSignal="SearchTextSignal" Placeholder="Search organizations..." EnableSticky="false" />

@if (LoadCommand.IsLoading)
{
    <div class="organizations-grid">
        @for (var i = 0; i < 6; i++)
        {
            <MudCard Elevation="1">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" />
                <MudCardContent>
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="56px" Height="56px" />
                    <MudSkeleton Width="70%" Height="20px" Class="mt-4" />
                    <MudSkeleton Width="100%" Height="14px" Class="mt-2" />
                    <MudSkeleton Width="80%" Height="14px" Class="mt-1" />
                </MudCardContent>
            </MudCard>
        }
    </div>
}
else if (_organizations.Count == 0)
{
    @if (HasActiveFilters)
    {
        <MudPaper Elevation="1" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No organizations found</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No organizations match your search criteria.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAltOff"
                           OnClick="ClearFilters" Class="mt-3">
                    Clear Filters
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No organizations available</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    There are no organizations to browse at this time.
                </MudText>
            </MudStack>
        </MudPaper>
    }
}
else
{
    <div class="organizations-grid">
        @foreach (var org in _organizations)
        {
            <MudCard Elevation="1" Class="organization-browse-card">
                <div class="card-header">
                    @if (!string.IsNullOrWhiteSpace(org.Organization.CardPictureUrl))
                    {
                        <img src="@org.Organization.CardPictureUrl" alt="" class="card-banner" />
                    }
                    else
                    {
                        <div class="card-banner-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" />
                        </div>
                    }
                    <div class="profile-picture-container">
                        @if (!string.IsNullOrWhiteSpace(org.Organization.ProfilePictureUrl))
                        {
                            <MudAvatar Size="Size.Large" Class="profile-avatar">
                                <MudImage Src="@org.Organization.ProfilePictureUrl" Alt="@org.Organization.Name" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Size="Size.Large" Color="Color.Primary" Class="profile-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Business" />
                            </MudAvatar>
                        }
                    </div>
                </div>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle1" Class="organization-name">@org.Organization.Name</MudText>
                    @if (!string.IsNullOrWhiteSpace(org.Organization.AboutUs))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="organization-description">
                            @TruncateDescription(org.Organization.AboutUs)
                        </MudText>
                    }
                </MudCardContent>
                <MudCardActions Class="justify-center pa-4">
                    @if (org.IsMember)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   OnClick="() => NavigateToOrganization(org.Organization)">
                            View
                        </MudButton>
                    }
                    else if (org.HasPendingRequest)
                    {
                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">
                            Request Pending
                        </MudChip>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.PersonAdd"
                                   OnClick="() => RequestAccess(org)">
                            Request Access
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        }
    </div>
    @if (_hasMore)
    {
        <div class="d-flex justify-center mt-8">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => LoadMoreCommand.ExecuteAsync()"
                       Disabled="LoadMoreCommand.IsLoading">
                @if (LoadMoreCommand.IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Load More
            </MudButton>
        </div>
    }
}

@code {
    private List<OrganizationWithStatus> _organizations = [];
    private HashSet<Guid> _memberOrganizations = [];
    private HashSet<Guid> _pendingRequestOrganizations = [];
    private bool _hasMore;
    private Guid? _cursor;

    [Signal]
    private string? _searchText;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText);

    protected override async Task OnInitializedAsync()
    {
        SearchTextSignal.OnChange(_ => InvokeAsync(async () =>
        {
            await LoadCommand.ExecuteAsync();
            StateHasChanged();
        }));
        await LoadUserStatusAsync();
        await LoadCommand.ExecuteAsync();
    }

    private async Task LoadUserStatusAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.CurrentUser is null)
            return;

        _pendingRequestOrganizations.Clear();
        await foreach (var request in AccessRequestClient.GetMyRequestsAsync(new OrganizationAccessRequestParameters(PageSize: 100, Status: "Pending")))
        {
            _pendingRequestOrganizations.Add(request.OrganizationId);
        }
    }

    [RelayCommand]
    private async Task Load()
    {
        _organizations.Clear();
        _cursor = null;

        var parameters = CreateParameters();
        var count = 0;
        await foreach (var org in OrganizationClient.GetOrganizationsAsync(parameters))
        {
            _organizations.Add(new OrganizationWithStatus(
                org,
                _memberOrganizations.Contains(org.Id),
                _pendingRequestOrganizations.Contains(org.Id)
            ));
            _cursor = org.Id;
            count++;
        }
        _hasMore = count >= parameters.PageSize;
    }

    [RelayCommand]
    private async Task LoadMore()
    {
        if (!_hasMore) return;

        var parameters = CreateParameters(_cursor);
        var count = 0;
        await foreach (var org in OrganizationClient.GetOrganizationsAsync(parameters))
        {
            _organizations.Add(new OrganizationWithStatus(
                org,
                _memberOrganizations.Contains(org.Id),
                _pendingRequestOrganizations.Contains(org.Id)
            ));
            _cursor = org.Id;
            count++;
        }
        _hasMore = count >= parameters.PageSize;
    }

    private OrganizationParameters CreateParameters(Guid? cursor = null) => new()
    {
        PageSize = 24,
        Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
        Cursor = cursor
    };

    private void ClearFilters()
    {
        SearchText = null;
    }

    private void NavigateToOrganization(OrganizationDtoForList organization)
    {
        Navigation.NavigateTo($"/organizations/{organization.Id}");
    }

    private async Task RequestAccess(OrganizationWithStatus org)
    {
        var parameters = new DialogParameters<RequestAccessDialog>
        {
            { x => x.OrganizationName, org.Organization.Name }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RequestAccessDialog>("Request Access", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string message })
        {
            var request = new CreateOrganizationAccessRequestRequest(org.Organization.Id, message);
            var createResult = await AccessRequestClient.CreateAsync(org.Organization.Id, request);
            createResult.Switch(
                _ =>
                {
                    Snackbar.Add("Access request submitted successfully", Severity.Success);
                    org.HasPendingRequest = true;
                    _pendingRequestOrganizations.Add(org.Organization.Id);
                    StateHasChanged();
                },
                conflict => Snackbar.Add(conflict.Message, Severity.Warning),
                error => Snackbar.Add($"Failed to submit request: {error.Message}", Severity.Error)
            );
        }
    }

    private static string TruncateDescription(string description)
    {
        const int maxLength = 100;
        if (description.Length <= maxLength)
            return description;
        return description[..maxLength].TrimEnd() + "...";
    }

    private sealed class OrganizationWithStatus(OrganizationDtoForList organization, bool isMember, bool hasPendingRequest)
    {
        public OrganizationDtoForList Organization { get; } = organization;
        public bool IsMember { get; set; } = isMember;
        public bool HasPendingRequest { get; set; } = hasPendingRequest;
    }
}
