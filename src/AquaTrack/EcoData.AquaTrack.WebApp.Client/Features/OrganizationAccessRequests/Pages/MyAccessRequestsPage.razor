@page "/my-requests"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Parameters
@using EcoData.AquaTrack.Application.Client
@using BlazingSingularity.Commands
@using EcoData.AquaTrack.WebApp.Client.Services
@inject IOrganizationAccessRequestHttpClient AccessRequestClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>My Access Requests - AquaTrack</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">My Access Requests</MudText>

@if (LoadCommand.IsLoading)
{
    <MudPaper Elevation="1" Class="pa-4">
        @for (var i = 0; i < 3; i++)
        {
            <MudSkeleton Height="80px" Class="mb-4" />
        }
    </MudPaper>
}
else if (_requests.Count == 0)
{
    <MudPaper Elevation="1" Class="pa-8 rounded-lg">
        <MudStack AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No access requests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                You haven't requested access to any organizations yet.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search"
                       OnClick="NavigateToBrowse" Class="mt-3">
                Browse Organizations
            </MudButton>
        </MudStack>
    </MudPaper>
}
else
{
    <MudPaper Elevation="1">
        <MudList T="OrganizationAccessRequestDto" Dense="false">
            @foreach (var request in _requests)
            {
                <MudListItem>
                    <div class="d-flex align-center justify-space-between flex-wrap gap-4 py-2" style="width: 100%;">
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.Business" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1">@request.OrganizationName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Requested @FormatDate(request.CreatedAt)
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(request.RequestMessage))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        "@request.RequestMessage"
                                    </MudText>
                                }
                            </div>
                        </div>
                        <div class="d-flex align-center gap-2">
                            @switch (request.Status)
                            {
                                case "Pending":
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">
                                        Pending
                                    </MudChip>
                                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                               OnClick="() => CancelRequest(request)">
                                        Cancel
                                    </MudButton>
                                    break;
                                case "Approved":
                                    <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">
                                        Approved
                                    </MudChip>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               OnClick="() => NavigateToOrganization(request.OrganizationId)">
                                        View Organization
                                    </MudButton>
                                    break;
                                case "Rejected":
                                    <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small">
                                        Rejected
                                    </MudChip>
                                    break;
                            }
                        </div>
                    </div>
                    @if (request.Status == "Rejected" && !string.IsNullOrWhiteSpace(request.ReviewNotes))
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2 mb-2">
                            <MudText Typo="Typo.caption">
                                <strong>Reviewer notes:</strong> @request.ReviewNotes
                            </MudText>
                        </MudAlert>
                    }
                    @if (request.Status != "Pending" && request.ReviewedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            @(request.Status == "Approved" ? "Approved" : "Rejected") by @(request.ReviewedByDisplayName ?? "Unknown") on @FormatDate(request.ReviewedAt.Value)
                        </MudText>
                    }
                </MudListItem>
                <MudDivider />
            }
        </MudList>
    </MudPaper>

    @if (_hasMore)
    {
        <div class="d-flex justify-center mt-4">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => LoadMoreCommand.ExecuteAsync()"
                       Disabled="LoadMoreCommand.IsLoading">
                @if (LoadMoreCommand.IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Load More
            </MudButton>
        </div>
    }
}

@code {
    private List<OrganizationAccessRequestDto> _requests = [];
    private bool _hasMore;
    private Guid? _cursor;

    protected override async Task OnInitializedAsync()
    {
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        _requests.Clear();
        _cursor = null;

        var parameters = new OrganizationAccessRequestParameters(PageSize: 20);
        var count = 0;
        await foreach (var request in AccessRequestClient.GetMyRequestsAsync(parameters))
        {
            _requests.Add(request);
            _cursor = request.Id;
            count++;
        }
        _hasMore = count >= parameters.PageSize;
    }

    [RelayCommand]
    private async Task LoadMore()
    {
        if (!_hasMore) return;

        var parameters = new OrganizationAccessRequestParameters(PageSize: 20, Cursor: _cursor);
        var count = 0;
        await foreach (var request in AccessRequestClient.GetMyRequestsAsync(parameters))
        {
            _requests.Add(request);
            _cursor = request.Id;
            count++;
        }
        _hasMore = count >= parameters.PageSize;
    }

    private async Task CancelRequest(OrganizationAccessRequestDto request)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to cancel your access request to \"{request.OrganizationName}\"?" },
            { x => x.ButtonText, "Cancel Request" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Cancel Request", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var cancelResult = await AccessRequestClient.CancelMyRequestAsync(request.Id);
            cancelResult.Switch(
                _ =>
                {
                    Snackbar.Add("Request cancelled successfully", Severity.Success);
                    _requests.Remove(request);
                    StateHasChanged();
                },
                _ => Snackbar.Add("Request not found", Severity.Error),
                validation => Snackbar.Add(validation.Errors.FirstOrDefault()?.ErrorMessage ?? "Cannot cancel request", Severity.Error),
                error => Snackbar.Add($"Failed to cancel: {error.Message}", Severity.Error)
            );
        }
    }

    private void NavigateToBrowse() => Navigation.NavigateTo("/browse");

    private void NavigateToOrganization(Guid organizationId) => Navigation.NavigateTo($"/organizations/{organizationId}");

    private static string FormatDate(DateTimeOffset date) => date.LocalDateTime.ToString("MMM d, yyyy");
}
