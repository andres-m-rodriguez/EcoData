@page "/organizations/{OrganizationId:guid}/members"
@page "/organizations/{OrganizationId:guid}/team"
@using EcoData.AquaTrack.Contracts
@using EcoData.AquaTrack.WebApp.Client.Authorization
@attribute [OrganizationPermission(Permissions.Organization.ManageMembers)]
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Features.OrganizationMembers.Components
@using EcoData.AquaTrack.WebApp.Client.Features.OrganizationMembers.Dialogs
@using BlazingSingularity.Commands
@using BlazingSingularity.Signals
@inject IOrganizationHttpClient OrganizationClient
@inject IOrganizationMemberHttpClient MemberClient
@inject INavigationService Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Members - @(_organization?.Name ?? "Organization") - AquaTrack</PageTitle>

<SearchHeader @bind-Value="SearchText" Placeholder="Search members..." EnableSticky="true">
    <Actions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenAddMemberDialog">
            Add Member
        </MudButton>
    </Actions>
</SearchHeader>

@if (LoadCommand.IsLoading)
{
    <MudPaper Elevation="0" Class="rounded-lg">
        @for (var i = 0; i < 5; i++)
        {
            <MudPaper Elevation="0" Class="pa-3 border-b">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                    <MudStack Spacing="1">
                        <MudSkeleton Width="150px" Height="16px" />
                        <MudSkeleton Width="200px" Height="12px" />
                    </MudStack>
                    <MudSpacer />
                    <MudSkeleton Width="80px" Height="24px" />
                </MudStack>
            </MudPaper>
        }
    </MudPaper>
}
else if (_organization is null)
{
    <MudPaper Elevation="0" Class="pa-8 rounded-lg">
        <MudStack AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
        </MudStack>
    </MudPaper>
}
else if (FilteredMembers.Count == 0)
{
    @if (HasActiveFilters)
    {
        <MudPaper Elevation="0" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No members found</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No members match your search criteria.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAltOff"
                           OnClick="ClearFilters" Class="mt-3">
                    Clear Filters
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No members yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Add members to this organization to get started.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="OpenAddMemberDialog" Class="mt-3">
                    Add Member
                </MudButton>
            </MudStack>
        </MudPaper>
    }
}
else
{
    <MudPaper Elevation="0" Class="rounded-lg">
        @foreach (var member in FilteredMembers)
        {
            <MemberListItem Member="member" ShowActions="true" OnChangeRole="OpenChangeRoleDialog"
                            OnRemove="ConfirmRemoveMember" />
        }
    </MudPaper>
}

@code {
    [Parameter]
    public Guid OrganizationId { get; set; }

    private OrganizationDtoForDetail? _organization;
    private List<OrganizationMemberDto> _members = [];

    [Signal]
    private string? _searchText;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText);

    private List<OrganizationMemberDto> FilteredMembers =>
        string.IsNullOrWhiteSpace(SearchText)
            ? _members
            : _members.Where(m =>
                m.DisplayName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                m.Email.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                m.RoleName.Contains(SearchText, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        Navigation.SetFallback($"/organizations/{OrganizationId}");
        SearchTextSignal.OnChange(_ => InvokeAsync(StateHasChanged));
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var result = await OrganizationClient.GetByIdAsync(OrganizationId);
        result.Switch(
            organization => _organization = organization,
            _ => _organization = null,
            _ => _organization = null
        );

        if (_organization is not null)
        {
            _members.Clear();
            await foreach (var member in MemberClient.GetAllAsync(OrganizationId))
            {
                _members.Add(member);
            }
        }
    }

    private void ClearFilters()
    {
        SearchText = null;
    }

    private async Task OpenAddMemberDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddMemberDialog>("Add Member", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddMemberRequest request })
        {
            var createResult = await MemberClient.CreateAsync(OrganizationId, request);
            createResult.Switch(
                member =>
                {
                    _members.Add(member);
                    Snackbar.Add("Member added successfully", Severity.Success);
                    StateHasChanged();
                },
                _ => Snackbar.Add("User not found", Severity.Error),
                conflict => Snackbar.Add(conflict.Message, Severity.Warning),
                error => Snackbar.Add($"Failed to add member: {error.Message}", Severity.Error)
            );
        }
    }

    private async Task OpenChangeRoleDialog(OrganizationMemberDto member)
    {
        var parameters = new DialogParameters<ChangeRoleDialog>
        {
            { x => x.MemberName, member.DisplayName },
            { x => x.CurrentRole, member.RoleName }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ChangeRoleDialog>("Change Role", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: UpdateMemberRoleRequest request })
        {
            var updateResult = await MemberClient.UpdateAsync(OrganizationId, member.UserId, request);
            updateResult.Switch(
                updatedMember =>
                {
                    var index = _members.FindIndex(m => m.UserId == member.UserId);
                    if (index >= 0)
                    {
                        _members[index] = updatedMember;
                    }
                    Snackbar.Add("Role updated successfully", Severity.Success);
                    StateHasChanged();
                },
                _ => Snackbar.Add("Member not found", Severity.Error),
                validation => Snackbar.Add(validation.Errors.FirstOrDefault()?.ErrorMessage ?? "Validation error", Severity.Warning),
                error => Snackbar.Add($"Failed to update role: {error.Message}", Severity.Error)
            );
        }
    }

    private async Task ConfirmRemoveMember(OrganizationMemberDto member)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to remove {member.DisplayName} from this organization?" },
            { x => x.ButtonText, "Remove" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Remove Member", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var deleteResult = await MemberClient.DeleteAsync(OrganizationId, member.UserId);
            deleteResult.Switch(
                _ =>
                {
                    _members.Remove(member);
                    Snackbar.Add("Member removed successfully", Severity.Success);
                    StateHasChanged();
                },
                _ => Snackbar.Add("Member not found", Severity.Error),
                validation => Snackbar.Add(validation.Errors.FirstOrDefault()?.ErrorMessage ?? "Cannot remove member",
Severity.Warning),
                error => Snackbar.Add($"Failed to remove member: {error.Message}", Severity.Error)
            );
        }
    }
}
