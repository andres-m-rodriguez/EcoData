@using EcoData.AquaTrack.Contracts.Dtos

<div class="sensor-row" @onclick="HandleClick">
    <div class="sensor-primary">
        <MudText Typo="Typo.body1" Class="sensor-name">@Sensor.Name</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">@Sensor.ExternalId</MudText>
    </div>
    <MudText Typo="Typo.body2" Class="hide-mobile">@Sensor.MunicipalityId</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="hide-mobile hide-tablet">
        @Sensor.Latitude.ToString("F4"), @Sensor.Longitude.ToString("F4")
    </MudText>
    <div class="sensor-status">
        <MudChip T="string"
                 Size="Size.Small"
                 Color="@(Sensor.IsActive ? Color.Success : Color.Default)"
                 Variant="Variant.Filled">
            @(Sensor.IsActive ? "Active" : "Inactive")
        </MudChip>
    </div>
    <div class="sensor-actions" @onclick:stopPropagation="true">
        <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                 Size="Size.Small"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Outlined.Map" OnClick="@HandleMapClick">
                View on Map
            </MudMenuItem>
        </MudMenu>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required SensorDtoForList Sensor { get; set; }

    [Parameter]
    public EventCallback<SensorDtoForList> OnMapClick { get; set; }

    [Parameter]
    public EventCallback<SensorDtoForList> OnClick { get; set; }

    private async Task HandleMapClick()
    {
        await OnMapClick.InvokeAsync(Sensor);
    }

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync(Sensor);
    }
}
