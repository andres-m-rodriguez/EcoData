@inject IJSRuntime JS
@implements IAsyncDisposable

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4 flex-wrap search-header">
    <div class="search-wrapper">
        <SearchBar @bind-Value="Value"
                   Placeholder="@Placeholder"
                   ShowFilterButton="ShowFilterButton"
                   HasActiveFilters="HasActiveFilters"
                   FilterCount="FilterCount"
                   OnFilterClick="OnFilterClick"
                   EnableSticky="EnableSticky" />
    </div>
    @if (Actions is not null)
    {
        <div class="actions-wrapper">
            @Actions
        </div>
    }
</MudStack>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "Search...";

    [Parameter]
    public bool ShowFilterButton { get; set; }

    [Parameter]
    public bool HasActiveFilters { get; set; }

    [Parameter]
    public int FilterCount { get; set; } = 1;

    [Parameter]
    public EventCallback OnFilterClick { get; set; }

    [Parameter]
    public bool EnableSticky { get; set; } = true;

    [Parameter]
    public RenderFragment? Actions { get; set; }

    public async ValueTask DisposeAsync()
    {
        // SearchBar handles its own disposal
    }
}
