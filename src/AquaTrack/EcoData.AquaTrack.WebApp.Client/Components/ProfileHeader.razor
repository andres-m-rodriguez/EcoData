@using MudBlazor

<MudStack Row="true" AlignItems="AlignItems.End" Spacing="3">
    @if (!string.IsNullOrWhiteSpace(AvatarUrl))
    {
        <MudAvatar Size="Size.Large" Class="profile-avatar">
            <MudImage Src="@AvatarUrl" Alt="@Title" ObjectFit="ObjectFit.Cover" />
        </MudAvatar>
    }
    else
    {
        <MudAvatar Size="Size.Large" Color="Color.Primary" Class="profile-avatar">
            <MudIcon Icon="@FallbackIcon" />
        </MudAvatar>
    }
    <MudStack Spacing="0" Class="pb-1">
        <MudText Typo="Typo.h5" Style="font-weight: 600;">@Title</MudText>
        @if (!string.IsNullOrWhiteSpace(SubtitleUrl))
        {
            <MudLink Href="@SubtitleUrl" Target="_blank" Color="Color.Primary" Typo="Typo.body2">
                <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" Class="mr-1" />
                @GetDisplayUrl(SubtitleUrl)
            </MudLink>
        }
        @if (!string.IsNullOrWhiteSpace(Caption))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-flex align-center mt-1">
                <MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" Size="Size.Small" Class="mr-1" />
                @Caption
            </MudText>
        }
    </MudStack>
</MudStack>

@code {
    [Parameter]
    public string? AvatarUrl { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? SubtitleUrl { get; set; }

    [Parameter]
    public string? Caption { get; set; }

    [Parameter]
    public string FallbackIcon { get; set; } = Icons.Material.Filled.Business;

    private static string GetDisplayUrl(string url)
    {
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
            return uri.Host;
        return url;
    }
}
