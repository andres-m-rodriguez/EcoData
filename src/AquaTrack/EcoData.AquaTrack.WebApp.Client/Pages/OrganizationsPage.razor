@page "/organizations"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Errors
@using EcoData.AquaTrack.Contracts.Parameters
@using EcoData.AquaTrack.Application.Client
@using BlazingSingularity.Signals
@using BlazingSingularity.Commands
@using EcoData.AquaTrack.WebApp.Client.Components
@using EcoData.AquaTrack.WebApp.Client.Services
@inject IOrganizationHttpClient OrganizationClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Organizations - AquaTrack</PageTitle>

<SearchHeader @bind-Value="SearchText"
              Placeholder="Search organizations..."
              EnableSticky="false">
    <Actions>
        @if (IsAdmin)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="NavigateToCreate">
                Add Organization
            </MudButton>
        }
    </Actions>
</SearchHeader>

@if (LoadCommand.IsLoading)
{
    <div class="organizations-grid">
        @for (var i = 0; i < 6; i++)
        {
            <MudCard Elevation="1">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" />
                <MudCardContent>
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="56px" Height="56px" />
                    <MudSkeleton Width="70%" Height="20px" Class="mt-4" />
                    <MudSkeleton Width="100%" Height="14px" Class="mt-2" />
                    <MudSkeleton Width="80%" Height="14px" Class="mt-1" />
                    <MudSkeleton Width="40%" Height="14px" Class="mt-3" />
                </MudCardContent>
            </MudCard>
        }
    </div>
}
else if (_organizations.Count == 0)
{
    @if (HasActiveFilters)
    {
        <MudPaper Elevation="1" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No organizations found</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No organizations match your search criteria.
                </MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.FilterAltOff"
                           OnClick="ClearFilters"
                           Class="mt-3">
                    Clear Filters
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No organizations yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Get started by adding your first organization.
                </MudText>
                @if (IsAdmin)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="NavigateToCreate"
                               Class="mt-3">
                        Add Organization
                    </MudButton>
                }
            </MudStack>
        </MudPaper>
    }
}
else
{
    <div class="organizations-grid">
        @foreach (var organization in _organizations)
        {
            <OrganizationListItem Organization="organization"
                                  ShowActions="IsAdmin"
                                  OnClick="NavigateToDetails"
                                  OnEdit="NavigateToEdit"
                                  OnDelete="ConfirmDelete" />
        }
    </div>
    @if (_hasMore)
    {
        <div class="d-flex justify-center mt-8">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="() => LoadMoreCommand.ExecuteAsync()"
                       Disabled="LoadMoreCommand.IsLoading">
                @if (LoadMoreCommand.IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Load More
            </MudButton>
        </div>
    }
}

@code {
    private List<OrganizationDtoForList> _organizations = [];
    private bool _hasMore;
    private Guid? _cursor;

    [Signal]
    private string? _searchText;

    private bool IsAdmin => AuthState.CurrentUser?.Role == "Admin";
    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText);

    protected override async Task OnInitializedAsync()
    {
        SearchTextSignal.OnChange(_ => InvokeAsync(async () =>
        {
            await LoadCommand.ExecuteAsync();
            StateHasChanged();
        }));
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        _organizations.Clear();
        _cursor = null;

        var parameters = CreateParameters();
        var count = 0;
        await foreach (var org in OrganizationClient.GetOrganizationsAsync(parameters))
        {
            _organizations.Add(org);
            _cursor = org.Id;
            count++;
        }
        _hasMore = count >= parameters.PageSize;
    }

    [RelayCommand]
    private async Task LoadMore()
    {
        if (!_hasMore) return;

        var parameters = CreateParameters(_cursor);
        var count = 0;
        await foreach (var org in OrganizationClient.GetOrganizationsAsync(parameters))
        {
            _organizations.Add(org);
            _cursor = org.Id;
            count++;
        }
        _hasMore = count >= parameters.PageSize;
    }

    private OrganizationParameters CreateParameters(Guid? cursor = null) => new()
    {
        PageSize = 24,
        Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
        Cursor = cursor
    };

    private void ClearFilters()
    {
        SearchText = null;
    }

    private void NavigateToCreate() => Navigation.NavigateTo("/organizations/create");

    private void NavigateToDetails(OrganizationDtoForList organization)
    {
        Navigation.NavigateTo($"/organizations/{organization.Id}");
    }

    private void NavigateToEdit(OrganizationDtoForList organization)
    {
        Navigation.NavigateTo($"/organizations/{organization.Id}/edit");
    }

    private async Task ConfirmDelete(OrganizationDtoForList organization)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete \"{organization.Name}\"? This action cannot be undone." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Organization", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var deleteResult = await OrganizationClient.DeleteAsync(organization.Id);
            deleteResult.Switch(
                _ =>
                {
                    Snackbar.Add("Organization deleted successfully", Severity.Success);
                    _organizations.Remove(organization);
                    StateHasChanged();
                },
                _ => Snackbar.Add("Organization not found", Severity.Error),
                error => Snackbar.Add($"Failed to delete: {error.Message}", Severity.Error)
            );
        }
    }
}
