@page "/organizations/{Id:guid}/edit"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Errors
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthStateService AuthState
@inject BackButtonService BackButton

<PageTitle>Edit Organization - AquaTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-4">
    @if (LoadCommand.IsLoading)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudSkeleton Width="200px" Height="32px" />
            <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
            <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
            <MudSkeleton Width="100%" Height="120px" Class="mt-4" />
            <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
        </MudPaper>
    }
    else if (_organization is null)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (!IsAdmin)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" />
                <MudText Typo="Typo.h6" Color="Color.Warning" Class="mt-2">Access Denied</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    You don't have permission to edit organizations.
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudText Typo="Typo.h5" Class="mb-4">Edit Organization</MudText>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">
                    @_errorMessage
                </MudAlert>
            }

            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name"
                              Label="Name"
                              Required="true"
                              RequiredError="Name is required"
                              MaxLength="200"
                              Counter="200"
                              Immediate="true"
                              Disabled="SaveCommand.IsLoading" />

                <MudTextField @bind-Value="_profilePictureUrl"
                              Label="Profile Picture URL"
                              Placeholder="https://example.com/logo.png"
                              MaxLength="500"
                              HelperText="URL to the organization's logo or profile picture"
                              Disabled="SaveCommand.IsLoading" />

                @if (!string.IsNullOrWhiteSpace(_profilePictureUrl))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Preview:</MudText>
                        <MudAvatar Size="Size.Large">
                            <MudImage Src="@_profilePictureUrl" Alt="Preview" />
                        </MudAvatar>
                    </MudStack>
                }

                <MudTextField @bind-Value="_cardPictureUrl"
                              Label="Card Picture URL"
                              Placeholder="https://example.com/banner.png"
                              MaxLength="500"
                              HelperText="Banner image displayed on organization cards"
                              Disabled="SaveCommand.IsLoading" />

                @if (!string.IsNullOrWhiteSpace(_cardPictureUrl))
                {
                    <MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Card Preview:</MudText>
                        <MudImage Src="@_cardPictureUrl" Alt="Card Preview"
                                  Style="max-width: 100%; height: 120px; object-fit: cover; border-radius: 8px;" />
                    </MudStack>
                }

                <MudTextField @bind-Value="_websiteUrl"
                              Label="Website URL"
                              Placeholder="https://example.com"
                              MaxLength="500"
                              HelperText="Organization's website (optional)"
                              Disabled="SaveCommand.IsLoading" />

                <MudTextField @bind-Value="_aboutUs"
                              Label="About Us"
                              Lines="5"
                              MaxLength="2000"
                              Counter="2000"
                              HelperText="Description of the organization"
                              Disabled="SaveCommand.IsLoading" />

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               OnClick="NavigateToDetails"
                               Disabled="SaveCommand.IsLoading">
                        Cancel
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="() => SaveCommand.ExecuteAsync()"
                               Disabled="SaveCommand.IsLoading || string.IsNullOrWhiteSpace(_name)">
                        @if (SaveCommand.IsLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Save Changes
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrganizationDtoForDetail? _organization;
    private string _name = string.Empty;
    private string? _profilePictureUrl;
    private string? _cardPictureUrl;
    private string? _aboutUs;
    private string? _websiteUrl;
    private string? _errorMessage;

    private bool IsAdmin => AuthState.CurrentUser?.Role == "Admin";

    protected override async Task OnInitializedAsync()
    {
        BackButton.SetPath($"/organizations/{Id}");
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var result = await OrganizationClient.GetByIdAsync(Id);
        result.Switch(
            organization =>
            {
                _organization = organization;
                _name = organization.Name;
                _profilePictureUrl = organization.ProfilePictureUrl;
                _cardPictureUrl = organization.CardPictureUrl;
                _aboutUs = organization.AboutUs;
                _websiteUrl = organization.WebsiteUrl;
            },
            _ => _organization = null
        );
    }

    [RelayCommand]
    private async Task Save()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Name is required";
            return;
        }

        var dto = new OrganizationDtoForUpdate(
            _name,
            _profilePictureUrl,
            _cardPictureUrl,
            _aboutUs,
            _websiteUrl
        );

        var result = await OrganizationClient.UpdateAsync(Id, dto);

        result.Switch(
            _ =>
            {
                Snackbar.Add("Organization updated successfully", Severity.Success);
                Navigation.NavigateTo($"/organizations/{Id}");
            },
            _ => _errorMessage = "Organization not found",
            validationError => _errorMessage = validationError.Errors.FirstOrDefault()?.ErrorMessage ?? "Validation failed",
            apiError => _errorMessage = apiError.Message ?? "Failed to update organization"
        );
    }

    private void NavigateToDetails() => Navigation.NavigateTo($"/organizations/{Id}");
}
