@page "/organizations/{OrganizationId:guid}/team"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject NavigationManager Navigation
@inject AuthStateService AuthState
@inject BackButtonService BackButton

<PageTitle>Team - @(_organization?.Name ?? "Organization") - AquaTrack</PageTitle>

<SearchHeader @bind-Value="_searchText" Placeholder="Search members..." EnableSticky="true" />

@if (LoadCommand.IsLoading)
{
    <MudGrid Spacing="3">
        @for (var i = 0; i < 8; i++)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="1">
                    <MudCardContent Class="text-center">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="56px" Height="56px" Class="mx-auto" />
                        <MudSkeleton Width="120px" Height="20px" Class="mt-3 mx-auto" />
                        <MudSkeleton Width="80px" Height="14px" Class="mt-2 mx-auto" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else if (_organization is null)
{
    <MudPaper Elevation="0" Class="pa-8 rounded-lg text-center" Style="background: var(--mud-palette-background-gray)">
        <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
        <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var member in FilteredTeamMembers)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="0" Class="team-card text-center">
                    <MudCardContent>
                        <MudAvatar Size="Size.Large" Style="@($"background-color: {member.Color}; color: white;")">
                            @member.Name[0]
                        </MudAvatar>
                        <MudText Typo="Typo.subtitle1" Class="mt-3 fw-bold">@member.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@member.Role</MudText>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Filled"
                                 Color="@(member.IsAdmin ? Color.Warning : Color.Default)"
                                 Class="mt-2">
                            @if (member.IsAdmin)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Class="mr-1" />
                            }
                            @(member.IsAdmin ? "Admin" : "Member")
                        </MudChip>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2" Style="font-family: monospace">
                            Joined @member.JoinedDate
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Parameter]
    public Guid OrganizationId { get; set; }

    private OrganizationDtoForDetail? _organization;
    private string? _searchText;

    private bool IsAdmin => AuthState.CurrentUser?.Role == "Admin";

    // Hardcoded team members
    private static readonly List<TeamMember> TeamMembers =
    [
        new("Andres Rivera", "Full Stack Developer", true, "Mar 2026", "#0ea5e9"),
        new("Maria Gonzalez", "Environmental Scientist", true, "Jan 2026", "#8b5cf6"),
        new("Carlos Perez", "Field Technician", false, "Feb 2026", "#22c55e"),
        new("Laura Diaz", "Data Analyst", false, "Feb 2026", "#f59e0b"),
        new("Roberto Soto", "IoT Engineer", false, "Mar 2026", "#ef4444"),
        new("Sofia Ortiz", "Researcher", false, "Mar 2026", "#14b8a6"),
        new("Miguel Torres", "Lab Technician", false, "Mar 2026", "#6366f1"),
        new("Ana Ruiz", "Project Coordinator", false, "Mar 2026", "#ec4899")
    ];

    private IEnumerable<TeamMember> FilteredTeamMembers =>
        string.IsNullOrWhiteSpace(_searchText)
            ? TeamMembers
            : TeamMembers.Where(m =>
                m.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                m.Role.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        BackButton.SetPath($"/organizations/{OrganizationId}");
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var result = await OrganizationClient.GetByIdAsync(OrganizationId);
        result.Switch(
            organization => _organization = organization,
            _ => _organization = null
        );
    }

    private record TeamMember(string Name, string Role, bool IsAdmin, string JoinedDate, string Color);
}
