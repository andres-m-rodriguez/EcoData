@page "/organizations/create"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthStateService AuthState
@inject BackButtonService BackButton

<PageTitle>Create Organization - AquaTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-4">
    @if (!IsAdmin)
    {
        <MudPaper Elevation="1" Class="pa-6 rounded-lg">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" />
                <MudText Typo="Typo.h6" Color="Color.Warning" Class="mt-2">Access Denied</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    You don't have permission to create organizations.
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-6 rounded-lg">
            <MudText Typo="Typo.h5" Class="mb-4">Create Organization</MudText>

            <OrganizationForm Model="_model"
                              SubmitButtonText="Create"
                              ErrorMessage="@_errorMessage"
                              IsLoading="CreateCommand.IsLoading"
                              OnSubmit="HandleSubmit"
                              OnCancel="NavigateBack" />
        </MudPaper>
    }
</MudContainer>

@code {
    private readonly OrganizationForm.OrganizationFormModel _model = new();
    private string? _errorMessage;

    private bool IsAdmin => AuthState.CurrentUser?.Role == "Admin";

    protected override void OnInitialized()
    {
        BackButton.SetPath("/organizations");
    }

    private async Task HandleSubmit(OrganizationForm.OrganizationFormModel model)
    {
        await CreateCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Create()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _errorMessage = "Name is required";
            return;
        }

        var dto = new OrganizationDtoForCreate(
            _model.Name,
            _model.ProfilePictureUrl,
            _model.CardPictureUrl,
            _model.AboutUs,
            _model.WebsiteUrl
        );

        var result = await OrganizationClient.CreateAsync(dto);

        result.Switch(
            created =>
            {
                Snackbar.Add("Organization created successfully", Severity.Success);
                Navigation.NavigateTo($"/organizations/{created.Id}");
            },
            validationError => _errorMessage = validationError.Errors.FirstOrDefault()?.ErrorMessage ?? "Validation failed",
            apiError => _errorMessage = apiError.Message ?? "Failed to create organization"
        );
    }

    private void NavigateBack() => Navigation.NavigateTo("/organizations");
}
