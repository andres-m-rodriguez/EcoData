@page "/sensors"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Parameters
@using EcoData.AquaTrack.Application.Client
@using BlazingSingularity.Signals
@using EcoData.AquaTrack.WebApp.Client.Components
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject ISensorHttpClient SensorClient
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Sensors - AquaTrack</PageTitle>

<div class="sensors-page">
    <div class="search-bar">
        <MudTextField @bind-Value="SearchText"
                      Placeholder="Search sensors..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      Clearable="true"
                      Margin="Margin.Dense"
                      Class="search-input" />
        <MudSelect @bind-Value="StatusFilter"
                   AnchorOrigin="Origin.BottomCenter"
                   Margin="Margin.Dense"
                   Class="status-filter">
            <MudSelectItem Value="SensorStatusFilter.All">All</MudSelectItem>
            <MudSelectItem Value="SensorStatusFilter.Active">Active</MudSelectItem>
            <MudSelectItem Value="SensorStatusFilter.Inactive">Inactive</MudSelectItem>
        </MudSelect>
        @if (HasActiveFilters)
        {
            <MudIconButton Icon="@Icons.Material.Filled.FilterAltOff"
                           Color="Color.Secondary"
                           Size="Size.Small"
                           OnClick="ClearFilters" />
        }
    </div>

    <MudPaper Elevation="1" Class="sensor-list-container">
        @if (_isEmpty)
        {
            @if (HasActiveFilters)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No sensors found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No sensors match your current filter criteria.
                    </MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.FilterAltOff"
                               OnClick="ClearFilters"
                               Class="mt-3">
                        Clear Filters
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Sensors" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No sensors yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Sensors will appear here once data is ingested.
                    </MudText>
                </MudStack>
            }
        }
        else
        {
            <Virtualize @ref="_virtualize"
                        ItemsProvider="LoadItemsAsync"
                        ItemSize="65"
                        OverscanCount="3"
                        Context="sensor">
                <ItemContent>
                    <SensorListItem Sensor="sensor" OnMapClick="NavigateToMap" />
                </ItemContent>
                <Placeholder>
                    <div class="sensor-skeleton">
                        <div class="skeleton-primary">
                            <MudSkeleton Width="180px" Height="16px" />
                            <MudSkeleton Width="100px" Height="12px" Class="mt-1" />
                        </div>
                        <MudSkeleton Width="120px" Height="14px" Class="hide-mobile" />
                        <MudSkeleton Width="140px" Height="14px" Class="hide-mobile hide-tablet" />
                        <MudSkeleton Width="60px" Height="24px" Class="rounded-pill" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                    </div>
                </Placeholder>
            </Virtualize>
        }
    </MudPaper>
</div>

@code {
    private Virtualize<SensorDtoForList>? _virtualize;
    private readonly List<SensorDtoForList> _cachedItems = [];
    private readonly SemaphoreSlim _fetchLock = new(1, 1);
    private Guid? _lastCursor;
    private bool _hasMoreItems = true;
    private bool _isEmpty;
    private int _generation;

    [Signal]
    private string? _searchText;

    [Signal]
    private SensorStatusFilter _statusFilter = SensorStatusFilter.All;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText) || StatusFilter != SensorStatusFilter.All;

    protected override void OnInitialized()
    {
        SearchTextSignal.OnChange(async _ => await RefreshAsync());
        StatusFilterSignal.OnChange(async _ => await RefreshAsync());
    }

    private async ValueTask<ItemsProviderResult<SensorDtoForList>> LoadItemsAsync(ItemsProviderRequest request)
    {
        var startIndex = request.StartIndex;
        var endIndex = startIndex + request.Count;
        var currentGeneration = _generation;

        if (_hasMoreItems && _cachedItems.Count < endIndex)
        {
            await _fetchLock.WaitAsync(request.CancellationToken);
            try
            {
                if (_generation != currentGeneration)
                    return CreateResult(startIndex, request.Count);

                while (_hasMoreItems && _cachedItems.Count < endIndex)
                {
                    var parameters = new SensorParameters
                    {
                        PageSize = 50,
                        Cursor = _lastCursor,
                        Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
                        IsActive = StatusFilter switch
                        {
                            SensorStatusFilter.Active => true,
                            SensorStatusFilter.Inactive => false,
                            _ => null
                        }
                    };

                    var fetchedCount = 0;
                    await foreach (var sensor in SensorClient.GetSensorsAsync(parameters, request.CancellationToken))
                    {
                        _cachedItems.Add(sensor);
                        _lastCursor = sensor.Id;
                        fetchedCount++;
                    }

                    if (fetchedCount < parameters.PageSize)
                    {
                        _hasMoreItems = false;
                    }
                }
            }
            finally
            {
                _fetchLock.Release();
            }
        }

        var result = CreateResult(startIndex, request.Count);

        if (startIndex == 0 && result.TotalItemCount == 0 && !_isEmpty)
        {
            _isEmpty = true;
            StateHasChanged();
        }

        return result;
    }

    private ItemsProviderResult<SensorDtoForList> CreateResult(int startIndex, int count)
    {
        var items = _cachedItems.Skip(startIndex).Take(count).ToList();
        var totalCount = _hasMoreItems ? _cachedItems.Count + 1 : _cachedItems.Count;
        return new ItemsProviderResult<SensorDtoForList>(items, totalCount);
    }

    private async Task RefreshAsync()
    {
        _generation++;
        _cachedItems.Clear();
        _lastCursor = null;
        _hasMoreItems = true;
        _isEmpty = false;

        if (_virtualize is not null)
        {
            await _virtualize.RefreshDataAsync();
        }

        StateHasChanged();
    }

    private void ClearFilters()
    {
        SearchText = null;
        StatusFilter = SensorStatusFilter.All;
    }

    private void NavigateToMap(SensorDtoForList sensor)
    {
        Navigation.NavigateTo($"/map?lat={sensor.Latitude}&lon={sensor.Longitude}");
    }

    public void Dispose()
    {
        _fetchLock.Dispose();
    }

    public enum SensorStatusFilter
    {
        All,
        Active,
        Inactive
    }
}
