@page "/organizations/{Id:guid}"
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Components
@inject IOrganizationHttpClient OrganizationClient
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthStateService AuthState

<PageTitle>@(_organization?.Name ?? "Organization") - AquaTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">
    @if (_isLoading)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="100px" Height="100px" />
                <MudStack Spacing="2" Style="flex: 1;">
                    <MudSkeleton Width="200px" Height="32px" />
                    <MudSkeleton Width="150px" Height="20px" />
                </MudStack>
            </MudStack>
            <MudSkeleton Width="100%" Height="100px" Class="mt-4" />
        </MudPaper>
    }
    else if (_organization is null)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="NavigateBack"
                           Class="mt-3">
                    Back to Organizations
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                    @if (!string.IsNullOrWhiteSpace(_organization.ProfilePictureUrl))
                    {
                        <MudAvatar Size="Size.Large" Style="width: 100px; height: 100px;">
                            <MudImage Src="@_organization.ProfilePictureUrl" Alt="@_organization.Name" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width: 100px; height: 100px;">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" />
                        </MudAvatar>
                    }
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h4">@_organization.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Created @_organization.CreatedAt.ToString("MMMM d, yyyy")
                        </MudText>
                    </MudStack>
                </MudStack>

                @if (IsAdmin)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="NavigateToEdit">
                            Edit
                        </MudButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       OnClick="ConfirmDelete" />
                    </MudStack>
                }
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_organization.WebsiteUrl))
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
                    <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" Color="Color.Secondary" />
                    <MudLink Href="@_organization.WebsiteUrl" Target="_blank" Typo="Typo.body1">
                        @_organization.WebsiteUrl
                    </MudLink>
                </MudStack>
            }

            @if (!string.IsNullOrWhiteSpace(_organization.AboutUs))
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-2">About</MudText>
                <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">@_organization.AboutUs</MudText>
            }

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Last updated @_organization.UpdatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")
            </MudText>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrganizationDtoForDetail? _organization;
    private bool _isLoading = true;

    private bool IsAdmin => AuthState.CurrentUser?.Role == "Admin";

    protected override async Task OnInitializedAsync()
    {
        await LoadOrganizationAsync();
    }

    private async Task LoadOrganizationAsync()
    {
        _isLoading = true;
        _organization = await OrganizationClient.GetByIdAsync(Id);
        _isLoading = false;
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/organizations");
    }

    private void NavigateToEdit()
    {
        Navigation.NavigateTo($"/organizations/{Id}/edit");
    }

    private async Task ConfirmDelete()
    {
        if (_organization is null) return;

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete \"{_organization.Name}\"? This action cannot be undone." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Organization", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            try
            {
                var deleted = await OrganizationClient.DeleteAsync(Id);
                if (deleted)
                {
                    Snackbar.Add("Organization deleted successfully", Severity.Success);
                    Navigation.NavigateTo("/organizations");
                }
                else
                {
                    Snackbar.Add("Failed to delete organization", Severity.Error);
                }
            }
            catch
            {
                Snackbar.Add("Failed to delete organization", Severity.Error);
            }
        }
    }
}
