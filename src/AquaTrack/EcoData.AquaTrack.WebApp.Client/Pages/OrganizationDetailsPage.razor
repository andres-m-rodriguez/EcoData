@page "/organizations/{Id:guid}"
@using EcoData.AquaTrack.Contracts
@using EcoData.AquaTrack.Contracts.Dtos
@using EcoData.AquaTrack.Contracts.Errors
@using EcoData.AquaTrack.Contracts.Parameters
@using EcoData.AquaTrack.Application.Client
@using EcoData.AquaTrack.WebApp.Client.Services
@using EcoData.AquaTrack.WebApp.Client.Features.Organizations.Authorization
@using EcoData.AquaTrack.WebApp.Client.Features.Organizations.Components
@using EcoData.AquaTrack.WebApp.Client.Features.Sensors.Components
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject ISensorHttpClient SensorClient
@inject IOrganizationMemberHttpClient MemberClient
@inject INavigationService Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@(_organization?.Name ?? "Organization") - AquaTrack</PageTitle>

@if (LoadCommand.IsLoading)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="4">
            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="56px" Height="56px" />
            <MudStack Spacing="1">
                <MudSkeleton Width="180px" Height="28px" />
                <MudSkeleton Width="120px" Height="16px" />
            </MudStack>
        </MudStack>
        <MudGrid Class="mt-5" Spacing="3">
            @for (var i = 0; i < 2; i++)
            {
                <MudItem xs="6">
                    <MudPaper Outlined Class="pa-4">
                        <MudSkeleton Width="60px" Height="12px" />
                        <MudSkeleton Width="40px" Height="28px" Class="mt-2" />
                        <MudSkeleton Width="80px" Height="12px" Class="mt-1" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
}
else if (_organization is null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
        <MudPaper Elevation="0" Class="pa-8 rounded-lg text-center" Style="background: var(--mud-palette-background-gray)">
            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
        </MudPaper>
    </MudContainer>
}
else
{
    <HeroBanner ImageUrl="@_organization.CardPictureUrl" Height="200">
        <Actions>
            <RequireOrganizationPermission Permission="@Permissions.Organization.Update" OrganizationId="Id">
                <MudButton Variant="Variant.Filled" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Edit"
                           OnClick="NavigateToEdit">
                    Edit
                </MudButton>
            </RequireOrganizationPermission>
            <RequireOrganizationPermission Permission="@Permissions.Organization.Delete" OrganizationId="Id">
                <MudButton Variant="Variant.Filled" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Delete"
                           Class="danger" OnClick="ConfirmDelete">
                    Delete
                </MudButton>
            </RequireOrganizationPermission>
        </Actions>
    </HeroBanner>

    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <ProfileHeader AvatarUrl="@_organization.ProfilePictureUrl"
                       Title="@_organization.Name"
                       SubtitleUrl="@_organization.WebsiteUrl"
                       Caption="@($"Created {_organization.CreatedAt:MMM d, yyyy}")" />

        <MudGrid Class="mt-5" Spacing="3">
            <MudItem xs="6">
                <StatCard Label="Sensors"
                          Value="@_sensorCount.ToString()"
                          Subtitle="@($"{_sensors.Count(s => s.IsActive)} online now")" />
            </MudItem>
            <MudItem xs="6">
                <StatCard Label="Team Members"
                          Value="@_members.Count.ToString()"
                          Subtitle="@($"{_members.Count(m => m.RoleName == "Admin")} admins")" />
            </MudItem>
        </MudGrid>

        @if (!string.IsNullOrWhiteSpace(_organization.AboutUs))
        {
            <MudPaper Outlined Class="pa-4 mt-5">
                <MudText Typo="Typo.subtitle2" Class="d-inline" Style="font-weight: 600;">About</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="d-inline ml-3">
                    @_organization.AboutUs
                </MudText>
            </MudPaper>
        }

        <div class="mt-6">
            <Tabs>
                <Tab Title="Sensors" Icon="@Icons.Material.Outlined.Sensors" Badge="@_sensorCount.ToString()">
                    <RequireOrganizationPermission Permission="@Permissions.Sensor.Create" OrganizationId="Id">
                        <MudStack Row Justify="Justify.FlexEnd" Class="mb-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add" OnClick="NavigateToCreateSensor">
                                Add Sensor
                            </MudButton>
                        </MudStack>
                    </RequireOrganizationPermission>
                    @if (_sensorCount == 0)
                    {
                        <MudPaper Elevation="0" Class="pa-6 rounded-lg text-center">
                            <MudIcon Icon="@Icons.Material.Outlined.Sensors" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">No sensors yet</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Outlined Class="rounded-lg">
                            @foreach (var sensor in _sensors)
                            {
                                <SensorListItem Sensor="sensor" OnClick="NavigateToSensor" />
                            }
                        </MudPaper>
                        @if (_sensorCount > 4)
                        {
                            <MudStack Row Justify="Justify.FlexEnd" Class="mt-3">
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="NavigateToSensors">
                                    View all
                                </MudButton>
                            </MudStack>
                        }
                    }
                </Tab>
                <Tab Title="Our Team" Icon="@Icons.Material.Outlined.Group" Badge="@_members.Count.ToString()">
                    <RequireOrganizationPermission Permission="@Permissions.Organization.ManageMembers" OrganizationId="Id">
                        <MudStack Row Justify="Justify.FlexEnd" Class="mb-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="NavigateToTeam">
                                Add Member
                            </MudButton>
                        </MudStack>
                    </RequireOrganizationPermission>
                    @if (_members.Count == 0)
                    {
                        <MudPaper Elevation="0" Class="pa-6 rounded-lg text-center">
                            <MudIcon Icon="@Icons.Material.Outlined.Group" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">No members yet</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudGrid Spacing="3">
                            @foreach (var member in _members.Take(10))
                            {
                                <MudItem xs="6" sm="4" md="3" lg="2">
                                    <MemberCard DisplayName="@member.DisplayName" RoleName="@member.RoleName" />
                                </MudItem>
                            }
                        </MudGrid>
                        @if (_members.Count > 10)
                        {
                            <MudStack Row Justify="Justify.FlexEnd" Class="mt-3">
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="NavigateToTeam">
                                    View all @_members.Count members
                                </MudButton>
                            </MudStack>
                        }
                    }
                </Tab>
            </Tabs>
        </div>
    </MudContainer>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrganizationDtoForDetail? _organization;
    private List<SensorDtoForList> _sensors = [];
    private List<OrganizationMemberDto> _members = [];
    private int _sensorCount;

    protected override async Task OnInitializedAsync()
    {
        Navigation.SetFallback("/organizations");
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var organizationFetchedResult = await OrganizationClient.GetByIdAsync(Id);
        organizationFetchedResult.Switch(
            organization => _organization = organization,
            notFound => _organization = null,
            unauthorized => _organization = null
        );

        if (_organization is not null)
        {
            var parameters = new SensorParameters(PageSize: 4, OrganizationId: Id);
            _sensorCount = await SensorClient.GetSensorCountAsync(parameters);

            await foreach (var sensor in SensorClient.GetSensorsAsync(parameters))
            {
                _sensors.Add(sensor);
            }

            await foreach (var member in MemberClient.GetAllAsync(Id))
            {
                _members.Add(member);
            }
        }
    }

    private void NavigateToEdit() => Navigation.NavigateTo($"/organizations/{Id}/edit", trackReturn: true);
    private void NavigateToSensors() => Navigation.NavigateTo($"/organizations/{Id}/sensors");
    private void NavigateToTeam() => Navigation.NavigateTo($"/organizations/{Id}/team");
    private void NavigateToSensor(SensorDtoForList sensor) => Navigation.NavigateTo($"/sensors/{sensor.Id}");
    private void NavigateToCreateSensor() => Navigation.NavigateTo($"/organizations/{Id}/sensors/create", trackReturn: true);

    private async Task ConfirmDelete()
    {
        if (_organization is null) return;

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete \"{_organization.Name}\"?" },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is { Canceled: false })
        {
            var result = await OrganizationClient.DeleteAsync(Id);
            result.Switch(
                _ =>
                {
                    Snackbar.Add("Deleted", Severity.Success);
                    Navigation.NavigateTo("/organizations");
                },
                _ => Snackbar.Add("Organization not found", Severity.Error),
                error => Snackbar.Add($"Failed to delete: {error.Message}", Severity.Error)
            );
        }
    }
}
