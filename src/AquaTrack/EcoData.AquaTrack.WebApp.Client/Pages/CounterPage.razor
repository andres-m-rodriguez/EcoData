@page "/counter"

<PageTitle>Counter - AquaTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-2" />

    <MudStack Spacing="1" Class="mb-4">
        <MudText Typo="Typo.h4">Counter</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Interactive counter demonstration
        </MudText>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6" Elevation="2">
                <MudStack AlignItems="AlignItems.Center" Spacing="4">
                    <MudAvatar Color="@GetCounterColor()" Size="Size.Large" Style="width: 100px; height: 100px;">
                        <MudText Typo="Typo.h3">@_count</MudText>
                    </MudAvatar>

                    <MudText Typo="Typo.h6" Color="Color.Secondary">Current Count</MudText>

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Remove"
                                   OnClick="DecrementCount"
                                   Disabled="@(_count <= 0)">
                            Decrease
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="IncrementCount">
                            Increase
                        </MudButton>
                    </MudStack>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="ResetCount"
                               Disabled="@(_count == 0)">
                        Reset
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" />
                    <MudText Typo="Typo.h6" Class="ml-2">About This Demo</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    This is a simple counter demonstration showing Blazor's interactive capabilities.
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.TouchApp">
                        Click buttons to change the count
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Palette">
                        Color changes based on count value
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Speed">
                        Updates instantly without page reload
                    </MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int _count;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new BreadcrumbItem("Dashboard", href: "/", icon: Icons.Material.Filled.Home),
        new BreadcrumbItem("Counter", href: null, disabled: true)
    ];

    private void IncrementCount() => _count++;

    private void DecrementCount()
    {
        if (_count > 0) _count--;
    }

    private void ResetCount() => _count = 0;

    private Color GetCounterColor()
    {
        return _count switch
        {
            0 => Color.Default,
            < 5 => Color.Info,
            < 10 => Color.Success,
            < 20 => Color.Warning,
            _ => Color.Error
        };
    }
}
