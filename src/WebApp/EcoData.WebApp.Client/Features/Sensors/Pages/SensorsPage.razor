@page "/sensors"
@using EcoData.Sensors.Contracts.Dtos
@using EcoData.WebApp.Client.Features.Sensors.Components
@inject NavigationManager Navigation

<PageTitle>Sensors - EcoData</PageTitle>

<SensorList OnMapClick="NavigateToMap" />

@code {
    private void NavigateToMap(SensorDtoForList sensor)
    {
        Navigation.NavigateTo($"/map?lat={sensor.Latitude}&lon={sensor.Longitude}");
    }
}
