@using EcoData.Organization.Contracts.Dtos

<MudPaper Elevation="0" Class="pa-3 border-b">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Size="Size.Medium" Color="@GetAvatarColor(Member.DisplayName)">
                @GetInitial(Member.DisplayName)
            </MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="Typo.body2">@Member.DisplayName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Member.Email</MudText>
            </MudStack>
        </MudStack>

        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudHidden Breakpoint="Breakpoint.SmAndUp" Invert>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Joined @Member.CreatedAt.ToString("MMM d, yyyy")
                </MudText>
            </MudHidden>

            <MudChip T="string"
                     Size="Size.Small"
                     Color="@GetRoleColor(Member.RoleName)"
                     Variant="Variant.Filled">
                @if (Member.RoleName == "Admin")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Class="mr-1" />
                }
                @Member.RoleName
            </MudChip>

            @if (ShowActions)
            {
                <div @onclick:stopPropagation="true">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                             Size="Size.Small"
                             AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight">
                        <MudMenuItem Icon="@Icons.Material.Outlined.AdminPanelSettings" OnClick="HandleChangeRole">
                            Change Role
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.PersonRemove" OnClick="HandleRemove">
                            Remove
                        </MudMenuItem>
                    </MudMenu>
                </div>
            }
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public required OrganizationMemberDto Member { get; set; }

    [Parameter]
    public bool ShowActions { get; set; }

    [Parameter]
    public EventCallback<OrganizationMemberDto> OnChangeRole { get; set; }

    [Parameter]
    public EventCallback<OrganizationMemberDto> OnRemove { get; set; }

    private async Task HandleChangeRole()
    {
        await OnChangeRole.InvokeAsync(Member);
    }

    private async Task HandleRemove()
    {
        await OnRemove.InvokeAsync(Member);
    }

    private static char GetInitial(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? '?' : char.ToUpper(name[0]);
    }

    private static Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Warning,
        "Contributor" => Color.Info,
        _ => Color.Default
    };

    private static Color GetAvatarColor(string name)
    {
        var colors = new[] { Color.Primary, Color.Secondary, Color.Tertiary, Color.Info, Color.Success, Color.Warning, Color.Error };
        var hash = name.GetHashCode();
        return colors[Math.Abs(hash) % colors.Length];
    }
}
