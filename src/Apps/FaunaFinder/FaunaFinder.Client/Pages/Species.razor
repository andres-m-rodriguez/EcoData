@page "/species"
@page "/species/{Id:guid}"
@using EcoData.Wildlife.Contracts.Dtos
@using EcoData.Wildlife.Contracts.Parameters
@using EcoData.Locations.Contracts.Dtos
@using EcoData.Locations.Application.Client
@using EcoData.NativeUi.Components.NativeNavbar
@using BlazingSingularity.Fetch
@implements IDisposable
@inject ISpeciesHttpClient SpeciesHttpClient
@inject ISpeciesCategoryHttpClient SpeciesCategoryHttpClient
@inject IMunicipalityHttpClient MunicipalityHttpClient
@inject INativeNavbarManager Navbar
@inject NavigationManager NavigationManager
@inject IDialogService Dialogs
@inject IBrowserViewportService Viewport

<PageTitle>FaunaFinder - Species</PageTitle>

@if (Id is not null)
{
    <NuiPageLayout Title="@_detailFetch?.Data?.ScientificName" ParentPath="/species">
        @if (_detailFetch?.IsLoading is not false)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="240px" Class="mb-4 rounded-lg" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Class="mb-2" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
        }
        else if (_detailFetch.Data is { } detail)
        {
            <SpeciesHero Species="detail" />

            <MudPaper Elevation="0" Class="pa-4 pa-md-6 rounded-lg border-solid border mud-border-lines-default mb-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.LocationCity" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Municipalities</MudText>
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @detail.MunicipalityIds.Count
                    </MudText>
                </MudStack>

                @if (_municipalitiesFetch?.IsLoading is not false)
                {
                    <MudGrid Spacing="2">
                        @for (var i = 0; i < Math.Min(6, detail.MunicipalityIds.Count); i++)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="60px" Class="rounded-lg" />
                            </MudItem>
                        }
                    </MudGrid>
                }
                else if ((_municipalitiesFetch.Data?.Count ?? 0) == 0)
                {
                    <NuiEmptyState Icon="@Icons.Material.Outlined.LocationOff"
                                   Title="No municipalities"
                                   Description="This species has no recorded municipality associations yet." />
                }
                else
                {
                    <MudGrid Spacing="2">
                        @foreach (var muni in _municipalitiesFetch.Data!)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MunicipalityCard Municipality="muni"
                                                  OnClick="@(m => NavigateToMunicipality(m.Id))" />
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudPaper>

            <ConservationLinksPanel SpeciesId="detail.Id" />
        }
        else
        {
            <NuiEmptyState Icon="@Icons.Material.Outlined.SearchOff" Title="Species not found"
                           Description="The species you're looking for doesn't exist or has been removed." />
        }
    </NuiPageLayout>
}
else
{
    <div class="ff-page">
        <SpeciesEditorialHero Stats="@_statsFetch?.Data" />

        <SpeciesStatsRow Stats="@_statsFetch?.Data" />

        <SpeciesFeaturedRow OnSpeciesClick="NavigateToSpeciesDetail" />

        <SpeciesToolbar Filter="@_filter"
                        FilterChanged="OnFilterChanged"
                        SearchText="@_search"
                        SearchTextChanged="OnSearchChanged"
                        Sort="@_sort"
                        SortChanged="OnSortChanged"
                        Stats="@_statsFetch?.Data"
                        OnFilterClick="OpenFilterDialog" />

        <SpeciesGrid Filter="@_filter"
                     Search="@_search"
                     Sort="@_sort"
                     OnSpeciesClick="NavigateToSpeciesDetail" />
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private IFetch<SpeciesDtoForDetail?>? _detailFetch;
    private IFetch<IReadOnlyList<MunicipalityDtoForList>>? _municipalitiesFetch;
    private IFetch<SpeciesStatsDto?>? _statsFetch;
    private IFetch<SpeciesFacetsDto?>? _facetsFetch;
    private IFetch<IReadOnlyList<TaxonFacetDto>>? _taxaCountsFetch;
    private Guid? _loadedDetailId;

    private SpeciesFilterResult _filter = SpeciesFilterResult.Empty;
    private string? _search;
    private SpeciesSort _sort = SpeciesSort.ScientificNameAsc;

    protected override void OnInitialized()
    {
        Navbar.SetTitle("Species");

        _statsFetch = new Fetch<SpeciesStatsDto?>(
            SpeciesHttpClient.GetStatsAsync,
            () => InvokeAsync(StateHasChanged));
        _ = _statsFetch.FetchAsync();

        _facetsFetch = new Fetch<SpeciesFacetsDto?>(
            ct => SpeciesHttpClient.GetFacetsAsync(BuildFacetParameters(), ct),
            () => InvokeAsync(StateHasChanged));
        _ = _facetsFetch.FetchAsync();

        _taxaCountsFetch = new Fetch<IReadOnlyList<TaxonFacetDto>>(
            SpeciesCategoryHttpClient.GetCountsAsync,
            () => InvokeAsync(StateHasChanged));
        _ = _taxaCountsFetch.FetchAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id is { } id)
        {
            if (_loadedDetailId == id) return;
            _loadedDetailId = id;

            (_detailFetch as IDisposable)?.Dispose();
            (_municipalitiesFetch as IDisposable)?.Dispose();

            _detailFetch = new Fetch<SpeciesDtoForDetail?>(
                async ct =>
                {
                    var detail = await SpeciesHttpClient.GetByIdAsync(id, ct);
                    if (detail is not null)
                    {
                        _ = LoadMunicipalitiesAsync(detail.MunicipalityIds);
                    }
                    return detail;
                },
                () =>
                {
                    if (_detailFetch?.Data is { } detail)
                    {
                        Navbar.SetTitle(GetSpeciesName(detail));
                    }
                    return InvokeAsync(StateHasChanged);
                }
            );
            await _detailFetch.FetchAsync();
        }
        else
        {
            _loadedDetailId = null;
        }
    }

    private Task LoadMunicipalitiesAsync(IReadOnlyList<Guid> ids)
    {
        _municipalitiesFetch = new Fetch<IReadOnlyList<MunicipalityDtoForList>>(
            ct => MunicipalityHttpClient.GetByIdsAsync(ids, ct),
            () => InvokeAsync(StateHasChanged));
        return _municipalitiesFetch.FetchAsync();
    }

    private SpeciesParameters BuildFacetParameters() => new(
        Search: string.IsNullOrWhiteSpace(_search) ? null : _search,
        IsEndemic: _filter.IsEndemic ? true : null,
        HasProfileImage: _filter.HasPhoto ? true : null,
        IucnStatuses: _filter.IucnStatuses.Count > 0 ? _filter.IucnStatuses.ToArray() : null,
        TaxonCodes: _filter.TaxonCodes.Count > 0 ? _filter.TaxonCodes.ToArray() : null,
        MinMunicipalityCount: _filter.MinMunicipalityCount,
        ObservedSinceUtc: _filter.ObservedRecently ? DateTimeOffset.UtcNow.AddYears(-1) : null
    );

    private void RefreshFacets()
    {
        (_facetsFetch as IDisposable)?.Dispose();
        _facetsFetch = new Fetch<SpeciesFacetsDto?>(
            ct => SpeciesHttpClient.GetFacetsAsync(BuildFacetParameters(), ct),
            () => InvokeAsync(StateHasChanged));
        _ = _facetsFetch.FetchAsync();
    }

    private void OnFilterChanged(SpeciesFilterResult filter)
    {
        _filter = filter;
        RefreshFacets();
    }

    private void OnSearchChanged(string? value)
    {
        _search = value;
        RefreshFacets();
    }

    private void OnSortChanged(SpeciesSort sort)
    {
        _sort = sort;
    }

    private async Task OpenFilterDialog()
    {
        var breakpoint = await Viewport.GetCurrentBreakpointAsync();
        var isMobile = breakpoint is Breakpoint.Xs or Breakpoint.Sm;

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            FullScreen = isMobile,
        };

        var parameters = new DialogParameters<SpeciesFilterDialog>
        {
            { x => x.Initial, _filter },
            { x => x.Facets, _facetsFetch?.Data },
            { x => x.TaxaCounts, _taxaCountsFetch?.Data }
        };

        var dialog = await Dialogs.ShowAsync<SpeciesFilterDialog>("Filters", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: SpeciesFilterResult next })
        {
            OnFilterChanged(next);
        }
    }

    private void NavigateToSpeciesDetail(SpeciesDtoForList species) =>
        NavigationManager.NavigateTo($"/species/{species.Id}");

    private void NavigateToMunicipality(Guid municipalityId) =>
        NavigationManager.NavigateTo($"/municipalities/{municipalityId}");

    public void Dispose()
    {
        (_detailFetch as IDisposable)?.Dispose();
        (_municipalitiesFetch as IDisposable)?.Dispose();
        (_statsFetch as IDisposable)?.Dispose();
        (_facetsFetch as IDisposable)?.Dispose();
        (_taxaCountsFetch as IDisposable)?.Dispose();
    }

    private static string GetSpeciesName(SpeciesDtoForDetail species)
    {
        var englishName = species.CommonName.FirstOrDefault(n => n.Code == "en");
        return englishName?.Value ?? species.CommonName.FirstOrDefault()?.Value ?? species.ScientificName;
    }
}
