@page "/"
@using EcoData.Common.Maps
@using EcoData.Common.Maps.Models
@using EcoData.Locations.Application.Client
@using EcoData.Wildlife.Application.Client
@using EcoData.Wildlife.Contracts.Dtos
@using BlazingSingularity.Fetch
@inject IMunicipalityHttpClient MunicipalityHttpClient
@inject ISpeciesHttpClient SpeciesHttpClient
@inject NavigationManager NavigationManager
@inject ILocalizer L
@implements IDisposable

<PageTitle>FaunaFinder — @L["Nav_Map"]</PageTitle>

<div class="map-page">
    <div class="map-container">
        @if (_mapInitFetch.IsLoading)
        {
            <MudOverlay Visible="true" DarkBackground="false" Absolute="true" Class="map-loading-overlay" ZIndex="1000">
                <MudStack AlignItems="AlignItems.Center">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@L["Home_MapLoading"]</MudText>
                </MudStack>
            </MudOverlay>
        }
        <NuiMap TMarker="MunicipalityMarker"
                Controller="_mapController"
                Height="100%"
                Width="100%" />
    </div>

    @* Desktop Sidebar *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        @if (_selectedMunicipality is not null)
        {
            <aside class="desktop-sidebar @(_sidebarOpen ? "open" : "")">
                <MapSpeciesPanel Title="@_selectedMunicipality.Name"
                                 IsLoading="@(_speciesFetch?.IsLoading is not false)"
                                 Species="@_speciesFetch?.Data"
                                 OnClose="CloseSidebar"
                                 OnSpeciesClick="OnSpeciesClicked" />
            </aside>
        }
    </MudHidden>

    @* Mobile Bottom Sheet *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        @if (_selectedMunicipality is not null)
        {
            <div class="mobile-sheet-backdrop @(_sheetOpen ? "open" : "")" @onclick="CloseSheet"></div>
            <div class="mobile-sheet @(_sheetOpen ? "open" : "")">
                <MapSpeciesPanel Title="@_selectedMunicipality.Name"
                                 IsLoading="@(_speciesFetch?.IsLoading is not false)"
                                 Species="@_speciesFetch?.Data"
                                 OnClose="CloseSheet"
                                 OnSpeciesClick="OnSpeciesClicked" />
            </div>
        }
    </MudHidden>
</div>

@code {
    private MapController<MunicipalityMarker> _mapController = new();
    private bool _sidebarOpen;
    private bool _sheetOpen;
    private SelectedMunicipality? _selectedMunicipality;

    private IFetch<bool> _mapInitFetch = default!;
    private IFetch<IReadOnlyList<SpeciesDtoForList>>? _speciesFetch;

    protected override void OnInitialized()
    {
        L.LanguageChanged += OnLanguageChanged;
        _mapController.OnGeoJsonClicked += OnGeoJsonClicked;
        _mapInitFetch = new Fetch<bool>(
            InitMapAsync,
            () => InvokeAsync(StateHasChanged)
        );
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        await _mapInitFetch.FetchAsync();
    }

    private async Task<bool> InitMapAsync(CancellationToken ct)
    {
        var geoJson = await MunicipalityHttpClient.GetGeoJsonByStateCodeAsync("PR", ct);
        if (!string.IsNullOrEmpty(geoJson))
        {
            _mapController.AddGeoJson(new MapGeoJson
            {
                Id = "municipalities",
                Data = geoJson,
                FillColor = "#40916c",
                FillOpacity = 0.3,
                StrokeColor = "#2d6a4f",
                StrokeWidth = 2
            });
        }
        return true;
    }

    private async void OnGeoJsonClicked(string layerId, string? properties)
    {
        if (layerId != "municipalities" || string.IsNullOrEmpty(properties))
            return;

        try
        {
            using var props = System.Text.Json.JsonDocument.Parse(properties);
            var root = props.RootElement;

            if (!root.TryGetProperty("id", out var idEl) ||
                !root.TryGetProperty("name", out var nameEl))
            {
                return;
            }

            var id = idEl.GetGuid();
            if (id == Guid.Empty) return;

            var name = nameEl.GetString() ?? string.Empty;
            await InvokeAsync(() => SelectMunicipalityAsync(new SelectedMunicipality(id, name)));
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to handle municipality click: {ex.Message}");
        }
    }

    private async Task SelectMunicipalityAsync(SelectedMunicipality municipality)
    {
        _selectedMunicipality = municipality;
        _sidebarOpen = true;
        _sheetOpen = true;

        (_speciesFetch as IDisposable)?.Dispose();
        _speciesFetch = new Fetch<IReadOnlyList<SpeciesDtoForList>>(
            ct => SpeciesHttpClient.GetByMunicipalityAsync(municipality.Id, ct),
            () => InvokeAsync(StateHasChanged)
        );
        await _speciesFetch.FetchAsync();
    }

    private sealed record SelectedMunicipality(Guid Id, string Name);

    private void CloseSidebar()
    {
        _sidebarOpen = false;
        _selectedMunicipality = null;
        (_speciesFetch as IDisposable)?.Dispose();
        _speciesFetch = null;
    }

    private async Task CloseSheet()
    {
        _sheetOpen = false;
        StateHasChanged();

        await Task.Delay(300);
        _selectedMunicipality = null;
        (_speciesFetch as IDisposable)?.Dispose();
        _speciesFetch = null;
        StateHasChanged();
    }

    private void OnSpeciesClicked(SpeciesDtoForList species) =>
        NavigationManager.NavigateTo($"/species/{species.Id}");

    public void Dispose()
    {
        L.LanguageChanged -= OnLanguageChanged;
        _mapController.OnGeoJsonClicked -= OnGeoJsonClicked;
        (_mapInitFetch as IDisposable)?.Dispose();
        (_speciesFetch as IDisposable)?.Dispose();
    }

    public record MunicipalityMarker(
        MapCoordinate Coordinate,
        string? PopupContent,
        string? TooltipContent) : IMapMarker;
}
