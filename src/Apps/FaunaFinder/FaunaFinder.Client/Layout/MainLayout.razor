@inherits LayoutComponentBase
@inject INativeNavigationManager Navigation
@inject INativeNavbarManager Navbar
@implements IDisposable

<MudThemeProvider Theme="FaunaFinderTheme.Default" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="_locale" IsFixed="false">
    <MudLayout>
        <MudAppBar Color="Color.Primary" Elevation="0" Fixed="true" Class="app-bar-blur ff-appbar">
            @* Mobile: Back button + Title OR Logo *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <div class="d-flex align-center" style="flex: 1;">
                    @if (!IsHomePage)
                    {
                        <NuiNativeNavbar ShowBackButton="true" ShowTitle="false" ShowActions="false" />
                        <span class="page-title">@Navbar.State.Title</span>
                    }
                    else
                    {
                        <span class="logo-text">FaunaFinder</span>
                    }
                </div>
            </MudHidden>

            @* Desktop: Logo + Page Title *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <div class="d-flex align-center">
                    <span class="logo-text">FaunaFinder</span>
                    @if (ShowTitleDivider)
                    {
                        <MudDivider Vertical="true" FlexItem="true" Class="mx-4 my-3" />
                        <span class="page-title">@Navbar.State.Title</span>
                    }
                </div>
            </MudHidden>

            @* Desktop: Navigation links *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <nav class="ff-nav ml-6">
                    <a href="/" class="@GetNavLinkClass("/", exact: true)">Map</a>
                    <a href="/species" class="@GetNavLinkClass("/species")">Species</a>
                    <a href="/categories" class="@GetNavLinkClass("/categories")">Categories</a>
                </nav>
            </MudHidden>

            <MudSpacer />

            @* EN/ES toggle — shown on every breakpoint *@
            <div class="ff-lang-toggle" role="group" aria-label="Language">
                <button type="button"
                        class="@(_locale.Code == "en" ? "is-on" : "")"
                        @onclick="@(() => SetLocale(LocaleContext.English))">
                    EN
                </button>
                <button type="button"
                        class="@(_locale.Code == "es" ? "is-on" : "")"
                        @onclick="@(() => SetLocale(LocaleContext.Spanish))">
                    ES
                </button>
            </div>

            @* Mobile: Action button(s) at far right *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                @if (!IsHomePage)
                {
                    <NuiNativeNavbar ShowBackButton="false" ShowTitle="false" />
                }
            </MudHidden>
        </MudAppBar>

        <MudMainContent Class="main-content">
            @if (IsHomePage || IsSpeciesListPage)
            {
                @Body
            }
            else
            {
                <MudContainer MaxWidth="MaxWidth.Large" Class="py-6 px-4 content-container">
                    @Body
                </MudContainer>
            }
        </MudMainContent>
    </MudLayout>

    @* Mobile Bottom Navigation - Outside MudLayout for stability *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <div class="bottom-nav">
            <MudStack Row="true" Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Class="bottom-nav-container">
                <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Map)" Class="bottom-nav-item"
                           OnClick="@(() => NavigateToTab(NavigationTab.Map))">
                    <MudStack AlignItems="AlignItems.Center" Spacing="0">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Medium" />
                        <MudText Typo="Typo.caption">Map</MudText>
                    </MudStack>
                </MudButton>
                <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Species)" Class="bottom-nav-item"
                           OnClick="@(() => NavigateToTab(NavigationTab.Species))">
                    <MudStack AlignItems="AlignItems.Center" Spacing="0">
                        <MudIcon Icon="@Icons.Material.Filled.Pets" Size="Size.Medium" />
                        <MudText Typo="Typo.caption">Species</MudText>
                    </MudStack>
                </MudButton>
                <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Categories)" Class="bottom-nav-item"
                           OnClick="@(() => NavigateToTab(NavigationTab.Categories))">
                    <MudStack AlignItems="AlignItems.Center" Spacing="0">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Medium" />
                        <MudText Typo="Typo.caption">Categories</MudText>
                    </MudStack>
                </MudButton>
            </MudStack>
        </div>
    </MudHidden>
</CascadingValue>

@code {
    private enum NavigationTab { Map, Species, Categories }

    private NavigationTab _currentTab = NavigationTab.Map;
    private LocaleContext _locale = LocaleContext.English;

    private bool IsHomePage => Navigation.State.Path == "/" || Navigation.State.Path == "";

    private bool IsSpeciesListPage =>
        string.Equals(Navigation.State.Path, "/species", StringComparison.OrdinalIgnoreCase);

    // Hide the divider+title on pages with their own editorial hero (home, species list).
    private bool ShowTitleDivider =>
        !IsHomePage && !IsSpeciesListPage && Navbar.State.Title is not null;

    protected override void OnInitialized()
    {
        Navigation.OnStateChanged += HandleNavigationStateChanged;
        Navbar.OnStateChanged += HandleNavbarStateChanged;
        UpdateCurrentTab();
    }

    private void HandleNavigationStateChanged()
    {
        UpdateCurrentTab();
        InvokeAsync(StateHasChanged);
    }

    private void HandleNavbarStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCurrentTab()
    {
        var path = Navigation.State.Path;
        _currentTab = path switch
        {
            "/" or "" => NavigationTab.Map,
            var p when p.StartsWith("/species", StringComparison.OrdinalIgnoreCase) => NavigationTab.Species,
            var p when p.StartsWith("/categories", StringComparison.OrdinalIgnoreCase) => NavigationTab.Categories,
            _ => NavigationTab.Map
        };
    }

    private string GetNavLinkClass(string path, bool exact = false)
    {
        var currentPath = Navigation.State.Path;
        var isActive = exact
            ? (path == "/" ? currentPath == "/" || string.IsNullOrEmpty(currentPath) : string.Equals(currentPath, path, StringComparison.OrdinalIgnoreCase))
            : currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);

        return isActive ? "ff-nav-link is-active" : "ff-nav-link";
    }

    private Color GetBottomNavColor(NavigationTab tab)
    {
        return _currentTab == tab ? Color.Primary : Color.Default;
    }

    private void NavigateToTab(NavigationTab tab)
    {
        var path = tab switch
        {
            NavigationTab.Map => "/",
            NavigationTab.Species => "/species",
            NavigationTab.Categories => "/categories",
            _ => "/"
        };
        Navigation.NavigateTo(path);
    }

    private void SetLocale(LocaleContext locale)
    {
        if (_locale.Code == locale.Code) return;
        _locale = locale;
    }

    public void Dispose()
    {
        Navigation.OnStateChanged -= HandleNavigationStateChanged;
        Navbar.OnStateChanged -= HandleNavbarStateChanged;
    }
}
