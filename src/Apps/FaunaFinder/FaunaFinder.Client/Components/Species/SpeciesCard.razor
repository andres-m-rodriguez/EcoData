@namespace FaunaFinder.Client.Components.Species
@using EcoData.Wildlife.Contracts
@using EcoData.Wildlife.Contracts.Dtos

<article class="@CardClass" @onclick="HandleClick">
    <div class="ff-card-img">
        @if (Species.HasProfileImage)
        {
            <img src="@($"/wildlife/species/{Species.Id}/image")"
                 alt="@CommonName"
                 loading="lazy" />
        }
        else
        {
            <div class="ff-card-img-placeholder">
                <MudIcon Icon="@TaxonIcons.GetIcon(Species.TaxonCode)"
                         Size="Size.Large" />
            </div>
        }

        <span class="ff-card-taxa" title="@TaxonIcons.GetLabel(Species.TaxonCode)">
            <MudIcon Icon="@TaxonIcons.GetIcon(Species.TaxonCode)" Size="Size.Small" />
        </span>

        @if (Species.IsEndemic && Variant == SpeciesCardVariant.Featured)
        {
            <span class="ff-card-endemic">
                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                Endemic PR
            </span>
        }

        @if (Species.IucnStatus is { } status)
        {
            <span class="ff-status-pill ff-card-status @($"status-{status}")">@status</span>
        }
    </div>

    <div class="ff-card-body">
        <div class="ff-card-name">@CommonName</div>
        <div class="ff-card-sci">@Species.ScientificName</div>
        <div class="ff-card-foot">
            <span class="muni">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                @Species.MunicipalityCount municipios
            </span>
            <span>@FormatLastSeen(Species.LastObservedAtUtc)</span>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public required SpeciesDtoForList Species { get; set; }

    [Parameter] public SpeciesCardVariant Variant { get; set; } = SpeciesCardVariant.Default;

    [Parameter] public EventCallback<SpeciesDtoForList> OnClick { get; set; }

    [CascadingParameter] public LocaleContext Locale { get; set; } = LocaleContext.English;

    private string CommonName => Locale.Resolve(Species.CommonName, fallback: Species.ScientificName);

    private string CardClass => Variant switch
    {
        SpeciesCardVariant.Featured => "ff-card is-featured",
        SpeciesCardVariant.Medium => "ff-card is-medium",
        _ => "ff-card"
    };

    private Task HandleClick() => OnClick.InvokeAsync(Species);

    private static string FormatLastSeen(DateTimeOffset? lastSeen)
    {
        if (lastSeen is null) return "Verified";

        var delta = DateTimeOffset.UtcNow - lastSeen.Value;
        return delta switch
        {
            { TotalMinutes: < 60 } => $"{Math.Max(1, (int)delta.TotalMinutes)}m ago",
            { TotalHours: < 24 } => $"{(int)delta.TotalHours}h ago",
            { TotalDays: < 30 } => $"{(int)delta.TotalDays}d ago",
            { TotalDays: < 365 } => $"{(int)(delta.TotalDays / 30)}mo ago",
            _ => $"{(int)(delta.TotalDays / 365)}y ago"
        };
    }
}
