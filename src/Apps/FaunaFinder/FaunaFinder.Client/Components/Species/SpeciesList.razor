@namespace FaunaFinder.Client.Components.Species
@using EcoData.Wildlife.Contracts.Dtos
@using EcoData.Wildlife.Contracts.Parameters
@using EcoData.Wildlife.Application.Client
@using EcoData.Common.Pagination.Blazor
@using BlazingSingularity.Signals
@inject ISpeciesHttpClient SpeciesClient
@inject IDialogService Dialogs

@if (ShowToolbar)
{
    <MudStack Spacing="2" Class="mb-4">
        <NuiSearchBar Value="@SearchText" ValueChanged="OnSearchChanged"
                      Placeholder="@Placeholder" ShowFilterButton="true"
                      HasActiveFilters="HasActiveFilters" FilterCount="@ActiveFilterCount"
                      OnFilterClick="OpenFilterDialog" EnableSticky="false" />

        @if (HasActiveFilters)
        {
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                @if (_userCategoryName is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                             OnClose="ClearCategory">@_userCategoryName</MudChip>
                }
                @if (_userFauna != FaunaFilter.All)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                             OnClose="ClearFauna">@_userFauna.ToString()</MudChip>
                }
            </MudStack>
        }
    </MudStack>
}

<EcoDataVirtualizedList @ref="_list" TItem="SpeciesDtoForList" TParams="SpeciesParameters"
                        ItemsProvider="Fetch" ParametersBuilder="BuildParameters"
                        CursorSelector="@(s => s.Id)" ItemSize="76" OverscanCount="3">
    <LoadingTemplate>
        @for (var i = 0; i < 6; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-2 rounded-lg" />
        }
    </LoadingTemplate>
    <EmptyTemplate>
        @if (HasActiveFilters || !string.IsNullOrWhiteSpace(SearchText))
        {
            <NuiEmptyState Icon="@Icons.Material.Outlined.SearchOff" Title="No species match"
                           Description="Try adjusting your filters or search terms." />
        }
        else
        {
            <NuiEmptyState Icon="@Icons.Material.Outlined.Pets" Title="@EmptyTitle"
                           Description="@EmptyDescription" />
        }
    </EmptyTemplate>
    <ItemTemplate Context="species">
        <div class="mb-2">
            <SpeciesCard Species="species" OnClick="HandleClick" />
        </div>
    </ItemTemplate>
    <PlaceholderTemplate>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="mb-2 rounded-lg" />
    </PlaceholderTemplate>
</EcoDataVirtualizedList>

@code {
    private EcoDataVirtualizedList<SpeciesDtoForList, SpeciesParameters>? _list;

    [Signal]
    private string? _searchText;

    private Guid? _userCategoryId;
    private FaunaFilter _userFauna = FaunaFilter.All;
    private string? _userCategoryName;

    [Parameter] public Guid? MunicipalityId { get; set; }
    [Parameter] public Guid? CategoryId { get; set; }
    [Parameter] public bool? IsFauna { get; set; }
    [Parameter] public bool ShowToolbar { get; set; } = true;
    [Parameter] public string Placeholder { get; set; } = "Search species...";
    [Parameter] public string EmptyTitle { get; set; } = "No species found";
    [Parameter] public string EmptyDescription { get; set; } = "No species have been added yet.";
    [Parameter] public EventCallback<SpeciesDtoForList> OnSpeciesClick { get; set; }

    private bool HasActiveFilters => _userCategoryId is not null || _userFauna != FaunaFilter.All;
    private int ActiveFilterCount =>
        (_userCategoryId is not null ? 1 : 0) + (_userFauna != FaunaFilter.All ? 1 : 0);

    protected override void OnInitialized()
    {
        SearchTextSignal.OnChange(_ => _list?.Refresh());
    }

    private SpeciesParameters BuildParameters(Guid? cursor) => new(
        PageSize: 20,
        Cursor: cursor,
        Search: string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
        CategoryId: CategoryId ?? _userCategoryId,
        MunicipalityId: MunicipalityId,
        IsFauna: IsFauna ?? _userFauna switch
        {
            FaunaFilter.Fauna => true,
            FaunaFilter.Flora => false,
            _ => null
        }
    );

    private IAsyncEnumerable<SpeciesDtoForList> Fetch(SpeciesParameters parameters, CancellationToken ct) =>
        SpeciesClient.GetSpeciesAsync(parameters, ct);

    private Task OnSearchChanged(string? value)
    {
        SearchText = value;
        return Task.CompletedTask;
    }

    private async Task HandleClick(SpeciesDtoForList species)
    {
        if (OnSpeciesClick.HasDelegate)
        {
            await OnSpeciesClick.InvokeAsync(species);
        }
    }

    private async Task OpenFilterDialog()
    {
        var parameters = new DialogParameters<SpeciesFilterDialog>
        {
            { x => x.CategoryId, _userCategoryId },
            { x => x.Fauna, _userFauna },
            { x => x.ShowCategory, CategoryId is null }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await Dialogs.ShowAsync<SpeciesFilterDialog>("Filters", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: SpeciesFilterResult filter })
        {
            _userCategoryId = filter.CategoryId;
            _userFauna = filter.Fauna;
            _userCategoryName = null;
            _list?.Refresh();
            StateHasChanged();
        }
    }

    private void ClearCategory()
    {
        _userCategoryId = null;
        _userCategoryName = null;
        _list?.Refresh();
    }

    private void ClearFauna()
    {
        _userFauna = FaunaFilter.All;
        _list?.Refresh();
    }
}
