@namespace FaunaFinder.Client.Components.Shared

<MudPaper Elevation="0" Class="pa-4 rounded-lg border-solid border mud-border-lines-default">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
        <NuiIconBox Icon="@Icon" Color="@Color" />
        <MudStack Spacing="0">
            @if (Value is null)
            {
                <MudSkeleton Width="80px" Height="32px" />
            }
            else
            {
                <MudText Typo="Typo.h4" Class="font-weight-bold">@Value</MudText>
            }
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Label</MudText>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public required string Icon { get; set; }

    [Parameter, EditorRequired]
    public required string Label { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public Color Color { get; set; } = Color.Primary;
}
