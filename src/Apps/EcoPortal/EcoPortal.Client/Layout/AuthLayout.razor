@inherits LayoutComponentBase
@using EcoPortal.Client.Themes

<MudThemeProvider Theme="AppThemes.Azure" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-header">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="auth-logo">
                <MudIcon Icon="@Icons.Material.Filled.Water" Size="Size.Large" />
            </MudAvatar>
            <MudText Typo="Typo.h4" Class="mt-3">EcoData</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">Environmental Monitoring</MudText>
        </div>
        @Body
    </div>
</div>
