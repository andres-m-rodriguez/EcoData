@inherits LayoutComponentBase
@using BlazingSingularity
@using BlazingSingularity.Commands
@using EcoPortal.Client.Components
@using EcoPortal.Client.Pages
@using EcoPortal.Client.Services
@using EcoPortal.Client.Themes
@inject AuthStateService AuthState
@inject ClientAuthStateProvider AuthStateProvider
@inject INavigationService Navigation
@inject NavigationManager NavigationManager
@implements IDisposable

<MudThemeProvider Theme="AppThemes.Azure" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Class="app-bar-blur">

        @* Mobile: Back button + Hamburger menu (hidden on md+) *@
        <div class="d-flex d-md-none">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Edge="Edge.Start" Size="Size.Small"
                           Disabled="@(!Navigation.CanGoBack)" OnClick="NavigateBackAsync" />
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                           OnClick="ToggleDrawer" />
        </div>

        <span class="logo-text ml-2">EcoData</span>

        @* Desktop: Navigation links (hidden on sm-) *@
        <div class="d-none d-md-flex align-center ml-6 gap-4">
            <MudLink Href="@HomePage.Path" Underline="Underline.None" Class="@GetNavLinkClass(HomePage.Path)">
                Home
            </MudLink>
            <MudLink Href="@SensorsPage.Path" Underline="Underline.None" Class="@GetNavLinkClass(SensorsPage.Path)">
                Sensors
            </MudLink>
            <MudLink Href="@HealthAlertsPage.Path" Underline="Underline.None" Class="@GetNavLinkClass(HealthAlertsPage.Path)">
                Alerts
            </MudLink>
            <MudLink Href="/organizations/discover" Underline="Underline.None" Class="@GetNavLinkClass("/organizations")">
                Organizations
            </MudLink>
            <MudLink Href="@GettingStartedPage.Path" Underline="Underline.None" Class="@GetNavLinkClass(GettingStartedPage.Path)">
                Getting Started
            </MudLink>
        </div>

        <MudSpacer />

        @* Desktop: User menu (hidden on sm-) *@
        <div class="d-none d-md-flex align-center">
            @if (AuthState.IsAuthenticated)
            {
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Class="ml-2 cursor-pointer">
                            <AvatarContent>
                                <MudAvatar Color="Color.Tertiary" Size="Size.Small">
                                    @GetUserInitial()
                                </MudAvatar>
                            </AvatarContent>
                            <ChildContent>
                                @AuthState.CurrentUser?.DisplayName
                            </ChildContent>
                        </MudChip>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Person">Profile</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem OnClick="LogoutAsync" Icon="@Icons.Material.Outlined.Logout">Sign Out</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            }
            else
            {
                <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="ml-2 gradient-btn">
                    Sign In
                </MudButton>
            }
        </div>
    </MudAppBar>

    @* Mobile-only drawer *@
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Docked" Variant="DrawerVariant.Temporary"
               Elevation="1" Breakpoint="Breakpoint.Md">
        <MudToolBar Dense="true">
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" OnClick="ToggleDrawer"
                           Edge="Edge.Start" />
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Outlined.Notifications" Color="Color.Inherit" Edge="Edge.End" />
        </MudToolBar>

        <MudNavMenu Class="pt-4">
            <MudNavLink Href="@HomePage.Path" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Home">
                Home
            </MudNavLink>
            <MudNavLink Href="@SensorsPage.Path" Icon="@Icons.Material.Outlined.Water">Sensors</MudNavLink>
            <MudNavLink Href="@HealthAlertsPage.Path" Icon="@Icons.Material.Outlined.NotificationsActive">Alerts</MudNavLink>
            <MudNavLink Href="/organizations/discover" Icon="@Icons.Material.Outlined.Business">Organizations</MudNavLink>
            <MudNavLink Href="@GettingStartedPage.Path" Icon="@Icons.Material.Outlined.Help">Getting Started</MudNavLink>
        </MudNavMenu>

        <MudSpacer />

        <MudDivider />
        <MudList T="string" Dense="true">
            @if (AuthState.IsAuthenticated)
            {
                <MudListItem>
                    <ChildContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Small">
                                @GetUserInitial()
                            </MudAvatar>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@AuthState.CurrentUser?.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@AuthState.CurrentUser?.Email</MudText>
                            </MudStack>
                        </MudStack>
                    </ChildContent>
                </MudListItem>
                <MudListItem OnClick="LogoutAsync" Icon="@Icons.Material.Outlined.Logout">
                    <ChildContent>
                        <MudText Typo="Typo.body2">Sign Out</MudText>
                    </ChildContent>
                </MudListItem>
            }
            else
            {
                <MudListItem Href="/login" Icon="@Icons.Material.Outlined.Login">
                    <ChildContent>
                        <MudText Typo="Typo.body2">Sign In</MudText>
                    </ChildContent>
                </MudListItem>
            }
        </MudList>
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6 px-4 content-container">
            @Body
        </MudContainer>
        <Footer />
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;
    private bool _isDarkMode;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private async Task NavigateBackAsync()
    {
        await Navigation.GoBackAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        AuthState.SetAuthStateProvider(AuthStateProvider);
        AuthState.OnAuthStateChanged += HandleAuthStateChanged;
        Navigation.OnStateChanged += HandleNavigationStateChanged;
        NavigationManager.LocationChanged += HandleLocationChanged;
        await AuthState.InitializeAsync();
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleAuthStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleNavigationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetUserInitial()
    {
        var name = AuthState.CurrentUser?.DisplayName;
        return string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();
    }

    private string GetNavLinkClass(string path)
    {
        var currentUri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var isActive = path == "/"
            ? string.IsNullOrEmpty(currentUri) || currentUri == "/"
            : currentUri.StartsWith(path.TrimStart('/'), StringComparison.OrdinalIgnoreCase);

        return isActive ? "nav-link-active" : "nav-link";
    }

    [RelayCommand]
    private async Task Logout()
    {
        await AuthState.LogoutAsync();
    }

    private async Task LogoutAsync()
    {
        await LogoutCommand.ExecuteAsync();
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= HandleAuthStateChanged;
        Navigation.OnStateChanged -= HandleNavigationStateChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
