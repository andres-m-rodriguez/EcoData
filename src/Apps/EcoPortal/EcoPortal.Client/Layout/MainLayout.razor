@inherits LayoutComponentBase
@using BlazingSingularity
@using BlazingSingularity.Commands
@using EcoPortal.Client.Components
@using EcoPortal.Client.Pages
@using EcoPortal.Client.Services
@using EcoPortal.Client.Themes
@inject AuthStateService AuthState
@inject INativeNavigationManager Navigation
@inject INativeNavbarManager Navbar
@inject ITabNavigationService Tabs
@inject NotificationService NotificationService
@implements IAsyncDisposable

<MudThemeProvider Theme="AppThemes.Azure" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Class="app-bar-blur">

        @* Mobile: Back button + Title OR Logo *@
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <div class="d-flex align-center" style="flex: 1;">
                @if (!IsHomePage)
                {
                    <NuiNativeNavbar ShowBackButton="true" ShowTitle="false" ShowActions="false" />
                    <span class="page-title">@Navbar.State.Title</span>
                }
                else
                {
                    <span class="logo-text">Ecoportal</span>
                }
            </div>
        </MudHidden>

        @* Desktop: Logo + Page Title *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="d-flex align-center">
                <span class="logo-text">Ecoportal</span>
                @if (!IsHomePage && Navbar.State.Title is not null)
                {
                    <MudDivider Vertical="true" FlexItem="true" Class="mx-4 my-3" />
                    <span class="logo-text">@Navbar.State.Title</span>
                }
            </div>
        </MudHidden>

        @* Desktop: Navigation links *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="d-flex align-center ml-6 gap-4">
                <MudLink Href="@HomePage.Path" Underline="Underline.None" Class="@GetNavLinkClass(HomePage.Path)">
                    Home
                </MudLink>
                <MudLink Href="@SensorsPage.Path" Underline="Underline.None" Class="@GetNavLinkClass(SensorsPage.Path)">
                    Sensors
                </MudLink>
                <MudLink Href="@HealthAlertsPage.Path" Underline="Underline.None"
                         Class="@GetNavLinkClass(HealthAlertsPage.Path)">
                    Alerts
                </MudLink>
                <MudLink Href="/organizations/discover" Underline="Underline.None"
                         Class="@GetNavLinkClass("/organizations")">
                    Organizations
                </MudLink>
                <MudLink Href="@GettingStartedPage.Path" Underline="Underline.None"
                         Class="@GetNavLinkClass(GettingStartedPage.Path)">
                    Getting Started
                </MudLink>
            </div>
        </MudHidden>

        <MudSpacer />

        @* Mobile: Action button(s) at far right *@
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            @if (!IsHomePage)
            {
                <NuiNativeNavbar ShowBackButton="false" ShowTitle="false" />
            }
        </MudHidden>

        @* Desktop: User menu *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="d-flex align-center">
            @if (AuthState.IsAuthenticated)
            {
                <NotificationBell />
                <MudButton Href="/account" Variant="Variant.Text" Color="Color.Default" Class="ml-2 text-transform-none">
                    <MudAvatar Color="Color.Tertiary" Size="Size.Small" Class="mr-2">
                        @GetUserInitial()
                    </MudAvatar>
                    @AuthState.CurrentUser?.DisplayName
                </MudButton>
            }
            else
            {
                <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           Class="ml-2 gradient-btn">
                    Sign In
                </MudButton>
            }
            </div>
        </MudHidden>
    </MudAppBar>

    <MudMainContent Class="main-content">
        @* Desktop: Contextual navigation for organization pages *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            @if (AuthState.IsAuthenticated && IsUserContextPage)
            {
                <MudContainer MaxWidth="MaxWidth.Large" Class="py-2 px-4 d-flex gap-2">
                    <MudButton Href="/organizations/discover"
                               Variant="@GetUserNavVariant("/organizations/discover")"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Explore"
                               Size="Size.Small">
                        Discover
                    </MudButton>
                    <MudButton Href="/organizations/my"
                               Variant="@GetUserNavVariant("/organizations/my")"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Business"
                               Size="Size.Small">
                        My Organizations
                    </MudButton>
                    <MudButton Href="/organizations/requests"
                               Variant="@GetUserNavVariant("/organizations/requests")"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.HowToReg"
                               Size="Size.Small">
                        Access Requests
                    </MudButton>
                </MudContainer>
            }
        </MudHidden>
        @if (IsHomePage)
        {
            <div class="@_pageTransitionClass" @key="_navigationKey">
                @Body
            </div>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.Large" Class="py-6 px-4 content-container">
                <div class="@_pageTransitionClass" @key="_navigationKey">
                    @Body
                </div>
            </MudContainer>
        }
    </MudMainContent>

</MudLayout>

@* Mobile Bottom Navigation - Outside MudLayout for stability *@
<MudHidden Breakpoint="Breakpoint.MdAndUp">
    <div class="bottom-nav">
    <MudStack Row="true" Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Class="bottom-nav-container">
        <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Home)" Class="bottom-nav-item"
                   OnClick="@(() => NavigateToBottomNav(NavigationTab.Home))">
            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Medium" />
                <MudText Typo="Typo.caption">Home</MudText>
            </MudStack>
        </MudButton>
        <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Monitor)" Class="bottom-nav-item"
                   OnClick="@(() => NavigateToBottomNav(NavigationTab.Monitor))">
            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                <MudIcon Icon="@Icons.Material.Filled.Sensors" Size="Size.Medium" />
                <MudText Typo="Typo.caption">Monitor</MudText>
            </MudStack>
        </MudButton>
        <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Orgs)" Class="bottom-nav-item"
                   OnClick="@(() => NavigateToBottomNav(NavigationTab.Orgs))">
            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Medium" />
                <MudText Typo="Typo.caption">Orgs</MudText>
            </MudStack>
        </MudButton>
        <MudButton Variant="Variant.Text" Color="@GetBottomNavColor(NavigationTab.Account)" Class="bottom-nav-item"
                   OnClick="@(() => NavigateToBottomNav(NavigationTab.Account))">
            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Medium" />
                <MudText Typo="Typo.caption">Account</MudText>
            </MudStack>
        </MudButton>
    </MudStack>
    </div>
</MudHidden>

@code {
    private bool _isDarkMode;
    private string _pageTransitionClass = "";
    private string _navigationKey = Guid.NewGuid().ToString();
    private string _lastUri = "";

    private bool IsHomePage => Tabs.CurrentTab == NavigationTab.Home;

    private bool IsUserContextPage
    {
        get
        {
            var path = Navigation.State.Path;
            return path.StartsWith("/organizations", StringComparison.OrdinalIgnoreCase);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnAuthStateChanged += HandleAuthStateChanged;
        Navigation.OnStateChanged += HandleNavigationStateChanged;
        Navbar.OnStateChanged += HandleNavbarStateChanged;
        await AuthState.InitializeAsync();

        if (AuthState.IsAuthenticated)
        {
            await NotificationService.InitializeAsync();
        }
    }

    private void HandleAuthStateChanged()
    {
        InvokeAsync(async () =>
        {
            if (AuthState.IsAuthenticated)
            {
                await NotificationService.InitializeAsync();
            }
            else
            {
                NotificationService.Stop();
            }
            StateHasChanged();
        });
    }

    private void HandleNavigationStateChanged()
    {
        // Only change key and transition class on actual navigation (URI change)
        if (_lastUri != Navigation.State.Uri)
        {
            _lastUri = Navigation.State.Uri;
            _pageTransitionClass = Navigation.State.Direction switch
            {
                NavigationDirection.Forward => "page-transition-forward",
                NavigationDirection.Back => "page-transition-back",
                _ => ""
            };
            _navigationKey = Guid.NewGuid().ToString();
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleNavbarStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetUserInitial()
    {
        var name = AuthState.CurrentUser?.DisplayName;
        return string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();
    }

    private string GetNavLinkClass(string path)
    {
        var currentPath = Navigation.State.Path;
        var isActive = path == "/"
            ? currentPath == "/"
            : currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);

        return isActive ? "nav-link-active" : "nav-link";
    }

    private Variant GetUserNavVariant(string path)
    {
        var currentPath = Navigation.State.Path;
        var isActive = currentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
        return isActive ? Variant.Filled : Variant.Text;
    }

    private Color GetBottomNavColor(NavigationTab tab)
    {
        return Tabs.CurrentTab == tab ? Color.Primary : Color.Default;
    }

    private void NavigateToBottomNav(NavigationTab tab)
    {
        Tabs.NavigateToTab(tab);
    }

    [RelayCommand]
    private async Task Logout()
    {
        await AuthState.LogoutAsync();
    }

    private async Task LogoutAsync()
    {
        await LogoutCommand.ExecuteAsync();
    }

    public async ValueTask DisposeAsync()
    {
        AuthState.OnAuthStateChanged -= HandleAuthStateChanged;
        Navigation.OnStateChanged -= HandleNavigationStateChanged;
        Navbar.OnStateChanged -= HandleNavbarStateChanged;
        await NotificationService.DisposeAsync();
    }
}
