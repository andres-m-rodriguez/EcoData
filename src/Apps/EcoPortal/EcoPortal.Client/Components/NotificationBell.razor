@using EcoPortal.Client.Services
@inject NotificationService NotificationService
@implements IDisposable

<MudBadge Content="@UnreadCountDisplay"
          Visible="@HasUnread"
          Color="Color.Error"
          Overlap="true"
          Class="notification-bell">
    <MudIconButton Icon="@Icons.Material.Outlined.Notifications"
                   Color="Color.Default"
                   Size="Size.Medium"
                   OnClick="TogglePanel" />
</MudBadge>

<MudOverlay Visible="_isPanelOpen" OnClick="ClosePanel" LockScroll="false" />

<MudPopover Open="@_isPanelOpen"
            Fixed="true"
            AnchorOrigin="Origin.BottomRight"
            TransformOrigin="Origin.TopRight"
            Class="notification-popover">
    <NotificationPanel OnClose="ClosePanel" />
</MudPopover>

@code {
    private bool _isPanelOpen;

    private bool HasUnread => NotificationService.UnreadCount > 0;

    private string UnreadCountDisplay =>
        NotificationService.UnreadCount > 99 ? "99+" : NotificationService.UnreadCount.ToString();

    protected override void OnInitialized()
    {
        NotificationService.OnUnreadCountChanged += HandleUnreadCountChanged;
    }

    private void HandleUnreadCountChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void TogglePanel()
    {
        _isPanelOpen = !_isPanelOpen;
    }

    private void ClosePanel()
    {
        _isPanelOpen = false;
    }

    public void Dispose()
    {
        NotificationService.OnUnreadCountChanged -= HandleUnreadCountChanged;
    }
}

<style>
    .notification-bell {
        margin-right: 8px;
    }

    /* Pull the unread-count badge inward so it sits on the icon's top-right corner
       instead of floating above the button. Override MudBlazor's default
       translate(50%, -50%) which was pulling it back up the y-axis. */
    .notification-bell .mud-badge.mud-badge-overlap {
        top: 8px;
        right: 8px;
        transform: none;
    }

    .notification-popover {
        width: 340px;
        max-height: 440px;
        overflow: hidden;
    }
</style>
