<CascadingValue Value="this">
    <div class="tabs-container">
        <!-- Desktop: Horizontal tabs -->
        <div class="tabs-header tabs-desktop">
            @foreach (var tab in _tabs)
            {
                var isActive = tab == ActiveTab;
                <button class="tab-item @(isActive ? "active" : "")" @onclick="() => SelectTab(tab)">
                    @if (!string.IsNullOrEmpty(tab.Icon))
                    {
                        <MudIcon Icon="@tab.Icon" Size="Size.Small" />
                    }
                    <span>@tab.Title</span>
                    @if (tab.Badge is not null)
                    {
                        <span class="tab-badge">@tab.Badge</span>
                    }
                </button>
            }
        </div>

        <!-- Mobile: Dropdown -->
        <div class="tabs-header tabs-mobile">
            <MudSelect T="int" Value="ActiveIndex" ValueChanged="OnDropdownChanged" Variant="Variant.Outlined"
                       Class="tabs-dropdown" Dense="true">
                @foreach (var tab in _tabs)
                {
                    var index = _tabs.IndexOf(tab);
                    <MudSelectItem T="int" Value="index">
                        @tab.Title
                        @if (tab.Badge is not null)
                        {
                            <span class="ml-2">(@tab.Badge)</span>
                        }
                    </MudSelectItem>
                }
            </MudSelect>
        </div>

        <div class="tabs-content">
            @ChildContent
        </div>
    </div>
</CascadingValue>

@code {
    private List<Tab> _tabs = [];

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public int ActiveIndex { get; set; } = 0;

    [Parameter]
    public EventCallback<int> ActiveIndexChanged { get; set; }

    public Tab? ActiveTab => _tabs.Count > ActiveIndex ? _tabs[ActiveIndex] : _tabs.FirstOrDefault();

    public void AddTab(Tab tab)
    {
        if (!_tabs.Contains(tab))
        {
            _tabs.Add(tab);
            StateHasChanged();
        }
    }

    public void RemoveTab(Tab tab)
    {
        _tabs.Remove(tab);
        StateHasChanged();
    }

    private async Task SelectTab(Tab tab)
    {
        var index = _tabs.IndexOf(tab);
        if (index >= 0)
        {
            ActiveIndex = index;
            await ActiveIndexChanged.InvokeAsync(index);
            StateHasChanged();
        }
    }

    private async Task OnDropdownChanged(int index)
    {
        ActiveIndex = index;
        await ActiveIndexChanged.InvokeAsync(index);
        StateHasChanged();
    }
}
