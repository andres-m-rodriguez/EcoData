@using EcoData.NativeUi.Services
@inject INativeNavigationManager Navigation
@inject INativeNavbarManager Navbar

<div class="page-container mt-4 mb-8">
    @if (!string.IsNullOrEmpty(ParentPath))
    {
        <MudHidden Breakpoint="Breakpoint.Xs">
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack"
                       Class="mb-2">
                Back
            </MudButton>
        </MudHidden>
    }

    @if (!string.IsNullOrEmpty(Label) || NavbarActions is { Count: > 0 })
    {
        <div class="page-header mb-4">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    @if (!string.IsNullOrEmpty(Label))
                    {
                        <MudText Typo="Typo.overline" Color="Color.Secondary">
                            @Label
                        </MudText>
                    }
                </MudStack>

                @if (NavbarActions is { Count: > 0 })
                {
                    <MudHidden Breakpoint="Breakpoint.Xs">
                        <div class="page-actions">
                            <MudStack Row Spacing="2">
                                @foreach (var action in NavbarActions)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               OnClick="@(() => action.OnClick())">
                                        @action.Title
                                    </MudButton>
                                }
                            </MudStack>
                        </div>
                    </MudHidden>
                }
            </MudStack>
        </div>
    }

    <div class="page-content">
        @ChildContent
    </div>
</div>

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? ParentPath { get; set; }

    [Parameter]
    public IReadOnlyList<NavbarAction>? NavbarActions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        if (Title is not null)
        {
            Navbar.SetTitle(Title);
        }

        if (ParentPath is not null)
        {
            Navigation.SetParentPath(ParentPath);
        }

        if (NavbarActions is { Count: > 0 })
        {
            Navbar.SetActions(NavbarActions.ToArray());
        }
        else
        {
            Navbar.ClearActions();
        }
    }

    private void GoBack() => _ = Navigation.GoBackAsync();
}
