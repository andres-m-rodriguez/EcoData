@using EcoPortal.Client.Services
@inject INavigationService Navigation

<MudContainer MaxWidth="@MaxWidth" Class="@ContainerClass">
    @if (!string.IsNullOrEmpty(FallbackUrl))
    {
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="GoBack"
                   Class="mb-2">
            Back
        </MudButton>
    }

    @if (!string.IsNullOrEmpty(Title) || Actions is not null)
    {
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
            <MudStack Spacing="0">
                @if (!string.IsNullOrEmpty(FeatureName))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@FeatureName</MudText>
                }
                @if (!string.IsNullOrEmpty(Title))
                {
                    <MudText Typo="@TitleTypo">@Title</MudText>
                }
            </MudStack>

            @if (Actions is not null)
            {
                <MudStack Row Spacing="2">
                    @Actions
                </MudStack>
            }
        </MudStack>
    }

    @ChildContent
</MudContainer>

@code {
    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? FeatureName { get; set; }

    [Parameter]
    public string? FallbackUrl { get; set; }

    [Parameter]
    public MaxWidth MaxWidth { get; set; } = MaxWidth.Large;

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string ContainerClass => MaxWidth == MaxWidth.Small ? "pa-4" : "mt-6 mb-8";
    private Typo TitleTypo => MaxWidth == MaxWidth.Small ? Typo.h5 : Typo.h4;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(FallbackUrl))
        {
            Navigation.SetFallback(FallbackUrl);
        }
    }

    private void GoBack() => Navigation.GoBack();
}
