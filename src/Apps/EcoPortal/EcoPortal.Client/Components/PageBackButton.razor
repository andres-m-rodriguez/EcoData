@using EcoPortal.Client.Services
@inject INavigationService Navigation

<MudButton Variant="Variant.Text"
           StartIcon="@Icons.Material.Filled.ArrowBack"
           OnClick="@(() => Navigation.GoBack())"
           Class="mb-2">
    @Text
</MudButton>

@code {
    [Parameter]
    public string Text { get; set; } = "Back";
}
