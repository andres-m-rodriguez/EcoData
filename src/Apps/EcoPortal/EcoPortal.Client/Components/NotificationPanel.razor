@using EcoData.Sensors.Contracts.Dtos
@using EcoPortal.Client.Services
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@implements IDisposable

<MudPaper Elevation="0" Class="notification-panel">
    <div class="notification-header">
        <MudText Typo="Typo.subtitle2">Notifications</MudText>
        <MudSpacer />
        @if (NotificationService.UnreadCount > 0)
        {
            <MudLink Color="Color.Primary"
                     Typo="Typo.caption"
                     Underline="Underline.None"
                     OnClick="MarkAllAsReadAsync">
                Mark all read
            </MudLink>
        }
    </div>

    <div class="notification-list">
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-3">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            </div>
        }
        else if (_notifications.Count == 0)
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Outlined.NotificationsNone"
                         Size="Size.Medium"
                         Color="Color.Default" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    No notifications yet
                </MudText>
            </div>
        }
        else
        {
            @foreach (var notification in _notifications)
            {
                <div class="@GetNotificationClass(notification)"
                     @onclick="() => HandleNotificationClick(notification)">
                    <div class="notification-icon">
                        <MudIcon Icon="@GetNotificationIcon(notification.Type)"
                                 Color="@GetNotificationColor(notification.Type)"
                                 Size="Size.Small" />
                    </div>
                    <div class="notification-content">
                        <MudText Typo="Typo.body2" Class="notification-title">
                            @notification.Title
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="notification-meta">
                            @notification.SensorName · @FormatTime(notification.CreatedAt)
                        </MudText>
                    </div>
                    @if (!notification.IsRead)
                    {
                        <div class="unread-dot"></div>
                    }
                </div>
            }

            @if (_hasMore)
            {
                <div class="d-flex justify-center py-1">
                    <MudLink Typo="Typo.caption"
                             Underline="Underline.None"
                             OnClick="LoadMoreAsync"
                             Disabled="_isLoadingMore">
                        @if (_isLoadingMore)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Load more
                    </MudLink>
                </div>
            }
        }
    </div>

    <div class="notification-footer">
        <MudLink Href="/notifications"
                 Typo="Typo.caption"
                 Underline="Underline.None"
                 Color="Color.Primary">
            View all
        </MudLink>
    </div>
</MudPaper>

@code {
    [Parameter]
    public EventCallback OnClose { get; set; }

    private List<UserNotificationDto> _notifications = [];
    private bool _isLoading = true;
    private bool _isLoadingMore;
    private bool _hasMore;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        NotificationService.OnNotificationReceived += HandleNewNotification;
        await LoadNotificationsAsync();
    }

    private async Task LoadNotificationsAsync()
    {
        _isLoading = true;
        try
        {
            var notifications = await NotificationService.GetNotificationsAsync(PageSize + 1);
            _hasMore = notifications.Count > PageSize;
            _notifications = notifications.Take(PageSize).ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        if (_isLoadingMore || _notifications.Count == 0) return;

        _isLoadingMore = true;
        try
        {
            var cursor = _notifications.Last().Id;
            var notifications = await NotificationService.GetNotificationsAsync(PageSize + 1, cursor);
            _hasMore = notifications.Count > PageSize;
            _notifications.AddRange(notifications.Take(PageSize));
        }
        finally
        {
            _isLoadingMore = false;
        }
    }

    private void HandleNewNotification()
    {
        InvokeAsync(async () =>
        {
            await LoadNotificationsAsync();
            StateHasChanged();
        });
    }

    private async Task HandleNotificationClick(UserNotificationDto notification)
    {
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id);
            var index = _notifications.FindIndex(n => n.Id == notification.Id);
            if (index >= 0)
            {
                _notifications[index] = notification with { IsRead = true };
            }
        }

        await OnClose.InvokeAsync();
        Navigation.NavigateTo($"/sensors/{notification.SensorId}");
    }

    private async Task MarkAllAsReadAsync()
    {
        await NotificationService.MarkAllAsReadAsync();
        for (int i = 0; i < _notifications.Count; i++)
        {
            _notifications[i] = _notifications[i] with { IsRead = true };
        }
    }

    private string GetNotificationClass(UserNotificationDto notification)
        => "notification-item";

    private string GetNotificationIcon(string type) => type switch
    {
        "SensorStale" => Icons.Material.Filled.Warning,
        "SensorUnhealthy" => Icons.Material.Filled.Error,
        "SensorRecovered" => Icons.Material.Filled.CheckCircle,
        _ => Icons.Material.Filled.Notifications
    };

    private Color GetNotificationColor(string type) => type switch
    {
        "SensorStale" => Color.Warning,
        "SensorUnhealthy" => Color.Error,
        "SensorRecovered" => Color.Success,
        _ => Color.Default
    };

    private string FormatTime(DateTimeOffset time)
    {
        var diff = DateTimeOffset.UtcNow - time;

        if (diff.TotalMinutes < 1)
            return "Just now";
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays}d ago";

        return time.ToLocalTime().ToString("MMM d");
    }

    public void Dispose()
    {
        NotificationService.OnNotificationReceived -= HandleNewNotification;
    }
}

<style>
    .notification-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .notification-header {
        display: flex;
        align-items: center;
        padding: 8px 12px;
    }

    .notification-list {
        flex: 1;
        overflow-y: auto;
        max-height: 320px;
        border-top: 1px solid var(--mud-palette-divider);
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .notification-item {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        cursor: pointer;
        transition: background-color 0.15s;
        position: relative;
    }

    .notification-item:hover {
        background-color: var(--mud-palette-action-default-hover);
    }

    .notification-icon {
        margin-right: 10px;
        display: flex;
        align-items: center;
    }

    .notification-content {
        flex: 1;
        min-width: 0;
    }

    .notification-title {
        font-weight: 500;
        line-height: 1.25;
    }

    .notification-meta {
        line-height: 1.25;
    }

    .unread-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--mud-palette-primary);
        margin-left: 8px;
        flex-shrink: 0;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px 12px;
        gap: 4px;
    }

    .notification-footer {
        display: flex;
        justify-content: center;
        padding: 6px;
    }
</style>
