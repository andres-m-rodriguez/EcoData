@page "/notifications"
@using EcoData.Sensors.Contracts.Dtos
@using EcoPortal.Client.Services
@using EcoPortal.Client.Components
@using EcoPortal.Client.Features.Notifications.Components
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject INativeNavbarManager Navbar

<PageTitle>Notifications - EcoData</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <NotificationList OnNotificationClick="HandleNotificationClick" />
</MudContainer>

@code {
    public const string Path = "/notifications";

    protected override void OnInitialized()
    {
        Navbar.SetTitle("Notifications");
    }

    private async Task HandleNotificationClick(UserNotificationDto notification)
    {
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id);
        }

        Navigation.NavigateTo($"/sensors/{notification.SensorId}");
    }
}
