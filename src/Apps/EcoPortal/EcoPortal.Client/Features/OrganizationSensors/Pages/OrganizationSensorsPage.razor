@page "/organizations/{OrganizationId:guid}/sensors"
@using EcoData.Sensors.Contracts
@using EcoPortal.Client.Authorization
@attribute [OrganizationPermission(Permissions.Sensor.Read)]
@using EcoData.Organization.Contracts.Dtos
@using EcoData.Organization.Application.Client
@using EcoData.Sensors.Contracts.Dtos
@using EcoData.NativeUi.Services
@using EcoPortal.Client.Components
@using EcoPortal.Client.Services
@using EcoPortal.Client.Features.Sensors.Components
@using EcoPortal.Client.Features.Organizations.Authorization
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject INativeNavigationManager Navigation
@inject AuthStateService AuthState

<PageTitle>Sensors - EcoData</PageTitle>

<NuiPageLayout Title="Sensors" ParentPath="@($"/organizations/{OrganizationId}")"
                 Actions="@([new("Add", NavigateToCreateSensor)])">
    <SensorList OrganizationId="OrganizationId"
                EmptyMessage="No sensors yet"
                EmptySubMessage="Add sensors to start monitoring water quality."
                OnSensorClick="NavigateToDetail" />
</NuiPageLayout>

@code {
    [Parameter]
    public Guid OrganizationId { get; set; }

    private OrganizationDtoForDetail? _organization;

    protected override async Task OnInitializedAsync()
    {
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var result = await OrganizationClient.GetByIdAsync(OrganizationId);
        result.Switch(
            organization => _organization = organization,
            _ => _organization = null
        );
    }

    private void NavigateToCreateSensor() => Navigation.NavigateTo($"/organizations/{OrganizationId}/sensors/create");

    private void NavigateToDetail(SensorDtoForList sensor)
    {
        Navigation.NavigateTo($"/sensors/{sensor.Id}");
    }
}
