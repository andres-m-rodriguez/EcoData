@page "/organizations/{OrganizationId:guid}/sensors/create"
@using EcoData.Sensors.Contracts
@using EcoPortal.Client.Authorization
@attribute [OrganizationPermission(Permissions.Sensor.Create)]
@using EcoData.Organization.Contracts.Dtos
@using EcoData.Organization.Application.Client
@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Contracts.Requests
@using EcoData.Sensors.Application.Client
@using EcoPortal.Client.Services
@using BlazingSingularity.Commands
@using EcoPortal.Client.Features.OrganizationSensors.Dialogs
@using EcoPortal.Client.Features.Sensors.Components
@using static EcoPortal.Client.Features.Sensors.Components.SensorForm
@inject ISensorHttpClient SensorClient
@inject IOrganizationHttpClient OrganizationClient
@inject INavigationService Navigation
@inject IDialogService DialogService

<PageTitle>Add Sensor - EcoData</PageTitle>

<EcoDataPageLayout Title="Add Sensor" FallbackUrl="@($"/organizations/{OrganizationId}/sensors")">
    <ChildContent>
        @if (LoadCommand.IsLoading)
        {
            <MudPaper Elevation="1" Class="pa-6">
                <MudSkeleton Width="200px" Height="32px" />
                <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
                <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
                <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
            </MudPaper>
        }
        else if (_organization is null)
        {
            <MudPaper Elevation="1" Class="pa-6">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                    <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-6">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Adding sensor to <strong>@_organization.Name</strong>
                </MudText>

                <SensorForm Model="_formModel"
                            SubmitButtonText="Create Sensor"
                            ErrorMessage="@_errorMessage"
                            IsLoading="CreateCommand.IsLoading"
                            HideExternalId="false"
                            ShowReportingInterval="true"
                            OnSubmit="OnFormSubmit"
                            OnCancel="NavigateToSensors" />
            </MudPaper>
        }
    </ChildContent>
</EcoDataPageLayout>

@code {
    [Parameter]
    public Guid OrganizationId { get; set; }

    private OrganizationDtoForDetail? _organization;
    private SensorFormModel _formModel = new();
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var result = await OrganizationClient.GetByIdAsync(OrganizationId);
        result.Switch(
            organization => _organization = organization,
            _ => _organization = null
        );
    }

    private async Task OnFormSubmit(SensorFormModel model)
    {
        await CreateCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Create()
    {
        _errorMessage = null;

        var request = new RegisterSensorRequest(
            OrganizationId,
            _organization!.Name,
            _formModel.Name.Trim(),
            _formModel.ExternalId.Trim(),
            _formModel.Latitude,
            _formModel.Longitude,
            _formModel.MunicipalityId,
            ExpectedIntervalSeconds: _formModel.ExpectedIntervalSeconds
        );

        var result = await SensorClient.RegisterAsync(request);

        await result.Match(
            async credentials =>
            {
                await ShowCredentialsDialog(credentials);
                Navigation.NavigateTo($"/organizations/{OrganizationId}/sensors");
            },
            problem =>
            {
                _errorMessage = problem.Detail ?? "Failed to register sensor";
                return Task.CompletedTask;
            }
        );
    }

    private async Task ShowCredentialsDialog(SensorDtoForRegistered credentials)
    {
        var parameters = new DialogParameters<SensorCredentialsDialog>
        {
            { x => x.SensorId, credentials.SensorId },
            { x => x.AccessToken, credentials.AccessToken },
            { x => x.ExpiresAt, credentials.ExpiresAt },
            { x => x.SensorName, _formModel.Name }
        };

        var options = new DialogOptions
        {
            CloseButton = false,
            BackdropClick = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<SensorCredentialsDialog>("Sensor Registered", parameters, options);
        await dialog.Result;
    }

    private void NavigateToSensors() => Navigation.GoBack();
}
