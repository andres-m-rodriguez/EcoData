@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Success" />
            <MudText Typo="Typo.h6">Sensor Registered Successfully</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-2">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                Save these credentials now. The access token will not be shown again.
            </MudAlert>

            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Sensor <strong>@SensorName</strong> has been registered.
            </MudText>

            <MudTextField Value="@SensorId.ToString()"
                          Label="Sensor ID"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="@(() => CopySensorId())" />

            <MudTextField Value="@AccessToken"
                          Label="Access Token"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="@(() => CopyAccessToken())" />

            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Token expires: @ExpiresAt.ToString("yyyy-MM-dd HH:mm:ss UTC")
            </MudText>

            <MudExpansionPanels Class="mt-2">
                <MudExpansionPanel Text="Usage Example">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        Use the access token in the Authorization header:
                    </MudText>
                    <MudPaper Class="pa-3" Style="background-color: var(--mud-palette-background-grey); font-family: monospace; font-size: 0.85rem; overflow-x: auto;">
                        <pre style="margin: 0;">POST /api/push/readings
Authorization: Bearer @AccessToken
Content-Type: application/json

{
  "sensorId": "@SensorId",
  "readings": [...]
}</pre>
                    </MudPaper>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Close">
            I've Saved the Credentials
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Guid SensorId { get; set; }

    [Parameter]
    public string AccessToken { get; set; } = string.Empty;

    [Parameter]
    public DateTimeOffset ExpiresAt { get; set; }

    [Parameter]
    public string SensorName { get; set; } = string.Empty;

    private async Task CopySensorId()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", SensorId.ToString());
        Snackbar.Add("Sensor ID copied to clipboard", Severity.Success);
    }

    private async Task CopyAccessToken()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", AccessToken);
        Snackbar.Add("Access token copied to clipboard", Severity.Success);
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
