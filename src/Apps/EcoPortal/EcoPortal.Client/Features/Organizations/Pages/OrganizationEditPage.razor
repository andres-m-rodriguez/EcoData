@page "/organizations/{Id:guid}/edit"
@using EcoData.Organization.Contracts
@using EcoPortal.Client.Authorization
@attribute [OrganizationPermission(Permissions.Organization.Update)]
@using EcoData.Organization.Contracts.Dtos
@using EcoData.Organization.Application.Client
@using EcoPortal.Client.Components
@using EcoPortal.Client.Services
@using EcoPortal.Client.Features.Organizations.Components
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject INativeNavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthStateService AuthState

<PageTitle>Edit Organization - EcoData</PageTitle>

<NuiPageLayout Title="Edit Organization" ParentPath="@($"/organizations/{Id}")">
        @if (LoadCommand.IsLoading)
        {
            <MudPaper Elevation="1" Class="pa-6 rounded-lg">
                <MudSkeleton Width="200px" Height="32px" />
                <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
                <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
                <MudSkeleton Width="100%" Height="120px" Class="mt-4" />
                <MudSkeleton Width="100%" Height="56px" Class="mt-4" />
            </MudPaper>
        }
        else if (_organization is null)
        {
            <MudPaper Elevation="1" Class="pa-6 rounded-lg">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                    <MudText Typo="Typo.h6" Color="Color.Error" Class="mt-2">Organization not found</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-6 rounded-lg">
                <OrganizationForm Model="_model" SubmitButtonText="Save Changes" ErrorMessage="@_errorMessage"
                                  IsLoading="SaveCommand.IsLoading" OnSubmit="HandleSubmit" OnCancel="NavigateToDetails" />
            </MudPaper>
        }
</NuiPageLayout>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrganizationDtoForDetail? _organization;
    private readonly OrganizationForm.OrganizationFormModel _model = new();
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Load()
    {
        var result = await OrganizationClient.GetByIdAsync(Id);
        result.Switch(
            organization =>
            {
                _organization = organization;
                _model.Name = organization.Name;
                _model.ProfilePictureUrl = organization.ProfilePictureUrl;
                _model.CardPictureUrl = organization.CardPictureUrl;
                _model.AboutUs = organization.AboutUs;
                _model.WebsiteUrl = organization.WebsiteUrl;
            },
            _ => _organization = null
        );
    }

    private async Task HandleSubmit(OrganizationForm.OrganizationFormModel model)
    {
        await SaveCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Save()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _errorMessage = "Name is required";
            return;
        }

        var dto = new OrganizationDtoForUpdate(
            _model.Name,
            _model.ProfilePictureUrl,
            _model.CardPictureUrl,
            _model.AboutUs,
            _model.WebsiteUrl
        );

        var result = await OrganizationClient.UpdateAsync(Id, dto);

        result.Switch(
            _ =>
            {
                Snackbar.Add("Organization updated successfully", Severity.Success);
                Navigation.NavigateTo($"/organizations/{Id}");
            },
            problem => _errorMessage = problem.Detail ?? "Failed to update organization"
        );
    }

    private void NavigateToDetails() => _ = Navigation.GoBackAsync();
}
