@page "/organizations/create"
@using EcoData.Organization.Contracts.Dtos
@using EcoData.Organization.Application.Client
@using EcoPortal.Client.Services
@using EcoPortal.Client.Components
@using EcoPortal.Client.Features.Organizations.Components
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject INavigationService Navigation
@inject ISnackbar Snackbar

<PageTitle>Create Organization - EcoData</PageTitle>

<EcoDataPageLayout Title="Create Organization" FeatureName="Organizations" FallbackUrl="/organizations/discover" MaxWidth="MaxWidth.Small">
    <ChildContent>
        <MudPaper Elevation="1" Class="pa-6 rounded-lg">
            <OrganizationForm Model="_model" SubmitButtonText="Create" ErrorMessage="@_errorMessage"
                              IsLoading="CreateCommand.IsLoading" OnSubmit="HandleSubmit" OnCancel="NavigateBack" />
        </MudPaper>
    </ChildContent>
</EcoDataPageLayout>

@code {
    private readonly OrganizationForm.OrganizationFormModel _model = new();
    private string? _errorMessage;

    private async Task HandleSubmit(OrganizationForm.OrganizationFormModel model)
    {
        await CreateCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task Create()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _errorMessage = "Name is required";
            return;
        }

        var dto = new OrganizationDtoForCreate(
            _model.Name,
            _model.ProfilePictureUrl,
            _model.CardPictureUrl,
            _model.AboutUs,
            _model.WebsiteUrl
        );

        var result = await OrganizationClient.CreateAsync(dto);

        result.Switch(
            created =>
            {
                Snackbar.Add("Organization created successfully", Severity.Success);
                Navigation.NavigateTo($"/organizations/{created.Id}");
            },
            validationError => _errorMessage = validationError.Errors.FirstOrDefault()?.ErrorMessage ?? "Validation failed",
            apiError => _errorMessage = apiError.Message ?? "Failed to create organization"
        );
    }

    private void NavigateBack() => Navigation.GoBack();
}
