@page "/organizations/my"
@using EcoData.Organization.Contracts.Dtos
@using EcoData.Organization.Application.Client
@using EcoPortal.Client.Features.Organizations.Components
@using EcoPortal.Client.Components
@using EcoPortal.Client.Services
@using EcoPortal.Client.Pages
@using BlazingSingularity.Commands
@inject IOrganizationHttpClient OrganizationClient
@inject AuthStateService AuthState
@inject INativeNavigationManager Navigation

<PageTitle>My Organizations - EcoData</PageTitle>

<NuiPageLayout Label="Organizations" Title="My Organizations">
        <MudPaper Elevation="1" Class="pa-5 rounded-lg">
            @if (LoadMyOrganizationsCommand.IsLoading)
            {
                <MudStack Spacing="2">
                    @for (var i = 0; i < 5; i++)
                    {
                        <div class="d-flex align-center gap-3 pa-3">
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                            <MudStack Spacing="1" Class="flex-grow-1">
                                <MudSkeleton Width="60%" Height="16px" />
                                <MudSkeleton Width="30%" Height="12px" />
                            </MudStack>
                        </div>
                    }
                </MudStack>
            }
            else if (_showLoginPrompt)
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                    <MudAvatar Size="Size.Large" Color="Color.Info" Variant="Variant.Outlined">
                        <MudIcon Icon="@Icons.Material.Outlined.Login" />
                    </MudAvatar>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mt-3">
                        Please log in to see your organizations
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Sign in to view and manage your organization memberships
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Login"
                               Href="@LoginPage.Path"
                               Class="mt-3">
                        Sign In
                    </MudButton>
                </MudStack>
            }
            else if (_myOrganizations.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                    <MudAvatar Size="Size.Large" Color="Color.Default" Variant="Variant.Outlined">
                        <MudIcon Icon="@Icons.Material.Outlined.Groups" />
                    </MudAvatar>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mt-3">
                        You haven't joined any organizations yet
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Check on your pending access requests or request access to new organizations
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Inbox"
                               Href="/organizations/requests"
                               Class="mt-3">
                        View My Requests
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudStack Spacing="1">
                    @foreach (var org in _myOrganizations)
                    {
                        <OrgListItem Organization="org" OnClick="() => NavigateToOrganization(org)" />
                    }
                </MudStack>
            }
        </MudPaper>
</NuiPageLayout>

@code {
    private List<MyOrganizationDto> _myOrganizations = [];
    private bool _showLoginPrompt;

    protected override async Task OnInitializedAsync()
    {
        await LoadMyOrganizationsCommand.ExecuteAsync();
    }

    [RelayCommand]
    private async Task LoadMyOrganizations()
    {
        if (!AuthState.IsAuthenticated)
        {
            _showLoginPrompt = true;
            return;
        }

        await foreach (var org in OrganizationClient.GetMyOrganizationsAsync(CancellationToken.None))
        {
            _myOrganizations.Add(org);
        }
    }

    private void NavigateToOrganization(MyOrganizationDto organization)
    {
        Navigation.NavigateTo($"/organizations/{organization.Id}");
    }
}
