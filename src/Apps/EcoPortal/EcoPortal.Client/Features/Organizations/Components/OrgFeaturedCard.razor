@using MudBlazor

<div class="featured-card" @onclick="OnClick">
    <div class="featured-card-image">
        @if (!string.IsNullOrWhiteSpace(ImageUrl))
        {
            <img src="@ImageUrl" alt="@Title" />
        }
        else
        {
            <div class="featured-card-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Secondary" />
            </div>
        }
    </div>
    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="featured-card-title">@Title</MudText>
</div>

@code {
    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClick { get; set; }
}
