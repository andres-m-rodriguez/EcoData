@using EcoData.Organization.Contracts.Dtos
@using MudBlazor

<div class="org-list-item" @onclick="OnClick">
    <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Filled">
        @if (!string.IsNullOrWhiteSpace(Organization.ProfilePictureUrl))
        {
            <MudImage Src="@Organization.ProfilePictureUrl" Alt="@Organization.Name" />
        }
        else
        {
            @Organization.Name[0]
        }
    </MudAvatar>
    <MudStack Spacing="0" Class="flex-grow-1">
        <MudText Typo="Typo.body1" Class="org-name">@Organization.Name</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">@Organization.RoleName</MudText>
    </MudStack>
    @if (!string.IsNullOrWhiteSpace(Organization.WebsiteUrl))
    {
        <span @onclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Outlined.Language" Size="Size.Small" Color="Color.Secondary"
                           Href="@Organization.WebsiteUrl" Target="_blank" />
        </span>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public MyOrganizationDto Organization { get; set; } = null!;

    [Parameter]
    public EventCallback OnClick { get; set; }
}