@using EcoData.Sensors.Contracts.Dtos

<div class="sensor-item" @onclick="HandleClick">
    @* Desktop layout *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <div class="sensor-item-main">
            <div class="sensor-icon">
                <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Color="Color.Secondary" />
            </div>
            <div class="sensor-info">
                <h3 class="sensor-name">@Sensor.Name</h3>
                <div class="sensor-location">
                    <span class="sensor-municipality">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                        @Sensor.MunicipalityId
                    </span>
                    <span class="sensor-coords">
                        @Sensor.Latitude.ToString("F4")° N, @Math.Abs(Sensor.Longitude).ToString("F4")° W
                    </span>
                </div>
            </div>
        </div>
        <div class="sensor-item-actions">
            <div class="sensor-status @(Sensor.IsActive ? "active" : "inactive")">
                @if (Sensor.IsActive)
                {
                    <span class="status-dot"></span>
                }
                <span class="status-text">@(Sensor.IsActive ? "Active" : "Inactive")</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                           Size="Size.Small"
                           Color="Color.Default"
                           Class="sensor-menu-btn"
                           OnClick:stopPropagation="true" />
        </div>
    </MudHidden>

    @* Mobile layout - compact single row *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <span class="sensor-name-mobile">@Sensor.Name</span>
        <div class="sensor-item-actions-mobile">
            <div class="sensor-status-mobile @(Sensor.IsActive ? "active" : "inactive")">
                @if (Sensor.IsActive)
                {
                    <span class="status-dot"></span>
                }
                <span class="status-text">@(Sensor.IsActive ? "Active" : "Inactive")</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                           Size="Size.Small"
                           Color="Color.Default"
                           Class="sensor-menu-btn"
                           OnClick:stopPropagation="true" />
        </div>
    </MudHidden>
</div>

@code {
    [Parameter, EditorRequired]
    public required SensorDtoForList Sensor { get; set; }

    [Parameter]
    public EventCallback<SensorDtoForList> OnClick { get; set; }

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync(Sensor);
    }
}
