@using EcoData.Sensors.Contracts.Dtos

<MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
          Class="pa-3 cursor-pointer mud-ripple" Style="border-bottom: 1px solid var(--mud-palette-lines-default);"
          @onclick="HandleClick">
    <MudStack Spacing="0" Style="min-width: 0; flex: 1;">
        <MudText Typo="Typo.body2" Class="mud-text-truncate">@Sensor.Name</MudText>
    </MudStack>

    <MudHidden Breakpoint="Breakpoint.MdAndUp" Invert>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="flex: 0 0 120px;">@Sensor.MunicipalityId</MudText>
    </MudHidden>

    <MudHidden Breakpoint="Breakpoint.LgAndUp" Invert>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex: 0 0 180px;">
            @Sensor.Latitude.ToString("F4"), @Sensor.Longitude.ToString("F4")
        </MudText>
    </MudHidden>

    <MudChip T="string"
             Size="Size.Small"
             Color="@(Sensor.IsActive ? Color.Success : Color.Default)"
             Variant="Variant.Filled">
        @(Sensor.IsActive ? "Active" : "Inactive")
    </MudChip>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public required SensorDtoForList Sensor { get; set; }

    [Parameter]
    public EventCallback<SensorDtoForList> OnClick { get; set; }

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync(Sensor);
    }
}
