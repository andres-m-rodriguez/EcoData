@using EcoData.Sensors.Contracts.Dtos

<MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3"
          Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
    <MudStack Spacing="0">
        <MudText Typo="Typo.body2">
            @if (!string.IsNullOrWhiteSpace(Reading.Description))
            {
                @Reading.Description
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: inline;"> (@Reading.Parameter)</MudText>
            }
            else
            {
                @Reading.Parameter
            }
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @Reading.RecordedAt.LocalDateTime.ToString("g")
        </MudText>
    </MudStack>
    <MudText Typo="Typo.body1">
        @Reading.Value.ToString("F2") @Reading.Unit
    </MudText>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public required ReadingDtoForDetail Reading { get; set; }
}