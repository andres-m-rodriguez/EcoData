@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Contracts.Parameters
@using EcoData.Sensors.Application.Client
@using EcoPortal.Client.Features.Sensors.Dialogs
@using EcoData.Common.Pagination.Blazor
@using BlazingSingularity.Signals
@inject ISensorHttpClient SensorClient
@inject IDialogService DialogService

@if (ShowFilters)
{
    <SearchHeader SearchSignal="SearchTextSignal" Placeholder="Search sensors..." ShowFilterButton="true"
                  HasActiveFilters="HasNonSearchFilters" OnFilterClick="OpenFilterDialog" />
}

<div class="sensor-list-container">
    <EcoDataVirtualizedList @ref="_virtualizedList" TItem="SensorDtoForList" TParams="SensorParameters"
                            ItemsProvider="GetItemsAsync" ParametersBuilder="BuildParameters" CursorSelector="sensor => sensor.Id"
                            ItemSize="120" OverscanCount="3">
        <LoadingTemplate>
            @for (var i = 0; i < 5; i++)
            {
                <div class="sensor-skeleton-card">
                    <div class="skeleton-main">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="48px" Height="48px" />
                        <div class="skeleton-info">
                            <MudSkeleton Width="60%" Height="20px" />
                            <MudSkeleton Width="40%" Height="14px" Class="mt-2" />
                        </div>
                    </div>
                    <div class="skeleton-actions">
                        <MudSkeleton Width="70px" Height="24px" Class="rounded-pill" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                    </div>
                </div>
            }
        </LoadingTemplate>
        <EmptyTemplate>
            @if (HasActiveFilters)
            {
                <div class="sensor-empty-state">
                    <div class="empty-icon">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" />
                    </div>
                    <h4 class="empty-title">No sensors found</h4>
                    <p class="empty-description">Try adjusting your filters or search terms to find what you're looking for.</p>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="ClearFilters" Class="mt-4">
                        Clear All Filters
                    </MudButton>
                </div>
            }
            else
            {
                <div class="sensor-empty-state">
                    <div class="empty-icon">
                        <MudIcon Icon="@Icons.Material.Filled.SensorsOff" Size="Size.Large" />
                    </div>
                    <h4 class="empty-title">@EmptyMessage</h4>
                    <p class="empty-description">@EmptySubMessage</p>
                </div>
            }
        </EmptyTemplate>
        <ItemTemplate Context="sensor">
            <SensorListItem Sensor="sensor" OnClick="HandleClick" />
        </ItemTemplate>
        <PlaceholderTemplate>
            <div class="sensor-skeleton-card">
                <div class="skeleton-main">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="48px" Height="48px" />
                    <div class="skeleton-info">
                        <MudSkeleton Width="60%" Height="20px" />
                        <MudSkeleton Width="40%" Height="14px" Class="mt-2" />
                    </div>
                </div>
                <div class="skeleton-actions">
                    <MudSkeleton Width="70px" Height="24px" Class="rounded-pill" />
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" />
                </div>
            </div>
        </PlaceholderTemplate>
    </EcoDataVirtualizedList>
</div>

@code {
    private EcoDataVirtualizedList<SensorDtoForList, SensorParameters>? _virtualizedList;

    [Signal]
    private string? _searchText;

    [Signal]
    private SensorStatusFilter _statusFilter = SensorStatusFilter.All;

    [Parameter]
    public Guid? OrganizationId { get; set; }

    [Parameter]
    public bool ShowFilters { get; set; } = true;

    [Parameter]
    public int Elevation { get; set; } = 1;

    [Parameter]
    public string EmptyMessage { get; set; } = "No sensors yet";

    [Parameter]
    public string EmptySubMessage { get; set; } = "Sensors will appear here once data is ingested.";

    [Parameter]
    public EventCallback<SensorDtoForList> OnSensorClick { get; set; }

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText) || StatusFilter != SensorStatusFilter.All;
    private bool HasNonSearchFilters => StatusFilter != SensorStatusFilter.All;

    protected override void OnInitialized()
    {
        SearchTextSignal.OnChange(_ => _virtualizedList?.Refresh());
        StatusFilterSignal.OnChange(_ => _virtualizedList?.Refresh());
    }

    private async Task OpenFilterDialog()
    {
        var parameters = new DialogParameters<SensorFilterDialog>
        {
            { x => x.StatusFilter, StatusFilter }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<SensorFilterDialog>("Filters", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: SensorStatusFilter filter })
        {
            StatusFilter = filter;
        }
    }

    private SensorParameters BuildParameters(Guid? cursor)
    {
        return new SensorParameters(
            PageSize: 50,
            Cursor: cursor,
            Search: string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
            IsActive: StatusFilter switch
            {
                SensorStatusFilter.Active => true,
                SensorStatusFilter.Inactive => false,
                _ => null
            },
            OrganizationId: OrganizationId
        );
    }

    private IAsyncEnumerable<SensorDtoForList> GetItemsAsync(SensorParameters parameters, CancellationToken
cancellationToken)
    {
        return SensorClient.GetSensorsAsync(parameters, cancellationToken);
    }

    private void ClearFilters()
    {
        SearchText = null;
        StatusFilter = SensorStatusFilter.All;
    }

    private async Task HandleClick(SensorDtoForList sensor)
    {
        await OnSensorClick.InvokeAsync(sensor);
    }

    public enum SensorStatusFilter
    {
        All,
        Active,
        Inactive
    }
}
