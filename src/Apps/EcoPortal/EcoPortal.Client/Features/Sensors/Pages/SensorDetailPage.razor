@page "/sensors/{SensorId:guid}"
@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Contracts.Parameters
@using EcoData.Sensors.Application.Client
@using EcoData.Common.Pagination.Blazor
@using EcoPortal.Client.Features.Sensors.Components
@using EcoPortal.Client.Features.Sensors.Dialogs
@using BlazingSingularity.Signals
@using static EcoPortal.Client.Features.Sensors.Dialogs.ReadingFilterDialog
@using EcoPortal.Client.Services
@using EcoPortal.Client.Components
@using EcoPortal.Client.Features.Organizations.Authorization
@using SensorPermissions = EcoData.Sensors.Contracts.Permissions
@inject ISensorHttpClient SensorClient
@inject ISensorReadingHttpClient ReadingClient
@inject IDialogService DialogService
@inject INavigationService Navigation
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>@(_sensor?.Name ?? "Sensor") - EcoData</PageTitle>

<EcoDataPageLayout FallbackUrl="/sensors">
    <ChildContent>
        @if (_loading)
        {
            <MudSkeleton Width="200px" Height="32px" Class="mb-4" />
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudSkeleton Width="60%" Height="24px" Class="mb-2" />
                <MudSkeleton Width="40%" Height="16px" Class="mb-2" />
                <MudSkeleton Width="50%" Height="16px" />
            </MudPaper>
        }
        else if (_sensor is null)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.SensorsOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">Sensor not found</MudText>
            </MudStack>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.h5">@_sensor.Name</MudText>
                            <MudChip T="string" Color="@(_sensor.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                                @(_sensor.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </MudStack>
                        <RequireOrganizationPermission Permission="@SensorPermissions.Sensor.Update" OrganizationId="_sensor.OrganizationId">
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                               OnClick="NavigateToEdit" />
                                <RequireOrganizationPermission Permission="@SensorPermissions.Sensor.Delete" OrganizationId="_sensor.OrganizationId">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   OnClick="ConfirmDelete" />
                                </RequireOrganizationPermission>
                            </MudStack>
                        </RequireOrganizationPermission>
                    </MudStack>

                    <MudStack Row="true" Spacing="4" Class="mt-2">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Coordinates</MudText>
                            <MudText Typo="Typo.body2">@_sensor.Latitude.ToString("F4"), @_sensor.Longitude.ToString("F4")</MudText>
                        </MudStack>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText>
                            <MudText Typo="Typo.body2">@_sensor.CreatedAt.LocalDateTime.ToString("d")</MudText>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-4">
                <Tabs ActiveIndex="_activeTab" ActiveIndexChanged="OnTabChanged">
                    <Tab Title="History" Icon="@Icons.Material.Filled.History" />
                    <Tab Title="Live" Icon="@Icons.Material.Filled.Stream" Badge="@(_liveConnected ? "●" : null)" />
                </Tabs>

                @if (_activeTab == 0)
                {
                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshReadings" Size="Size.Small">
                            Refresh
                        </MudButton>
                    </MudStack>

                    <SearchHeader SearchSignal="SearchTextSignal" Placeholder="Search by parameter..."
                                  ShowFilterButton="true" HasActiveFilters="HasNonSearchFilters"
                                  OnFilterClick="OpenFilterDialog" />

                    <EcoDataVirtualizedList @ref="_virtualizedList" TItem="ReadingDtoForDetail" TParams="ReadingParameters"
                                            ItemsProvider="GetReadingsAsync" ParametersBuilder="BuildParameters"
                                            CursorSelector="reading => reading.Id" ItemSize="60" OverscanCount="3">
                        <LoadingTemplate>
                            @for (var i = 0; i < 8; i++)
                            {
                                <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3"
                                          Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
                                    <MudStack Spacing="1">
                                        <MudSkeleton Width="120px" Height="16px" />
                                        <MudSkeleton Width="80px" Height="12px" />
                                    </MudStack>
                                    <MudSkeleton Width="60px" Height="16px" />
                                </MudStack>
                            }
                        </LoadingTemplate>
                        <EmptyTemplate>
                            @if (HasActiveFilters)
                            {
                                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No readings found</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        No readings match your current filter criteria.
                                    </MudText>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters" Class="mt-3">
                                        Clear Filters
                                    </MudButton>
                                </MudStack>
                            }
                            else
                            {
                                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No readings yet</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        Readings will appear here once the sensor starts reporting data.
                                    </MudText>
                                </MudStack>
                            }
                        </EmptyTemplate>
                        <ItemTemplate Context="reading">
                            <ReadingListItem Reading="reading" />
                        </ItemTemplate>
                        <PlaceholderTemplate>
                            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3"
                                      Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
                                <MudStack Spacing="1">
                                    <MudSkeleton Width="120px" Height="16px" />
                                    <MudSkeleton Width="80px" Height="12px" />
                                </MudStack>
                                <MudSkeleton Width="60px" Height="16px" />
                            </MudStack>
                        </PlaceholderTemplate>
                    </EcoDataVirtualizedList>
                }
                else
                {
                    @if (_liveReconnecting)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                <MudText Typo="Typo.body2">Reconnecting...</MudText>
                            </MudStack>
                        </MudAlert>
                    }

                    @if (!_liveConnected && !_liveReconnecting && _liveReadings.Count == 0)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                            <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
                            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">Connecting...</MudText>
                        </MudStack>
                    }
                    else if (_liveReadings.Count == 0)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                            <MudIcon Icon="@Icons.Material.Filled.Sensors" Size="Size.Large" Color="Color.Primary"
                                     Class="pulse-icon" />
                            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">Waiting for readings...</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                New readings will appear here in real-time.
                            </MudText>
                        </MudStack>
                    }
                    else
                    {
                        <div class="live-readings-list">
                            @foreach (var (reading, index) in _liveReadings.Select((r, i) => (r, i)))
                            {
                                <div class="live-reading-item @(index == 0 ? "new" : "")">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@reading.Parameter</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @reading.RecordedAt.LocalDateTime.ToString("HH:mm:ss")
                                            </MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.h6" Color="Color.Primary">
                                            @reading.Value.ToString("F2") <span style="font-size: 0.75em; font-weight: normal;">@reading.Unit</span>
                                        </MudText>
                                    </MudStack>
                                </div>
                            }
                        </div>
                    }
                }
            </MudPaper>
        }
    </ChildContent>
</EcoDataPageLayout>

<style>
    .pulse-icon {
        animation: pulse-icon 2s ease-in-out infinite;
    }

    @@keyframes pulse-icon {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .live-readings-list {
        max-height: 500px;
        overflow-y: auto;
    }

    .live-reading-item {
        padding: 12px 0;
        border-bottom: 1px solid var(--mud-palette-lines-default);
        transition: background-color 0.3s ease;
    }

    .live-reading-item.new {
        animation: highlight-new 1.5s ease;
    }

    @@keyframes highlight-new {
        0% { background-color: var(--mud-palette-primary-lighten); }
        100% { background-color: transparent; }
    }
</style>

@code {
    private EcoDataVirtualizedList<ReadingDtoForDetail, ReadingParameters>? _virtualizedList;
    private SensorDtoForDetail? _sensor;
    private IReadOnlyList<string> _availableParameters = [];
    private bool _loading = true;
    private int _activeTab;

    private string? _parameterFilter;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    // Live readings state
    private readonly List<ReadingDtoForCreate> _liveReadings = new();
    private CancellationTokenSource? _liveCts;
    private bool _liveConnected;
    private bool _liveReconnecting;
    private const int MaxLiveReadings = 100;

    [Signal]
    private string? _searchText;

    [Parameter]
    public Guid SensorId { get; set; }

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(SearchText) || HasNonSearchFilters;
    private bool HasNonSearchFilters => _parameterFilter is not null || _fromDate.HasValue || _toDate.HasValue;

    protected override async Task OnInitializedAsync()
    {
        SearchTextSignal.OnChange(_ => _virtualizedList?.Refresh());

        _sensor = await SensorClient.GetByIdAsync(SensorId);

        if (_sensor is not null)
        {
            _availableParameters = await ReadingClient.GetReadingParametersAsync(SensorId);
        }

        _loading = false;
    }

    private async Task OnTabChanged(int index)
    {
        _activeTab = index;

        if (index == 1)
        {
            await StartLiveStream();
        }
        else
        {
            await StopLiveStream();
        }
    }

    private async Task StartLiveStream()
    {
        await StopLiveStream();

        _liveCts = new CancellationTokenSource();
        _ = SubscribeToLiveReadingsAsync(_liveCts.Token);
    }

    private async Task StopLiveStream()
    {
        if (_liveCts is not null)
        {
            await _liveCts.CancelAsync();
            _liveCts.Dispose();
            _liveCts = null;
        }

        _liveConnected = false;
        _liveReconnecting = false;
    }

    private async Task SubscribeToLiveReadingsAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            try
            {
                _liveConnected = true;
                _liveReconnecting = false;
                await InvokeAsync(StateHasChanged);

                await foreach (var reading in ReadingClient.SubscribeToReadingsAsync(SensorId, ct))
                {
                    _liveReadings.Insert(0, reading);

                    if (_liveReadings.Count > MaxLiveReadings)
                    {
                        _liveReadings.RemoveAt(_liveReadings.Count - 1);
                    }

                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception)
            {
                _liveConnected = false;
                _liveReconnecting = true;
                await InvokeAsync(StateHasChanged);

                // Wait before reconnecting
                try
                {
                    await Task.Delay(3000, ct);
                }
                catch (OperationCanceledException)
                {
                    break;
                }
            }
        }
    }

    private async Task OpenFilterDialog()
    {
        var parameters = new DialogParameters<ReadingFilterDialog>
        {
            { x => x.ParameterFilter, _parameterFilter },
            { x => x.FromDate, _fromDate },
            { x => x.ToDate, _toDate },
            { x => x.AvailableParameters, _availableParameters }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ReadingFilterDialog>("Filters", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ReadingFilterResult filter })
        {
            _parameterFilter = filter.Parameter;
            _fromDate = filter.FromDate;
            _toDate = filter.ToDate;
            _virtualizedList?.Refresh();
        }
    }

    private ReadingParameters BuildParameters(Guid? cursor)
    {
        var localOffset = TimeZoneInfo.Local.GetUtcOffset(DateTime.Now);

        return new ReadingParameters(
            PageSize: 50,
            Cursor: cursor,
            Search: string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
            Parameter: _parameterFilter,
            FromDate: _fromDate.HasValue ? new DateTimeOffset(_fromDate.Value, localOffset) : null,
            ToDate: _toDate.HasValue ? new DateTimeOffset(_toDate.Value.AddDays(1).AddTicks(-1), localOffset) : null
        );
    }

    private IAsyncEnumerable<ReadingDtoForDetail> GetReadingsAsync(
        ReadingParameters parameters,
        CancellationToken cancellationToken)
    {
        return ReadingClient.GetReadingsAsync(SensorId, parameters, cancellationToken);
    }

    private void RefreshReadings()
    {
        _virtualizedList?.Refresh();
    }

    private void ClearFilters()
    {
        SearchText = null;
        _parameterFilter = null;
        _fromDate = null;
        _toDate = null;
        _virtualizedList?.Refresh();
    }

    private void NavigateToEdit() => Navigation.NavigateTo($"/sensors/{SensorId}/edit", $"/sensors/{SensorId}");

    private async Task ConfirmDelete()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete sensor '{_sensor!.Name}'? This will also delete all readings and health data." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Sensor", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var deleteResult = await SensorClient.DeleteAsync(SensorId);
            deleteResult.Switch(
                _ =>
                {
                    Snackbar.Add("Sensor deleted successfully", Severity.Success);
                    Navigation.GoBack();
                },
                _ => Snackbar.Add("Sensor not found", Severity.Error),
                error => Snackbar.Add(error.Message, Severity.Error)
            );
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopLiveStream();
    }
}
