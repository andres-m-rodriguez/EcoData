@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Application.Client
@inject ISensorReadingHttpClient ReadingClient
@implements IAsyncDisposable

@if (_reconnecting)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            <MudText Typo="Typo.body2">Reconnecting...</MudText>
        </MudStack>
    </MudAlert>
}

@if (!_connected && !_reconnecting && _readings.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8" Spacing="4">
        <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.h6" Color="Color.Secondary">Connecting...</MudText>
    </MudStack>
}
else if (_readings.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Sensors" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h6" Color="Color.Secondary">Waiting for readings...</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            New readings will appear here in real-time.
        </MudText>
    </MudStack>
}
else
{
    <MudList T="ReadingDtoForCreate" Dense="true">
        @foreach (var reading in _readings)
        {
            <MudListItem T="ReadingDtoForCreate">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@reading.Parameter</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @reading.RecordedAt.LocalDateTime.ToString("HH:mm:ss")
                        </MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Baseline">
                        <MudText Typo="Typo.h6" Color="Color.Primary">@reading.Value.ToString("F2")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@reading.Unit</MudText>
                    </MudStack>
                </MudStack>
            </MudListItem>
        }
    </MudList>
}

@code {
    private readonly List<ReadingDtoForCreate> _readings = [];
    private CancellationTokenSource? _cts;
    private bool _connected;
    private bool _reconnecting;
    private const int MaxReadings = 100;

    [Parameter, EditorRequired]
    public Guid SensorId { get; set; }

    public bool IsConnected => _connected;

    protected override async Task OnInitializedAsync()
    {
        await StartStream();
    }

    private async Task StartStream()
    {
        await StopStream();

        _cts = new CancellationTokenSource();
        _ = SubscribeAsync(_cts.Token);
    }

    private async Task StopStream()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
            _cts = null;
        }

        _connected = false;
        _reconnecting = false;
    }

    private async Task SubscribeAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            try
            {
                _connected = true;
                _reconnecting = false;
                await InvokeAsync(StateHasChanged);

                await foreach (var reading in ReadingClient.SubscribeToReadingsAsync(SensorId, ct))
                {
                    _readings.Insert(0, reading);

                    if (_readings.Count > MaxReadings)
                    {
                        _readings.RemoveAt(_readings.Count - 1);
                    }

                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception)
            {
                _connected = false;
                _reconnecting = true;
                await InvokeAsync(StateHasChanged);

                try
                {
                    await Task.Delay(3000, ct);
                }
                catch (OperationCanceledException)
                {
                    break;
                }
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopStream();
    }
}
