@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Contracts.Parameters
@using EcoData.Sensors.Application.Client
@using EcoPortal.Client.Features.Sensors.Components
@using EcoPortal.Client.Services
@using BlazingSingularity.Fetch
@implements IDisposable
@inject ISensorReadingHttpClient ReadingClient
@inject INavigationService Navigation

@if (_readingsFetch.IsLoading)
{
    <MudList T="string" Dense="true">
        @for (var i = 0; i < 6; i++)
        {
            <MudListItem T="string">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1">
                        <MudSkeleton Width="120px" Height="16px" />
                        <MudSkeleton Width="80px" Height="12px" />
                    </MudStack>
                    <MudSkeleton Width="60px" Height="16px" />
                </MudStack>
            </MudListItem>
        }
    </MudList>
}
else if (_readings.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-6" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.body1" Color="Color.Secondary">No readings yet</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Readings will appear here once the sensor starts reporting data.
        </MudText>
    </MudStack>
}
else
{
    <MudList T="ReadingDtoForDetail" Dense="true" Class="readings-preview-list">
        @foreach (var reading in _readings)
        {
            <ReadingListItem Reading="reading" />
        }
    </MudList>

    @if (_hasMore)
    {
        <div class="d-flex justify-center mt-3">
            <MudButton Variant="Variant.Text" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="NavigateToReadings">
                View all readings
            </MudButton>
        </div>
    }
}

@code {
    private readonly List<ReadingDtoForDetail> _readings = [];
    private IFetch<List<ReadingDtoForDetail>> _readingsFetch = default!;
    private bool _hasMore;
    private const int PreviewCount = 6;

    [Parameter, EditorRequired]
    public Guid SensorId { get; set; }

    protected override void OnInitialized()
    {
        _readingsFetch = new Fetch<List<ReadingDtoForDetail>>(
            FetchReadingsAsync,
            () => InvokeAsync(StateHasChanged)
        );

        _ = _readingsFetch.FetchAsync();
    }

    private async Task<List<ReadingDtoForDetail>> FetchReadingsAsync(CancellationToken ct)
    {
        var parameters = new ReadingParameters(PageSize: PreviewCount + 1);
        var readings = new List<ReadingDtoForDetail>();

        await foreach (var reading in ReadingClient.GetReadingsAsync(SensorId, parameters, ct))
        {
            readings.Add(reading);
            if (readings.Count > PreviewCount)
            {
                break;
            }
        }

        _hasMore = readings.Count > PreviewCount;
        if (_hasMore)
        {
            readings.RemoveAt(readings.Count - 1);
        }

        _readings.Clear();
        _readings.AddRange(readings);

        return readings;
    }

    public void Refresh()
    {
        _ = _readingsFetch.FetchAsync();
    }

    private void NavigateToReadings()
    {
        Navigation.NavigateTo($"/sensors/{SensorId}/readings", $"/sensors/{SensorId}");
    }

    public void Dispose()
    {
        if (_readingsFetch is IDisposable disposable)
        {
            disposable.Dispose();
        }
    }
}
