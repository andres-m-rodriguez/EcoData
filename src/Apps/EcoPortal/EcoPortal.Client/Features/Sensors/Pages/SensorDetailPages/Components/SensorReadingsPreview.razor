@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Contracts.Parameters
@using EcoData.Sensors.Application.Client
@using EcoPortal.Client.Features.Sensors.Components
@inject ISensorReadingHttpClient ReadingClient
@inject INativeNavigationManager Navigation

@if (_loading)
{
    <MudList T="string" Dense="true">
        @for (var i = 0; i < 5; i++)
        {
            <MudListItem T="string">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1">
                        <MudSkeleton Width="120px" Height="16px" />
                        <MudSkeleton Width="80px" Height="12px" />
                    </MudStack>
                    <MudSkeleton Width="60px" Height="16px" />
                </MudStack>
            </MudListItem>
        }
    </MudList>
}
else if (_readings.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-4" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Medium" Color="Color.Secondary" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">No readings yet</MudText>
    </MudStack>
}
else
{
    <MudList T="ReadingDtoForDetail" Dense="true">
        @foreach (var reading in _readings)
        {
            <ReadingListItem Reading="reading" />
        }
    </MudList>
    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
               EndIcon="@Icons.Material.Filled.ArrowForward"
               OnClick="NavigateToReadings" Class="mt-2">
        View All Readings
    </MudButton>
}

@code {
    private List<ReadingDtoForDetail> _readings = [];
    private bool _loading = true;
    private CancellationTokenSource? _cts;

    [Parameter, EditorRequired]
    public Guid SensorId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadReadingsAsync();
    }

    public void Refresh()
    {
        _ = LoadReadingsAsync();
    }

    private async Task LoadReadingsAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        _loading = true;
        StateHasChanged();

        try
        {
            var parameters = new ReadingParameters(PageSize: 5);
            var readings = new List<ReadingDtoForDetail>();

            await foreach (var reading in ReadingClient.GetReadingsAsync(SensorId, parameters, _cts.Token))
            {
                readings.Add(reading);
            }

            _readings = readings;
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellation
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void NavigateToReadings()
    {
        Navigation.NavigateTo($"/sensor/{SensorId}/readings");
    }
}
