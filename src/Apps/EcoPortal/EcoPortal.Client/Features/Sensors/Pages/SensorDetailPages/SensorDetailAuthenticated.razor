@using EcoData.Sensors.Contracts.Dtos
@using EcoData.Sensors.Application.Client
@using EcoData.Locations.Application.Client
@using EcoData.Locations.Contracts.Dtos
@using EcoPortal.Client.Components
@using EcoPortal.Client.Features.Organizations.Authorization
@using EcoPortal.Client.Features.Sensors.Pages.SensorDetailPages.Components
@using BlazingSingularity.Fetch
@using SensorPermissions = EcoData.Sensors.Contracts.Permissions
@implements IDisposable
@inject ISensorHttpClient SensorClient
@inject ISensorHealthHttpClient HealthClient
@inject ISensorReadingHttpClient ReadingClient
@inject IMunicipalityHttpClient MunicipalityClient
@inject IDialogService DialogService
@inject INativeNavigationManager Navigation
@inject ISnackbar Snackbar

@* Header Card *@
<MudPaper Elevation="0" Class="pa-5 pa-md-8 mb-4 rounded-lg border-solid border mud-border-lines-default">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
            <div class="sensor-icon">
                <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Color="Color.Primary" Size="Size.Large" />
            </div>
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@Sensor.Name</MudText>
                    <MudChip T="string" Color="@(Sensor.IsActive? Color.Success: Color.Default)" Size="Size.Small"
                             Variant="Variant.Filled">
                        @(Sensor.IsActive ? "Online" : "Offline")
                    </MudChip>
                    @if (_healthFetch.IsLoading)
                    {
                        <MudSkeleton Width="60px" Height="24px" Class="rounded-pill" />
                    }
                    else if (_healthFetch.Data is not null)
                    {
                        <MudChip T="string" Color="@GetHealthStatusColor()" Size="Size.Small" Variant="Variant.Outlined">
                            @_healthFetch.Data
                        </MudChip>
                    }
                </MudStack>
                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                             Class="px-0 mud-background-gray font-monospace">
                        @Sensor.ExternalId
                    </MudChip>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                        @if (_locationFetch.IsLoading)
                        {
                            <MudSkeleton Width="120px" Height="16px" />
                        }
                        else if (_locationFetch.Data is not null)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_locationFetch.Data.Name,
                                @_locationFetch.Data.StateCode</MudText>
                            }
                        else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Sensor.Latitude.ToString("F4"),
                                    @Sensor.Longitude.ToString("F4")</MudText>
                                }
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudStack>
                <RequireOrganizationPermission Permission="@SensorPermissions.Sensor.Delete"
                                               OrganizationId="Sensor.OrganizationId">
                    <MudTooltip Text="Delete Sensor">
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Error" Variant="Variant.Outlined"
                                       Size="Size.Medium" OnClick="ConfirmDelete" />
                    </MudTooltip>
                </RequireOrganizationPermission>
            </MudStack>
        </MudPaper>

        @* Live Readings Cards *@
        <MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg border-solid border mud-border-lines-default">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Live Readings</MudText>
                </MudStack>
                @if (_statsFetch.Data?.Parameters.Count > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                        <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Class="mr-1" />
                        Live
                    </MudChip>
                }
            </MudStack>
            @if (_statsFetch.IsLoading)
            {
                <MudGrid Spacing="3">
                    @for (var i = 0; i < 4; i++)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="0" Class="pa-4 rounded-lg border-solid border mud-border-lines-default">
                                <MudStack Spacing="1">
                                    <MudSkeleton Width="80px" Height="14px" />
                                    <MudSkeleton Width="60px" Height="32px" />
                                    <MudSkeleton Width="100px" Height="12px" />
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (_statsFetch.Data?.Parameters.Count > 0)
            {
                <MudGrid Spacing="3">
                    @foreach (var param in _statsFetch.Data.Parameters)
                    {
                        var isWarning = param.ThresholdStatus is "Above" or "Below";

                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="0"
                                      Class="@($"pa-4 rounded-lg border-solid border {(isWarning ? "mud-border-warning mud-warning-lighten" : "mud-border-lines-default")}")">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption" Color="@(isWarning? Color.Warning: Color.Secondary)"
                                             Class="text-uppercase">
                                        <MudIcon Icon="@GetParameterIcon(param.Parameter)" Size="Size.Small" Class="mr-1" />
                                        @param.Parameter
                                    </MudText>
                                    <MudText Typo="Typo.h6" Color="@(isWarning? Color.Warning: Color.Default)">
                                        @param.LatestValue.ToString("F1") <span class="mud-typography-body2">@param.Unit</span>
                                    </MudText>
                                    @if (isWarning)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Warning">
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                            @param.ThresholdStatus threshold
                                        </MudText>
                                    }
                                    else if (param.ChangeFromAverage is not null)
                                    {
                                        var change = param.ChangeFromAverage.Value;
                                        var changeColor = change > 0 ? Color.Success : change < 0 ? Color.Error : Color.Secondary;
                                        var changeIcon = change > 0 ? Icons.Material.Filled.TrendingUp
                                            : change < 0 ? Icons.Material.Filled.TrendingDown
                                            : Icons.Material.Filled.Remove;
                                        var changeText = change == 0 ? "No change" : $"{change:+0.0;-0.0} from avg";

                                        <MudText Typo="Typo.caption" Color="@changeColor">
                                            <MudIcon Icon="@changeIcon" Size="Size.Small" />
                                            @changeText
                                        </MudText>
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No readings available yet</MudText>
                </MudStack>
            }
        </MudPaper>

        @* Two Column Layout - Readings + Info Cards *@
        <div class="sensor-detail-grid mb-4">
            @* Left: Readings Preview *@
            <MudPaper Elevation="0" Class="pa-4 rounded-lg readings-card border-solid border mud-border-lines-default">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Recent Readings</MudText>
                </MudStack>
                <SensorReadingsPreview @ref="_readingsPreview" SensorId="Sensor.Id" />
            </MudPaper>

            @* Right: Location + Sensor Info (stacked to match readings height) *@
            <div class="info-cards-stack">
                @* Location Card *@
                <MudPaper Elevation="0" Class="pa-4 rounded-lg flex-1 border-solid border mud-border-lines-default">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Location</MudText>
                    </MudStack>
                    <MudStack Spacing="1">
                        <SensorLocationMap Latitude="Sensor.Latitude" Longitude="Sensor.Longitude" />
                        @if (_locationFetch.IsLoading)
                        {
                            <MudStack AlignItems="AlignItems.Center">
                                <MudSkeleton Width="80%" Height="14px" />
                            </MudStack>
                        }
                        else if (_locationFetch.Data is not null)
                        {
                            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                                @_locationFetch.Data.Name, @_locationFetch.Data.StateName
                            </MudText>
                        }
                    </MudStack>
                </MudPaper>

                @* Sensor Information Card *@
                <MudPaper Elevation="0" Class="pa-4 rounded-lg flex-1 border-solid border mud-border-lines-default">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Memory" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Sensor Info</MudText>
                    </MudStack>
                    <MudStack Spacing="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">ID</MudText>
                            <MudText Typo="Typo.body2" Class="font-monospace">@Sensor.ExternalId</MudText>
                        </MudStack>
                        @if (Sensor.DataSourceName is not null)
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Source</MudText>
                                <MudText Typo="Typo.body2">@Sensor.DataSourceName</MudText>
                            </MudStack>
                        }
                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Created</MudText>
                            <MudText Typo="Typo.body2">@Sensor.CreatedAt.LocalDateTime.ToString("MMM d, yyyy")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Coords</MudText>
                            <MudText Typo="Typo.body2" Class="font-monospace">
                                @Sensor.Latitude.ToString("F2"), @Sensor.Longitude.ToString("F2")
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </div>
        </div>

        @* Quick Actions Row *@
        <MudPaper Elevation="0" Class="pa-4 rounded-lg border-solid border mud-border-lines-default">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Quick Actions</MudText>
            </MudStack>
            <div class="quick-actions-grid">
                <QuickActionCard Icon="@Icons.Material.Filled.Refresh" Title="Refresh Readings" Description="Reload latest data"
                                 OnClick="RefreshReadings" />
                <QuickActionCard Icon="@Icons.Material.Filled.Download" Title="Export Data" Description="CSV, JSON, or PDF" />
                <RequireOrganizationPermission Permission="@SensorPermissions.Sensor.Update"
                                               OrganizationId="Sensor.OrganizationId">
                    <QuickActionCard Icon="@Icons.Material.Filled.Settings" Title="Configure Sensor" Description="Health & settings"
                                     OnClick="NavigateToConfigure" />
                </RequireOrganizationPermission>
            </div>
        </MudPaper>

@code {
    private SensorReadingsPreview? _readingsPreview;
    private IFetch<MunicipalityDtoForDetail?> _locationFetch = default!;
    private IFetch<string?> _healthFetch = default!;
    private IFetch<SensorReadingStatsDto?> _statsFetch = default!;

    [Parameter, EditorRequired]
    public SensorDtoForDetail Sensor { get; set; } = default!;

    protected override void OnInitialized()
    {
        _locationFetch = new Fetch<MunicipalityDtoForDetail?>(
            ct => MunicipalityClient.GetByIdAsync(Sensor.MunicipalityId, ct),
            () => InvokeAsync(StateHasChanged)
        );

        _healthFetch = new Fetch<string?>(
            async ct =>
            {
                var result = await HealthClient.GetSensorHealthAsync(Sensor.Id, ct);
                return result.Match<string?>(
                    health => health.Status,
                    _ => null
                );
            },
            () => InvokeAsync(StateHasChanged)
        );

        _statsFetch = new Fetch<SensorReadingStatsDto?>(
            ct => ReadingClient.GetStatsAsync(Sensor.Id, null, ct),
            () => InvokeAsync(StateHasChanged)
        );

        // Start fetches in parallel
        _ = _locationFetch.FetchAsync();
        _ = _healthFetch.FetchAsync();
        _ = _statsFetch.FetchAsync();
    }

    public void Dispose()
    {
        (_locationFetch as IDisposable)?.Dispose();
        (_healthFetch as IDisposable)?.Dispose();
        (_statsFetch as IDisposable)?.Dispose();
    }

    private Color GetHealthStatusColor() => _healthFetch.Data switch
    {
        "Healthy" => Color.Success,
        "Stale" => Color.Warning,
        "Unhealthy" => Color.Error,
        _ => Color.Default
    };

    private static string GetParameterIcon(string parameter) => parameter.ToLowerInvariant() switch
    {
        "ph" => Icons.Material.Filled.Science,
        "temperature" => Icons.Material.Filled.Thermostat,
        "dissolved oxygen" => Icons.Material.Filled.Air,
        "turbidity" => Icons.Material.Filled.Visibility,
        "conductivity" => Icons.Material.Filled.ElectricBolt,
        _ => Icons.Material.Filled.Sensors
    };

    private void RefreshReadings()
    {
        _readingsPreview?.Refresh();
        _ = _statsFetch.FetchAsync();
    }

    private void NavigateToConfigure() => Navigation.NavigateTo($"/sensors/{Sensor.Id}/configure");

    private void NavigateToEdit() => Navigation.NavigateTo($"/sensors/{Sensor.Id}/edit");

    private async Task ConfirmDelete()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete sensor '{Sensor.Name}'? This will also delete all readings and health data." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Sensor", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var deleteResult = await SensorClient.DeleteAsync(Sensor.Id);
            await deleteResult.Match(
                async _ =>
                {
                    Snackbar.Add("Sensor deleted successfully", Severity.Success);
                    await Navigation.GoBackAsync();
                },
                problem =>
                {
                    Snackbar.Add(problem.Detail ?? "Failed to delete sensor", Severity.Error);
                    return Task.CompletedTask;
                }
            );
        }
    }
}

