@page "/sensors"
@using EcoData.Sensors.Contracts.Dtos
@using EcoPortal.Client.Components
@using EcoPortal.Client.Features.Sensors.Components
@using EcoPortal.Client.Services
@inject INavigationService Navigation

<PageTitle>Sensors - EcoData</PageTitle>

<EcoDataPageLayout Title="Sensors" FeatureName="Sensors">
    <ChildContent>
        <SensorList OnMapClick="NavigateToMap" OnSensorClick="NavigateToDetail" />
    </ChildContent>
</EcoDataPageLayout>

@code {
    private void NavigateToMap(SensorDtoForList sensor)
    {
        Navigation.NavigateTo($"/map?lat={sensor.Latitude}&lon={sensor.Longitude}");
    }

    private void NavigateToDetail(SensorDtoForList sensor)
    {
        Navigation.NavigateTo($"/sensors/{sensor.Id}", "/sensors");
    }
}
