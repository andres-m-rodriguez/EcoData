@page "/monitor"
@inject INativeNavigationManager Navigation
@inject INativeNavbarManager Navbar

<PageTitle>Monitor - EcoData</PageTitle>

<div class="narrow-page">
    <MudStack Spacing="2">
        <QuickActionCard Icon="@Icons.Material.Filled.Water"
                         Title="Sensors"
                         Description="View sensor data"
                         OnClick="@(() => Navigation.NavigateTo("/sensor-dashboard"))" />

        <QuickActionCard Icon="@Icons.Material.Filled.Notifications"
                         Title="Alerts"
                         Description="Health alerts"
                         OnClick="@(() => Navigation.NavigateTo("/alerts"))" />
    </MudStack>
</div>

@code {
    protected override void OnInitialized()
    {
        Navbar.SetTitle("Monitor");
    }
}
