@page "/"
@using BlazorStaticNavigation
@using EcoPortal.Client.Components

<PageTitle>EcoData - Modernizing Puerto Rico's Ecological Data</PageTitle>

<div class="landing-page page-enter">
    @* Hero Section *@
    <section class="hero-section">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudGrid Spacing="6" Class="hero-grid">
                <MudItem xs="12" lg="6">
                    <div class="hero-content">
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <span class="hero-label">Environmental Intelligence</span>
                        </MudHidden>
                        <h1 class="hero-title">Modernizing Puerto Rico's Ecological Data</h1>
                        <p class="hero-description">
                            Founded by Inter American University, this open-access platform provides students,
                            researchers, and environmental agencies with real-time monitoring data from sensors
                            deployed across Puerto Rico's rivers, coastlines, and urban areas.
                        </p>
                        <MudLink Href="@SensorsPage.Path" Underline="Underline.None" Class="hero-link">
                            Explore Sensors <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                        </MudLink>
                    </div>
                </MudItem>
                <MudHidden Breakpoint="Breakpoint.MdAndDown">
                    <MudItem xs="12" lg="6">
                        <div class="hero-visual">
                        <div class="hero-circle-outer">
                            <div class="hero-circle-inner">
                                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDE6kUTMwGHe2konqf1KBDg69kGswP4lJoqKgGC_Sp4Cahomn5rFdQWo2dAN8A2WUIWZj8nqLJ_utlzeXe6xtfzXljkV_cyO_TELt6rHYaIAxHW-e38kD0XWYqNeycjwOcXt5qT0T6lBurU6JCjd5DVL7zY_sGyRQnkMfLjgXNatcvlLAl2zzebytiLn3wtuwK3SjEpA_8sxyyOSYaAmV39a6iCrhLRvZTGzqIvoj1vNHOnXFXXJTPx4PmKUzcJJp2yoUXcesdhLEY"
                                     alt="Aerial view of Puerto Rico lush green mountains" class="hero-image" />
                                @* Floating Data Cards *@
                                <div class="floating-card floating-card-top">
                                    <span class="floating-card-label">Humidity</span>
                                    <span class="floating-card-value">84%</span>
                                </div>
                                <div class="floating-card floating-card-bottom">
                                    <span class="floating-card-label">Air Quality</span>
                                    <span class="floating-card-value">AQI 12</span>
                                </div>
                            </div>
                        </div>
                        </div>
                    </MudItem>
                </MudHidden>
            </MudGrid>
        </MudContainer>
    </section>

    @* Mission Statement *@
    <section id="mission" class="mission-section scroll-reveal">
        <MudContainer MaxWidth="MaxWidth.Medium">
            <div class="mission-accent"></div>
            <h2 class="mission-quote">
                "Our mission is to foster a data-driven culture in Puerto Rico's environmental research,
                providing researchers, educators, and the public with transparent, real-time access to
                our island's vital signs."
            </h2>
        </MudContainer>
    </section>

    @* What We Monitor *@
    <section class="monitor-section">
        <MudContainer MaxWidth="MaxWidth.Large">
            <div class="section-header scroll-reveal">
                <span class="section-label">Observation Fields</span>
                <h2 class="section-title">What We Monitor</h2>
            </div>
            <MudGrid Spacing="4">
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="monitor-card scroll-reveal">
                        <div class="monitor-image-container">
                            <img src="images/water-quality.jpg" alt="Water Quality" class="monitor-image" />
                        </div>
                        <div class="monitor-card-content">
                            <h3 class="monitor-card-title">Water Quality</h3>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Monitoring pH levels, turbidity, and dissolved oxygen across major
                                reservoirs and coastal estuaries to ensure ecosystem health.
                            </MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="monitor-card scroll-reveal">
                        <div class="monitor-image-container">
                            <img src="images/air-quality.jpg" alt="Air Quality" class="monitor-image" />
                        </div>
                        <div class="monitor-card-content">
                            <h3 class="monitor-card-title">Air Quality</h3>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                High-precision particulate matter (PM2.5/PM10) and ozone tracking within
                                urban and industrial zones to safeguard public health.
                            </MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="monitor-card scroll-reveal">
                        <div class="monitor-image-container">
                            <img src="images/biodiversity.jpg" alt="Biodiversity" class="monitor-image" />
                        </div>
                        <div class="monitor-card-content">
                            <h3 class="monitor-card-title">Biodiversity</h3>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Acoustic monitoring and soil composition analysis to track species
                                migration and habitat shifts across our nature reserves.
                            </MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </section>

    @* Data Sources *@
    <section class="sources-section scroll-reveal">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudGrid Spacing="6">
                <MudItem xs="12" lg="6">
                    <div class="section-header">
                        <span class="section-label">Aggregated Intelligence</span>
                        <h2 class="section-title">Integrated Data Sources</h2>
                    </div>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
                        EcoData bridges the gap between local research and federal monitoring
                        by unifying disparate data streams into a single, accessible API.
                    </MudText>
                    <MudPaper Elevation="0" Class="source-highlight pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" Color="Color.Secondary" />
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Unified Archive</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Access over 10 years of historical ecological records.
                                </MudText>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" lg="6">
                    <MudStack Spacing="3">
                        <MudPaper Elevation="0" Class="source-card pa-6">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
                                </MudAvatar>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">University Sensor Network</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                Localized, high-frequency monitoring stations deployed across campus research sites.
                            </MudText>
                            <MudStack Row="true" Spacing="4">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small"
                                             Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Class="text-uppercase font-weight-bold"
                                             Color="Color.Secondary">15m Intervals</MudText>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                             Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Class="text-uppercase font-weight-bold"
                                             Color="Color.Secondary">Peer Reviewed</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                        <MudPaper Elevation="0" Class="source-card pa-6">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                                <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Filled.Public" />
                                </MudAvatar>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">USGS Integration</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                Live feed integration from the U.S. Geological Survey hydrological stations nationwide.
                            </MudText>
                            <MudStack Row="true" Spacing="4">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small"
                                             Color="Color.Info" />
                                    <MudText Typo="Typo.caption" Class="text-uppercase font-weight-bold"
                                             Color="Color.Info">25-Year Archive</MudText>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small"
                                             Color="Color.Info" />
                                    <MudText Typo="Typo.caption" Class="text-uppercase font-weight-bold"
                                             Color="Color.Info">Federal Standard</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </section>

    @* For Researchers *@
    <section class="researchers-section scroll-reveal">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudGrid Spacing="6">
                <MudItem xs="12" lg="6">
                    <span class="section-label light">Academic Portal</span>
                    <h2 class="section-title light">Empowering Scientific Discovery</h2>
                    <MudText Typo="Typo.body1" Class="researchers-text mb-6">
                        We provide researchers with the tools needed to export datasets, register
                        new monitoring organizations, and collaborate on island-wide environmental studies.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Href="@GettingStartedPage.Path" Size="Size.Large"
                               Class="researchers-btn">
                        Getting Started
                    </MudButton>
                </MudItem>
                <MudItem xs="12" lg="6">
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <div class="researcher-card">
                                <MudIcon Icon="@Icons.Material.Filled.School" Class="researcher-card-icon" />
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Student Projects</MudText>
                                <MudText Typo="Typo.caption">Undergraduate research initiatives</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="6">
                            <div class="researcher-card">
                                <MudIcon Icon="@Icons.Material.Filled.CorporateFare" Class="researcher-card-icon" />
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Organization Registry</MudText>
                                <MudText Typo="Typo.caption">Join the sensor network</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="6">
                            <div class="researcher-card">
                                <MudIcon Icon="@Icons.Material.Filled.UploadFile" Class="researcher-card-icon" />
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Deploy Sensors</MudText>
                                <MudText Typo="Typo.caption">Protocol for hardware onboarding</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="6">
                            <div class="researcher-card">
                                <MudIcon Icon="@Icons.Material.Filled.Download" Class="researcher-card-icon" />
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Data Export</MudText>
                                <MudText Typo="Typo.caption">CSV, JSON & API access</MudText>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </section>

</div>

