@page "/"
@using BlazorStaticNavigation

<PageTitle>EcoData - Environmental Monitoring Platform</PageTitle>

<div class="landing-page">
    @* Hero Section *@
    <section class="hero-section">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudStack Spacing="4" AlignItems="AlignItems.Center" Class="hero-content">
                <MudText Typo="Typo.h2" Align="Align.Center" Class="hero-title">
                    Centralize Your<br />
                    <span class="text-primary">Ecological Data</span>
                </MudText>
                <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Secondary" Class="hero-subtitle">
                    Monitor real-time sensor fleets, manage research teams, and publish findings—all
                    in one scalable platform designed for modern environmental organizations.
                </MudText>
                <MudStack Row="true" Spacing="2" Justify="Justify.Center" Class="hero-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Map"
                               Href="@SensorMapPage.Path"
                               Class="hero-btn">
                        Explore the Map
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Business"
                               Href="/organizations/discover"
                               Class="hero-btn">
                        Register Organization
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudContainer>
    </section>

    @* Features Section *@
    <section class="features-section">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudText Typo="Typo.h4" Align="Align.Center" Class="section-title mb-8">
                Built for Environmental Impact
            </MudText>
            <MudGrid Spacing="4" Justify="Justify.Center">
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="feature-card pa-6">
                        <MudStack Spacing="3">
                            <div class="feature-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Sensors" Size="Size.Large" Color="Color.Primary" />
                            </div>
                            <MudText Typo="Typo.h6">Real-Time Sensors</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Track live data from your hardware deployments. Monitor status, battery life,
                                and incoming metrics from the field instantly.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="feature-card pa-6">
                        <MudStack Spacing="3">
                            <div class="feature-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Color="Color.Primary" />
                            </div>
                            <MudText Typo="Typo.h6">Team Collaboration</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Manage access levels, invite researchers, and organize your members into
                                dedicated project teams under your organization.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="feature-card pa-6">
                        <MudStack Spacing="3">
                            <div class="feature-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Science" Size="Size.Large" Color="Color.Primary" />
                            </div>
                            <MudText Typo="Typo.h6">Research Hub</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Publish and aggregate university research, linking raw sensor data directly
                                to your published environmental findings.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </section>

    @* Data Sources Section *@
    <section class="data-sources-section">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudStack Spacing="4">
                <MudStack Spacing="1" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h4">Data Sources</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                        Comprehensive environmental monitoring across Puerto Rico
                    </MudText>
                </MudStack>
                <MudGrid Spacing="4" Justify="Justify.Center">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="0" Class="data-source-card pa-6">
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                                        <MudIcon Icon="@Icons.Material.Filled.Water" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.h6">Water Quality Sensors</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Our water quality monitoring network tracks key indicators including pH levels,
                                    dissolved oxygen, turbidity, temperature, and conductivity across rivers,
                                    lakes, and coastal areas.
                                </MudText>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2">Real-time measurements</MudText>
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2">Multiple parameters per station</MudText>
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2">Historical data analysis</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="0" Class="data-source-card pa-6">
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium">
                                        <MudIcon Icon="@Icons.Material.Filled.Air" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.h6">Air Quality Sensors</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Our air quality stations monitor particulate matter (PM2.5, PM10), ozone levels,
                                    carbon monoxide, and other atmospheric conditions that impact public health
                                    and the environment.
                                </MudText>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2">EPA-standard measurements</MudText>
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2">Urban and rural coverage</MudText>
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2">Air quality index reporting</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudContainer>
    </section>

    @* CTA Section *@
    <section class="cta-section">
        <MudContainer MaxWidth="MaxWidth.Medium">
            <MudPaper Elevation="0" Class="cta-card pa-8">
                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h5" Align="Align.Center">Ready to explore the data?</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                        Access real-time environmental data from sensors across Puerto Rico.
                    </MudText>
                    <MudStack Row="true" Justify="Justify.Center" Spacing="2" Class="mt-2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Map"
                                   Href="@SensorMapPage.Path">
                            Explore the Map
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Login"
                                   Href="/login">
                            Register
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudContainer>
    </section>

    @* Footer *@
    <footer class="footer-section">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                &copy; @DateTime.Now.Year EcoData Portal. All rights reserved.
            </MudText>
        </MudContainer>
    </footer>
</div>

